# Keystatic hosted admin configuration
# Copy to .env for local testing, and set the same values in Vercel env vars.
# See docs/tech/cms-admin-setup.md for the full setup walkthrough.

# Required to enable GitHub mode. Format: owner/repo
PUBLIC_KEYSTATIC_GITHUB_REPO=

# From your GitHub App (Settings → Developer settings → GitHub Apps)
# Important: Keystatic requires a GitHub App, NOT an OAuth App.
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=

# Random secret: generate with `openssl rand -hex 32`
KEYSTATIC_SECRET=

# Optional: limit branches visible/editable in Keystatic (example: keystatic-)
PUBLIC_KEYSTATIC_BRANCH_PREFIX=
