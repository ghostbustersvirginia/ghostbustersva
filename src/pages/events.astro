---
/**
 * Events page — mission board of upcoming and past events.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import EventCard from "../components/EventCard.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getCollection } from "astro:content";
import { splitEventsByStatus } from "../lib/events";
import { getPageCopy } from "../lib/page-copy";
import { getSafeHref } from "../lib/links";

const copy = await getPageCopy("events");
const allEvents = await getCollection("events");
const { upcoming, past } = splitEventsByStatus(allEvents);
const hasUpcoming = upcoming.length > 0;

const pageTitle = copy.pageTitle || "Events";
const pageIntro =
  copy.pageIntro || "Meet the team, support local charities, and see the Ecto in person.";
const upcomingHeading = copy.upcomingHeading || "Upcoming Events";
const pastHeading = copy.pastHeading || "Past Events";
const noUpcomingEventsTitle = copy.noUpcomingEventsTitle || "No Events Scheduled Yet";
const noUpcomingEventsBody =
  copy.emptyText ||
  "No upcoming or active events are currently scheduled, but take a look at our previous events to see where we’ve been.";
const noUpcomingEventsContactText =
  copy.noUpcomingEventsContactText ||
  "Want the team at your next event? Reach out and tell us what you have in mind.";
const noUpcomingEventsContactHref = copy.noUpcomingEventsContactHref || "/contact";
const eventCtaText =
  copy.eventCtaText ||
  "Interested in having Ghostbusters Virginia appear at your event, convention, or community gathering? We love supporting charitable and community causes across the Commonwealth. Contact us today to learn more.";
const eventCtaLabel = copy.eventCtaLabel || "Contact Us";
const eventCtaHref = copy.eventCtaHref || "/contact";
const showMoreLabel = copy.showMoreLabel || "Show More";
const showLessLabel = copy.showLessLabel || "Show Less";
const metaTitle = copy.metaTitle || "Events";
const metaDescription =
  copy.metaDescription ||
  "Upcoming and past Ghostbusters Virginia events across the Commonwealth, including conventions, parades, and charity appearances.";
const ogTitleVal = copy.ogTitle || "Events | Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Find where Ghostbusters Virginia will be next and browse our past appearances.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-pageant-winner-ecto.jpg";
const safeNoUpcomingEventsContactHref = getSafeHref(noUpcomingEventsContactHref) || "/contact";
const safeEventCtaHref = getSafeHref(eventCtaHref) || "/contact";
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/events"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="events-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="events-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container">
        <SectionHeading>{upcomingHeading}</SectionHeading>
        <ul class="event-list" role="list">
          {
            hasUpcoming ? (
              upcoming.map((event) => <EventCard event={event} showCountdown />)
            ) : (
              <li class="event-empty-card">
                <div class="event-empty-card__content">
                  <h3 class="event-empty-card__title">{noUpcomingEventsTitle}</h3>
                  <p class="event-empty-card__text">{noUpcomingEventsBody}</p>
                  <p class="event-empty-card__text event-empty-card__text--contact">
                    <a href={safeNoUpcomingEventsContactHref} class="event-empty-card__link">
                      {noUpcomingEventsContactText}
                    </a>
                  </p>
                </div>
              </li>
            )
          }
        </ul>
      </div>
    </div>

    {
      past.length > 0 && (
        <div
          class:list={["page-band", "page-band--white", !hasUpcoming && "page-band--past-compact"]}
        >
          <div class="container">
            <SectionHeading>{pastHeading}</SectionHeading>
            <ul class="event-list event-list--past" id="past-events-list" role="list">
              {past.map((event, index) => (
                <EventCard
                  event={event}
                  className={`event-item--alt-bg${index >= 4 ? " past-hidden" : ""}`}
                />
              ))}
            </ul>
            {past.length > 4 && (
              <div class="past-toggle">
                <Button variant="secondary" type="button" class="toggle-btn" id="past-show-more">
                  {showMoreLabel} ({past.length - 4} more)
                </Button>
                <Button
                  variant="secondary"
                  type="button"
                  class="toggle-btn"
                  id="past-show-less"
                  hidden
                >
                  {showLessLabel}
                </Button>
              </div>
            )}
          </div>
        </div>
      )
    }

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <div class="event-cta-card">
          <p class="prose-text event-cta-text">{eventCtaText}</p>
          <Button href={safeEventCtaHref} variant="primary">{eventCtaLabel}</Button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { setupShowMoreToggle } from "../lib/show-more";

  setupShowMoreToggle({
    showMoreId: "past-show-more",
    showLessId: "past-show-less",
    hiddenClass: "past-hidden",
    containerId: "past-events-list",
    initialVisibleCount: 4,
  });
</script>

<style>
  .event-section {
    width: 100%;
  }

  .event-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .event-empty-card {
    list-style: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
  }

  .event-empty-card__content {
    padding: var(--space-xl);
    text-align: center;
  }

  .event-empty-card__title {
    margin: 0;
    font-family: var(--font-brand-title);
    font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
    color: var(--color-text);
  }

  .event-empty-card__text {
    margin: var(--space-md) 0 0;
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .event-empty-card__text--contact {
    margin-top: var(--space-lg);
    font-weight: var(--weight-medium);
  }

  .event-empty-card__link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .event-empty-card__link:hover,
  .event-empty-card__link:focus-visible {
    color: var(--color-gb-green);
    text-decoration: underline;
  }

  .past-hidden {
    display: none;
  }

  .past-toggle {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .page-band--past-compact {
    padding-top: 0;
  }

  .event-cta-card {
    max-width: var(--content-width-mid);
    margin: 0 auto;
    padding: var(--space-2xl);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    box-shadow: var(--shadow-panel);
    display: grid;
    justify-items: center;
    gap: var(--space-lg);
    text-align: center;
  }

  .event-cta-text {
    margin-bottom: 0;
  }
</style>
