---
/**
 * Events page — mission board of upcoming and past events.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import EventCard from "../components/EventCard.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getCollection } from "astro:content";
import { splitEventsByStatus } from "../lib/events";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("events");
const allEvents = await getCollection("events");
const { upcoming, past } = splitEventsByStatus(allEvents);

const pageTitle = (copy?.pageTitle as string) || "Events";
const pageIntro =
  (copy?.pageIntro as string) ||
  "Meet the team, support local charities, and see the Ecto in person.";
const upcomingHeading = (copy?.upcomingHeading as string) || "Upcoming Events";
const pastHeading = (copy?.pastHeading as string) || "Past Events";
const emptyText = (copy?.emptyText as string) || "No events yet — check back soon!";
const showMoreLabel = (copy?.showMoreLabel as string) || "Show More";
const showLessLabel = (copy?.showLessLabel as string) || "Show Less";
const metaTitle = (copy?.metaTitle as string) || "Events";
const metaDescription =
  (copy?.metaDescription as string) ||
  "Upcoming and past Ghostbusters Virginia events across the Commonwealth, including conventions, parades, and charity appearances.";
const ogTitleVal = (copy?.ogTitle as string) || "Events | Ghostbusters Virginia";
const ogDescriptionVal =
  (copy?.ogDescription as string) ||
  "Find where Ghostbusters Virginia will be next and browse our past appearances.";
const ogImage =
  (copy?.ogImage as string) || "/images/ghostbusters-virginia-pageant-winner-ecto.jpg";
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/events"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="events-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="events-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    {
      upcoming.length > 0 && (
        <div class="page-band page-band--alt">
          <div class="container">
            <SectionHeading>{upcomingHeading}</SectionHeading>
            <ul class="event-list" role="list">
              {upcoming.map((event) => (
                <EventCard event={event} showCountdown />
              ))}
            </ul>
          </div>
        </div>
      )
    }

    {
      past.length > 0 && (
        <div class="page-band page-band--white">
          <div class="container">
            <SectionHeading>{pastHeading}</SectionHeading>
            <ul class="event-list event-list--past" id="past-events-list" role="list">
              {past.map((event, index) => (
                <EventCard event={event} className={`event-item--alt-bg${index >= 4 ? " past-hidden" : ""}`} />
              ))}
            </ul>
            {past.length > 4 && (
              <div class="past-toggle">
                <Button variant="secondary" type="button" class="toggle-btn" id="past-show-more">
                  {showMoreLabel} ({past.length - 4} more)
                </Button>
                <Button
                  variant="secondary"
                  type="button"
                  class="toggle-btn"
                  id="past-show-less"
                  hidden
                >
                  {showLessLabel}
                </Button>
              </div>
            )}
          </div>
        </div>
      )
    }

    {allEvents.length === 0 && (
      <div class="page-band page-band--alt">
        <div class="container container--mid">
          <p class="empty-state">{emptyText}</p>
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<script>
  const showMoreBtn = document.getElementById("past-show-more") as HTMLButtonElement | null;
  const showLessBtn = document.getElementById("past-show-less") as HTMLButtonElement | null;
  const hiddenItems = document.querySelectorAll<HTMLElement>("#past-events-list .past-hidden");

  showMoreBtn?.addEventListener("click", () => {
    hiddenItems.forEach((item) => item.classList.remove("past-hidden"));
    showMoreBtn.hidden = true;
    showLessBtn!.hidden = false;
  });

  showLessBtn?.addEventListener("click", () => {
    hiddenItems.forEach((item) => item.classList.add("past-hidden"));
    showLessBtn.hidden = true;
    showMoreBtn!.hidden = false;
    document
      .getElementById("past-events-list")
      ?.scrollIntoView({ behavior: "smooth", block: "start" });
  });
</script>

<style>
  .event-section {
    width: 100%;
  }

  .event-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .past-hidden {
    display: none;
  }

  .past-toggle {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }
</style>
