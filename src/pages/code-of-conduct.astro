---
/**
 * Code of Conduct — Standards for GBVA members and community.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("code-of-conduct");

interface CocSection {
  heading: string;
  body: string;
}

const defaultSections: CocSection[] = [
  {
    heading: "Be Respectful",
    body: "Treat all members, fans, event organizers, and the public with courtesy, dignity, and respect at all times — both online and in person.",
  },
  {
    heading: "Represent the Franchise Well",
    body: "When in costume or at events, you represent Ghostbusters Virginia and the broader Ghostbusters community. Conduct yourself professionally, stay in character appropriately, and keep the experience fun and welcoming for everyone — especially kids.",
  },
  {
    heading: "No Discrimination or Harassment",
    body: "Ghostbusters Virginia has zero tolerance for discrimination, harassment, or bullying based on race, gender, sexual orientation, disability, religion, or any other characteristic. We're all here because we love Ghostbusters.",
  },
  {
    heading: "Keep It Family-Friendly",
    body: "Our events often involve children and families. Language, behavior, and social media posts representing GBVA should be appropriate for all ages.",
  },
  {
    heading: "Follow Event Rules",
    body: "Respect the rules and policies of every venue and event we attend. This includes parking, prop handling, restricted areas, and photo policies. If you're unsure, ask a coordinator.",
  },
  {
    heading: "Support Charitable Missions",
    body: "GBVA exists to give back. Participate in good faith in charity drives, community events, and fundraisers. Never use a GBVA event for personal commercial gain without authorization.",
  },
  {
    heading: "Report Concerns",
    body: "If you experience or witness behavior that violates this Code of Conduct, report it to a franchise officer immediately. All reports will be handled discreetly and taken seriously.",
  },
  {
    heading: "Consequences",
    body: "Violations may result in a warning, suspension, or removal from the franchise depending on severity. Serious violations (legal offenses, threats, etc.) will result in immediate removal and may be reported to authorities.",
  },
];

const pageTitle = copy.pageTitle || "Code of Conduct";
const pageIntro =
  copy.pageIntro || "The standards that keep our franchise strong and our community welcoming.";
const sections: CocSection[] = copy.sections || defaultSections;
const metaTitle = copy.metaTitle || "Code of Conduct";
const metaDescription =
  copy.metaDescription ||
  "Ghostbusters Virginia's Code of Conduct — the standards we uphold as a franchise and community.";
const ogTitleVal = copy.ogTitle || "Code of Conduct | Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Our commitment to respect, professionalism, and community as Ghostbusters Virginia members.";
const ogImage = copy.ogImage || "";
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/code-of-conduct"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  {...ogImage ? { ogImage } : {}}
>
  <section class="page" aria-labelledby="coc-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="coc-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <ul class="coc-grid" role="list">
          {
            sections.map((section, i) => (
              <li>
                <article class="coc-card">
                  <span class="coc-card__number" aria-hidden="true">
                    {i + 1}
                  </span>
                  <h2 class="coc-card__title">{section.heading}</h2>
                  <p class="coc-card__body">{section.body}</p>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <style>
    .container--wide {
      max-width: var(--content-width-wide);
      margin-inline: auto;
      padding-inline: var(--space-xl);
    }

    .coc-grid {
      list-style: none;
      padding: 0;
      margin: var(--space-xl) 0 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .coc-card {
      height: 100%;
      background: var(--color-surface);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-panel);
      padding: var(--space-xl);
      display: grid;
      gap: var(--space-md);
      justify-items: center;
      text-align: center;
      transition:
        border-color var(--transition-base),
        box-shadow var(--transition-base),
        transform var(--transition-base);
    }

    .coc-card:hover {
      border-color: var(--color-hover-border);
      box-shadow: var(--shadow-elevated-soft);
      transform: translateY(-2px);
    }

    .coc-card:hover .coc-card__title {
      color: var(--color-accent);
    }

    .coc-card__number {
      width: 3rem;
      height: 3rem;
      border-radius: var(--radius-full);
      background: var(--color-glow-green);
      color: var(--color-gb-green);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: var(--weight-bold);
      line-height: 1;
      transition:
        color var(--transition-base),
        background var(--transition-base),
        border-color var(--transition-base),
        box-shadow var(--transition-base);
    }

    .coc-card:hover .coc-card__number,
    .coc-card:focus-within .coc-card__number {
      color: var(--color-gb-green);
      background: var(--color-surface);
      border: 1px solid var(--color-gb-green);
      box-shadow: var(--shadow-social-hover);
      animation: wiggle 0.5s ease-in-out;
    }

    :global(.reduce-motion) .coc-card__number {
      transition: none;
    }

    :global(.reduce-motion) .coc-card:hover .coc-card__number,
    :global(.reduce-motion) .coc-card:focus-within .coc-card__number {
      animation: none;
    }

    .coc-card__title {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--text-xl);
      font-weight: var(--weight-bold);
      letter-spacing: var(--tracking-wide);
      line-height: var(--leading-tight);
      text-transform: uppercase;
      color: var(--color-heading-section);
    }

    .coc-card__body {
      margin: 0;
      color: var(--color-text-muted);
      font-family: var(--font-body);
      font-size: var(--text-base);
      line-height: var(--leading-loose);
    }

    @media (min-width: 769px) {
      .coc-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  </style>
</BaseLayout>
