---
/**
 * Home page — hero, gallery, upcoming events, join CTA, support.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import EventCard from "../components/EventCard.astro";
import HeroSection from "../components/HeroSection.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import LightboxImageTrigger from "../components/ui/LightboxImageTrigger.astro";
import { getCollection } from "astro:content";
import { splitEventsByStatus } from "../lib/events";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSafeCmsHref, getSafeImageAssetPath } from "../lib/links";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("home");
const donateCopy = await getPageCopy("donate");

const allEvents = await getCollection("events");
const { upcoming } = splitEventsByStatus(allEvents);
const gallery = await getCollection("gallery");

/* ── CMS-driven copy ── */
const heroTitleText = String(copy.heroTitleText || "Bustin' Means");
const heroTitleAccent = String(copy.heroTitleAccent || "Doing Good");
const heroTagline = String(
  copy.heroTagline ||
    "Giving back to the community through a love of Ghostbusters, uniting fans across Virginia to support local charities and turn fandom into real-world impact.",
);
const heroPrimaryCtaLabel = "Donate Today";
const heroLogoSrc = getSafeImageAssetPath(copy.heroLogoSrc) || "/images/logo.png";
const heroLogoAlt = String(copy.heroLogoAlt || "Ghostbusters Virginia logo");
const missionHeading = copy.missionHeading || "Who We Are";
const missionSubtitle =
  copy.missionSubtitle ||
  "Ghostbusters Virginia is a 501(c)3 nonprofit uniting fans across the Commonwealth to turn our love of Ghostbusters into real community impact.";
const missionBody =
  copy.missionBody ||
  "We participate in community events all over Virginia to help raise money and awareness for charities, visit children\u2019s hospitals in full Ghostbusters gear, appear at parades and comic conventions, and welcome fans of all ages and backgrounds \u2014 all in a safe, fun, and family friendly manner.";
const galleryHeading = copy.galleryHeading || "Out in the Field";
const gallerySubtitle =
  copy.gallerySubtitle ||
  "From charity fundraisers and hospital visits to comic conventions and community parades.";
const eventsHeading = copy.eventsHeading || "Events";
const eventsSubtitle =
  copy.eventsSubtitle ||
  "Meet the team, support local charities, and see the Ecto in person. Check out where we\u2019ll be next \u2014 we\u2019d love to see you there.";
const noUpcomingEventsTitle = copy.noUpcomingEventsTitle || "No Events Scheduled Yet";
const noUpcomingEventsBody =
  copy.noUpcomingEventsBody ||
  "No upcoming or active events are currently scheduled, but take a look at our previous events to see where we\u2019ve been.";
const noUpcomingEventsContactText =
  copy.noUpcomingEventsContactText ||
  "Want the team at your next event? Reach out and tell us what you have in mind.";
const noUpcomingEventsContactHref = "/contact";
const eventsCtaLabel = copy.eventsCtaLabel || "See Past Events";
const eventsCtaHref = copy.eventsCtaHref || "/events";
const joinHeading = copy.joinHeading || "Join the Team";
const joinSubtitle =
  copy.joinSubtitle ||
  "Whether you\u2019re a lifelong Ghosthead or just getting started, there\u2019s a place for you in our franchise. Join a community of fans who build props, attend events, visit hospitals, and raise money for charity \u2014 all while having a blast.";
const joinImagePath =
  getSafeImageAssetPath(copy.joinImage) || "/images/ghostbusters-virginia-movie-premiere.jpg";
const joinImageAlt =
  copy.joinImageAlt ||
  "Three Ghostbusters Virginia members in full uniforms posing at a movie premiere event";
const joinQuoteLineOne =
  copy.joinQuoteLineOne ||
  "Do you believe in UFOs, astral projections, mental telepathy, ESP, clairvoyance, spirit photography, telekinetic movement, full trance mediums, the Loch Ness monster and the theory of Atlantis?";
const joinQuoteLineTwo =
  copy.joinQuoteLineTwo ||
  "Ready to get out there and start busting some ghosts? Excellent news rookie, we have openings!";
const joinCtaLabel = copy.joinCtaLabel || "Join Now";
const joinCtaHref = copy.joinCtaHref || "/join";
const supportSectionHeading = copy.supportHeading || "Support the Mission";
const supportCtaLabel = "Donate Today";
const supportCardText =
  donateCopy.donationText ||
  "Ghostbusters Virginia is a volunteer-run, community-focused franchise. Your generous donations help us fund charitable events, maintain the Ecto, purchase supplies for community outreach, and keep the franchise running strong.";
const safeHeroPrimaryCtaHref = "/donate";
const safeEventsCtaHref = getSafeCmsHref(eventsCtaHref) || "/events";
const safeNoUpcomingEventsContactHref = getSafeCmsHref(noUpcomingEventsContactHref) || "/contact";
const safeJoinCtaHref = getSafeCmsHref(joinCtaHref) || "/join";
const safeSupportCtaHref = "/donate";
const galleryCtaLabel = "See All Media";
const galleryCtaHref = "/media";

interface ImpactStat {
  value: string;
  label: string;
  countTarget?: string;
  countSuffix?: string;
}
const defaultImpactStats: ImpactStat[] = [
  { value: "2001", label: "Founded", countTarget: "2001" },
  { value: "501c3", label: "Registered Nonprofit" },
  { value: "50+", label: "Community Events", countTarget: "50", countSuffix: "+" },
  { value: "VA", label: "Statewide Presence" },
];
const impactStats = copy.impactStats || defaultImpactStats;
const impactStatsAriaLabel = copy.impactStatsAriaLabel || "Our impact";

const sortedGallery = [...gallery].sort((a, b) => {
  const aTs = a.data.date ? new Date(a.data.date).getTime() : 0;
  const bTs = b.data.date ? new Date(b.data.date).getTime() : 0;
  return bTs - aTs;
});
const homeGallery = await Promise.all(
  sortedGallery.slice(0, 6).map(async (item) => ({
    ...item,
    responsive: await getResponsiveImageAttrs({
      src: item.data.image,
      widths: [360, 720, 1080],
      sizes: "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw",
      width: 1080,
      height: 720,
      quality: 74,
    }),
  })),
);

const metaTitle = copy.metaTitle || "Home";
const metaDescription =
  copy.metaDescription ||
  "Ghostbusters Virginia is a Sony-recognized 501(c)(3) nonprofit bringing fandom and community service together across Virginia.";
const ogTitleVal = copy.ogTitle || "Ghostbusters Virginia";
const ogDescVal =
  copy.ogDescription ||
  "See upcoming events, media, and ways to join or support Ghostbusters Virginia.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-slimer-stay-puft.jpg";

/* ── Responsive image processing ── */
const heroLogoImage = await getResponsiveImageAttrs({
  src: heroLogoSrc,
  widths: [240, 360, 480, 720],
  sizes: "(max-width: 768px) 240px, 360px",
  width: 360,
  height: 360,
  quality: 75,
});
const joinImage = await getResponsiveImageAttrs({
  src: joinImagePath,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 50vw",
  width: 1200,
  height: 900,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/"
  ogTitle={ogTitleVal}
  ogDescription={ogDescVal}
  ogImage={ogImage}
  heroImagePreload={heroLogoImage}
>
  <!-- ───── HERO (static Astro component) ───── -->
  <HeroSection
    heroTitleText={heroTitleText}
    heroTitleAccent={heroTitleAccent}
    heroTagline={heroTagline}
    primaryCtaLabel={heroPrimaryCtaLabel}
    primaryCtaHref={safeHeroPrimaryCtaHref}
    heroLogoSrc={heroLogoSrc}
    heroLogoAlt={heroLogoAlt}
    heroLogoImage={heroLogoImage}
  />

  <!-- ───── MISSION / IDENTITY ───── -->
  <section class="section hp-section--white mission-section" aria-labelledby="mission-heading">
    <div class="container">
      <h2 id="mission-heading" class="section-heading">{missionHeading}</h2>
      <p class="section-subtitle">
        {missionSubtitle}
      </p>

      <div class="impact-stats" role="list" aria-label={impactStatsAriaLabel}>
        {
          impactStats.map((stat) => (
            <div class="impact-stat" role="listitem">
              <span
                class="impact-stat__number"
                {...(stat.countTarget ? { "data-count-target": stat.countTarget } : {})}
                {...(stat.countSuffix ? { "data-count-suffix": stat.countSuffix } : {})}
              >
                {stat.value}
              </span>
              <span class="impact-stat__label">{stat.label}</span>
            </div>
          ))
        }
      </div>

      <p class="mission-body">
        {missionBody}
      </p>
    </div>
  </section>

  <!-- ───── OUT IN THE FIELD ───── -->
  {
    homeGallery.length > 0 && (
      <section class="section hp-section--alt" aria-labelledby="gallery-heading">
        <div class="container">
          <h2 id="gallery-heading" class="section-heading">
            {galleryHeading}
          </h2>
          <p class="section-subtitle">{gallerySubtitle}</p>
          <ul class="home-gallery-grid" role="list">
            {homeGallery.map((item) => (
              <li class="home-gallery-item">
                <LightboxImageTrigger
                  group="home-gallery"
                  src={item.data.image}
                  alt={item.data.alt}
                  caption={item.data.title}
                  buttonClass="gallery-slide"
                  overlayClass="gallery-slide__overlay"
                >
                  <img
                    {...item.responsive}
                    alt={item.data.alt}
                    class="gallery-slide__img"
                    loading="lazy"
                    decoding="async"
                  />
                </LightboxImageTrigger>
              </li>
            ))}
          </ul>
          <div class="section-cta">
            <Button variant="secondary" href={galleryCtaHref}>
              {galleryCtaLabel}
            </Button>
          </div>
        </div>
      </section>
    )
  }

  <!-- ───── EVENTS ───── -->
  <section class="section hp-section--white" aria-labelledby="upcoming-heading">
    <div class="container">
      <h2 id="upcoming-heading" class="section-heading">
        {eventsHeading}
      </h2>
      <p class="section-subtitle">{eventsSubtitle}</p>
      <ul class="event-list">
        {
          upcoming.length > 0 ? (
            upcoming.map((event) => (
              <EventCard event={event} showCountdown className="event-item--homepage-upcoming" />
            ))
          ) : (
            <li class="event-empty-card">
              <div class="event-empty-card__content">
                <h3 class="event-empty-card__title">{noUpcomingEventsTitle}</h3>
                <p class="event-empty-card__text">{noUpcomingEventsBody}</p>
                <p class="event-empty-card__text event-empty-card__text--contact">
                  <a href={safeNoUpcomingEventsContactHref} class="event-empty-card__link">
                    {noUpcomingEventsContactText}
                  </a>
                </p>
              </div>
            </li>
          )
        }
      </ul>
      <div class="section-cta">
        <Button variant="secondary" href={safeEventsCtaHref}>
          {eventsCtaLabel}
        </Button>
      </div>
    </div>
  </section>

  <!-- ───── JOIN US ───── -->
  <section class="section hp-section--alt join-section" aria-labelledby="join-heading">
    <div class="container">
      <h2 id="join-heading" class="section-heading">{joinHeading}</h2>
      <p class="section-subtitle">
        {joinSubtitle}
      </p>
      <div class="join-layout">
        <LightboxImageTrigger
          group="home-join"
          src={joinImagePath}
          alt={joinImageAlt}
          caption={joinHeading}
          buttonClass="join-image-wrapper"
          overlayClass="join-image-overlay"
          ariaLabel="Click to view image larger"
        >
          <img
            {...joinImage}
            alt={joinImageAlt}
            class="join-image"
            loading="lazy"
            decoding="async"
          />
        </LightboxImageTrigger>
        <blockquote class="quote-block">
          <p>
            &ldquo;{joinQuoteLineOne}&rdquo;
          </p>
          <p>
            {joinQuoteLineTwo}
          </p>
        </blockquote>
      </div>
      <div class="section-cta">
        <Button variant="secondary-alt" href={safeJoinCtaHref}>{joinCtaLabel}</Button>
      </div>
    </div>
  </section>

  <!-- ───── SUPPORT THE MISSION ───── -->
  <section class="section hp-section--white support-section" aria-labelledby="support-heading">
    <div class="container">
      <h2 id="support-heading" class="section-heading">{supportSectionHeading}</h2>
      <div class="highlight-card highlight-card--centered">
        <p class="prose-text">{supportCardText}</p>
        <div class="section-cta">
          <Button variant="secondary" href={safeSupportCtaHref} external>{supportCtaLabel}</Button>
        </div>
      </div>
    </div>
  </section>

  <Lightbox id="home-join-lightbox" label="Join image viewer" lightboxGroup="home-join" />
  <Lightbox
    id="home-gallery-lightbox"
    hasNav
    label="Out in the Field image viewer"
    lightboxGroup="home-gallery"
  />
</BaseLayout>

<style is:global>
  /* ── Homepage section spacing ── */
  .section {
    padding-block: var(--space-3xl);
  }

  /* Override global left-align for homepage centered layout */
  .section-heading {
    text-align: center;
    padding-left: 0;
  }

  .section-heading::before {
    display: none;
  }

  .section-heading::after {
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: var(--color-gb-green);
    right: auto;
  }

  /* ── Mission / Identity section ── */
  .mission-section {
    text-align: center;
    padding-top: var(--space-3xl);
  }

  /* Ensure paragraph text in this section is clearly secondary to headings */
  .mission-section .section-subtitle,
  .mission-body {
    color: var(--color-text-muted);
  }

  .mission-body {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    margin: 0;
    max-width: var(--content-width-mid);
    margin-inline: auto;
    text-align: center;
  }

  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  /* ── Impact stats row ── */
  .impact-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    background: var(--color-surface-alt);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  @media (min-width: 640px) {
    .impact-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .impact-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-surface);
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .impact-stat:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .impact-stat__number {
    font-family: var(--font-brand-title);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .impact-stat__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  /* ── Upcoming events ── */
  .event-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .event-empty-card {
    list-style: none;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
  }

  .event-empty-card__content {
    padding: var(--space-xl);
    text-align: center;
  }

  .event-empty-card__title {
    margin: 0;
    font-family: var(--font-brand-title);
    font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
    color: var(--color-text);
  }

  .event-empty-card__text {
    margin: var(--space-md) 0 0;
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .event-empty-card__text--contact {
    margin-top: var(--space-lg);
    font-weight: var(--weight-medium);
  }

  .event-empty-card__link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .event-empty-card__link:hover,
  .event-empty-card__link:focus-visible {
    color: var(--color-gb-green);
    text-decoration: underline;
  }

  /* ── Join section ── */
  .join-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .join-layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .join-image-wrapper {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    padding: 0;
    width: 100%;
    background: none;
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .join-image-wrapper:hover,
  .join-image-wrapper:focus-visible {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-hover);
  }

  .join-image {
    width: 100%;
    display: block;
  }

  .join-image-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity var(--transition-base);
    pointer-events: none;
  }

  .join-image-wrapper:hover .join-image-overlay,
  .join-image-wrapper:focus-visible .join-image-overlay {
    opacity: 1;
  }

  /* ── Full-bleed section backgrounds ── */
  .hp-section--white {
    background-color: var(--color-surface);
  }

  .hp-section--alt {
    background-color: var(--color-surface-alt);
  }

  .home-gallery-grid {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    margin: 0;
    padding: 0;
  }

  @media (min-width: 640px) {
    .home-gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 1024px) {
    .home-gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .home-gallery-item {
    margin: 0;
  }

  /* Slide content */
  .gallery-slide {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    cursor: pointer;
    padding: 0;
    background: none;
    font: inherit;
    color: inherit;
    text-align: left;
    width: 100%;
    display: block;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }
  .gallery-slide:hover {
    border-color: var(--color-hover-border);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.15),
      0 2px 8px rgba(0, 0, 0, 0.08);
  }
  .gallery-slide__img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }
  .gallery-slide:hover .gallery-slide__img {
    transform: scale(1.03);
  }
  .gallery-slide__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
    z-index: 1;
  }
  .gallery-slide:hover .gallery-slide__overlay,
  .gallery-slide:focus-visible .gallery-slide__overlay {
    opacity: 1;
  }
</style>
