---
/**
 * Home page — hero, gallery, upcoming events, join CTA, support.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import EventCard from "../components/EventCard.astro";
import HeroSection from "../components/HeroSection.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import LightboxImageTrigger from "../components/ui/LightboxImageTrigger.astro";
import { getCollection } from "astro:content";
import { splitEventsByStatus } from "../lib/events";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSafeCmsHref, isSafeExternalUrl } from "../lib/links";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("home");
const donateCopy = await getPageCopy("donate");
const settings = await getSiteSettings();

const allEvents = await getCollection("events");
const { upcoming, past } = splitEventsByStatus(allEvents);
const galleryItems = await getCollection("gallery");

/* ── CMS-driven copy ── */
const heroTitleText = String(copy.heroTitleText || "Bustin' Means");
const heroTitleAccent = String(copy.heroTitleAccent || "Doing Good");
const heroTagline = String(
  copy.heroTagline ||
    "Virginia's only Sony-recognized 501(c)(3) Ghostbusters franchise — uniting fans and serving communities since 2001.",
);
const heroPrimaryCtaLabel = "Donate";
const heroSecondaryCtaLabel = String(copy.heroSecondaryCtaLabel || "Join the Team");
const heroSecondaryCtaHref = copy.heroSecondaryCtaHref;
const heroLogoSrc = String(copy.heroLogoSrc || "/images/logo.png");
const heroLogoAlt = String(copy.heroLogoAlt || "Ghostbusters Virginia logo");
const missionHeading = copy.missionHeading || "Who We Are";
const missionSubtitle =
  copy.missionSubtitle ||
  "Ghostbusters Virginia is the only 501(c)3 nonprofit recognized by Sony\u2019s Ghost Corps in the state. Since 2001, we\u2019ve united fans across the Commonwealth to turn our love of Ghostbusters into real community impact.";
const missionBody =
  copy.missionBody ||
  "We participate in community events all over Virginia to help raise money and awareness for charities, visit children\u2019s hospitals in full Ghostbusters gear, appear at parades and comic conventions, and welcome fans of all ages and backgrounds \u2014 all in a safe, fun, and family friendly manner.";
const galleryHeading = copy.galleryHeading || "Out in the Field";
const gallerySubtitle =
  copy.gallerySubtitle ||
  "From charity fundraisers and hospital visits to comic conventions and community parades.";
const galleryCtaLabel = copy.galleryCtaLabel || "See All Media";
const galleryCtaHref = copy.galleryCtaHref || "/media";
const eventsHeading = copy.eventsHeading || "Events";
const eventsSubtitle =
  copy.eventsSubtitle ||
  "Meet the team, support local charities, and see the Ecto in person. Check out where we\u2019ll be next \u2014 we\u2019d love to see you there.";
const noUpcomingEventsTitle = copy.noUpcomingEventsTitle || "No Events Scheduled Yet";
const noUpcomingEventsBody =
  copy.noUpcomingEventsBody ||
  "No upcoming or active events are currently scheduled, but take a look at our previous events to see where we\u2019ve been.";
const noUpcomingEventsContactText =
  copy.noUpcomingEventsContactText ||
  "Want the team at your next event? Reach out and tell us what you have in mind.";
const noUpcomingEventsContactHref = copy.noUpcomingEventsContactHref || "/contact";
const eventsCtaLabel = copy.eventsCtaLabel || "See Past Events";
const eventsCtaHref = copy.eventsCtaHref || "/events";
const joinHeading = copy.joinHeading || "Join the Team";
const joinSubtitle =
  copy.joinSubtitle ||
  "Whether you\u2019re a lifelong Ghosthead or just getting started, there\u2019s a place for you in our franchise. Join a community of fans who build props, attend events, visit hospitals, and raise money for charity \u2014 all while having a blast.";
const joinImagePath = copy.joinImage || "/images/ghostbusters-virginia-movie-premiere.jpg";
const joinImageAlt =
  copy.joinImageAlt ||
  "Three Ghostbusters Virginia members in full uniforms posing at a movie premiere event";
const joinQuoteLineOne =
  copy.joinQuoteLineOne ||
  "Do you believe in UFOs, astral projections, mental telepathy, ESP, clairvoyance, spirit photography, telekinetic movement, full trance mediums, the Loch Ness monster and the theory of Atlantis?";
const joinQuoteLineTwo =
  copy.joinQuoteLineTwo ||
  "Ready to get out there and start busting some ghosts? Excellent news rookie, we have openings!";
const joinCtaLabel = copy.joinCtaLabel || "Join Now";
const joinCtaHref = copy.joinCtaHref || "/join";
const supportSectionHeading = copy.supportHeading || "Support the Mission";
const supportCtaLabel = donateCopy.donationCtaLabel || "Support the Cause";
const supportCardText =
  donateCopy.donationText ||
  "Ghostbusters Virginia is a volunteer-run, community-focused franchise. Your generous donations help us fund charitable events, maintain the Ecto, purchase supplies for community outreach, and keep the franchise running strong.";
const defaultDonateUrl =
  "https://secure2.wish.org/site/TR;jsessionid=00000000.app20002b?team_id=58435&fr_id=7464&pg=team&NONCE_TOKEN=16AE47C509ECB858ECB963CD3D174802";
const donateUrl = settings.donateUrl || defaultDonateUrl;
const safeHeroPrimaryCtaHref = isSafeExternalUrl(donateUrl) ? donateUrl : defaultDonateUrl;
const safeHeroSecondaryCtaHref = getSafeCmsHref(heroSecondaryCtaHref) || "/join";
const safeGalleryCtaHref = getSafeCmsHref(galleryCtaHref) || "/media";
const safeEventsCtaHref = getSafeCmsHref(eventsCtaHref) || "/events";
const safeNoUpcomingEventsContactHref = getSafeCmsHref(noUpcomingEventsContactHref) || "/contact";
const safeJoinCtaHref = getSafeCmsHref(joinCtaHref) || "/join";
const safeSupportCtaHref = safeHeroPrimaryCtaHref;

interface ImpactStat {
  value: string;
  label: string;
  countTarget?: string;
  countSuffix?: string;
}
const defaultImpactStats: ImpactStat[] = [
  { value: "2001", label: "Founded", countTarget: "2001" },
  { value: "501c3", label: "Registered Nonprofit" },
  { value: "50+", label: "Community Events", countTarget: "50", countSuffix: "+" },
  { value: "VA", label: "Statewide Presence" },
];
const impactStats = copy.impactStats || defaultImpactStats;
const impactStatsAriaLabel = copy.impactStatsAriaLabel || "Our impact";

const metaTitle = copy.metaTitle || "Home";
const metaDescription =
  copy.metaDescription ||
  "Ghostbusters Virginia is a Sony-recognized 501(c)(3) nonprofit bringing fandom and community service together across Virginia.";
const ogTitleVal = copy.ogTitle || "Ghostbusters Virginia";
const ogDescVal =
  copy.ogDescription ||
  "See upcoming events, media, and ways to join or support Ghostbusters Virginia.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-slimer-stay-puft.jpg";

/* ── Responsive image processing ── */
const heroLogoImage = await getResponsiveImageAttrs({
  src: heroLogoSrc,
  widths: [240, 360, 480, 720],
  sizes: "(max-width: 768px) 240px, 360px",
  width: 360,
  height: 360,
  quality: 75,
});
const joinImage = await getResponsiveImageAttrs({
  src: joinImagePath,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 50vw",
  width: 1200,
  height: 900,
  quality: 75,
});
const galleryImageAttrs = await Promise.all(
  galleryItems.map((item) =>
    getResponsiveImageAttrs({
      src: item.data.image,
      widths: [480, 768, 1200],
      sizes: "(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw",
      width: 1200,
      height: 750,
      quality: 72,
    }),
  ),
);
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/"
  ogTitle={ogTitleVal}
  ogDescription={ogDescVal}
  ogImage={ogImage}
  heroImagePreload={heroLogoImage}
>
  <!-- ───── HERO (static Astro component) ───── -->
  <HeroSection
    heroTitleText={heroTitleText}
    heroTitleAccent={heroTitleAccent}
    heroTagline={heroTagline}
    primaryCtaLabel={heroPrimaryCtaLabel}
    primaryCtaHref={safeHeroPrimaryCtaHref}
    primaryCtaExternal
    secondaryCtaLabel={heroSecondaryCtaLabel}
    secondaryCtaHref={safeHeroSecondaryCtaHref}
    heroLogoSrc={heroLogoSrc}
    heroLogoAlt={heroLogoAlt}
    heroLogoImage={heroLogoImage}
  />

  <!-- ───── MISSION / IDENTITY ───── -->
  <section class="section hp-section--white mission-section" aria-labelledby="mission-heading">
    <div class="container">
      <h2 id="mission-heading" class="section-heading">{missionHeading}</h2>
      <p class="section-subtitle">
        {missionSubtitle}
      </p>

      <div class="impact-stats" role="list" aria-label={impactStatsAriaLabel}>
        {
          impactStats.map((stat) => (
            <div class="impact-stat" role="listitem">
              <span
                class="impact-stat__number"
                {...(stat.countTarget ? { "data-count-target": stat.countTarget } : {})}
                {...(stat.countSuffix ? { "data-count-suffix": stat.countSuffix } : {})}
              >
                {stat.value}
              </span>
              <span class="impact-stat__label">{stat.label}</span>
            </div>
          ))
        }
      </div>

      <p class="mission-body">
        {missionBody}
      </p>
    </div>
  </section>

  <!-- ───── GALLERY ───── -->
  {
    galleryItems.length > 0 && (
      <section class="section hp-section--alt" aria-labelledby="gallery-heading">
        <div class="container">
          <h2 id="gallery-heading" class="section-heading">
            {galleryHeading}
          </h2>
          <p class="section-subtitle">{gallerySubtitle}</p>
          <div id="gallery-splide" class="splide" aria-label="Photo gallery carousel">
            <div class="splide__track">
              <ul class="splide__list">
                {galleryItems.map((item, index) => (
                  <li class="splide__slide">
                    <button
                      class="gallery-slide"
                      type="button"
                      aria-label={`View full image: ${item.data.title}`}
                      data-lightbox-group="home-gallery"
                      data-lightbox-src={item.data.image}
                      data-lightbox-alt={item.data.alt}
                      data-lightbox-caption={item.data.title}
                    >
                      <img
                        {...galleryImageAttrs[index]}
                        alt={item.data.alt}
                        loading="lazy"
                        decoding="async"
                        class="gallery-slide__img"
                      />
                      <span class="gallery-slide__overlay" aria-hidden="true">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <polyline points="15 3 21 3 21 9" />
                          <polyline points="9 21 3 21 3 15" />
                          <line x1="21" y1="3" x2="14" y2="10" />
                          <line x1="3" y1="21" x2="10" y2="14" />
                        </svg>
                      </span>
                      <span class="gallery-slide__title">{item.data.title}</span>
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          </div>
          <div class="gallery-cta">
            <Button variant="secondary-alt" href={safeGalleryCtaHref}>
              {galleryCtaLabel}
            </Button>
          </div>
        </div>
      </section>
    )
  }

  <!-- ───── EVENTS ───── -->
  <section class="section hp-section--white" aria-labelledby="upcoming-heading">
    <div class="container">
      <h2 id="upcoming-heading" class="section-heading">
        {eventsHeading}
      </h2>
      <p class="section-subtitle">{eventsSubtitle}</p>
      <ul class="event-list">
        {
          upcoming.length > 0 ? (
            upcoming.map((event) => (
              <EventCard event={event} showCountdown className="event-item--homepage-upcoming" />
            ))
          ) : (
            <li class="event-empty-card">
              <div class="event-empty-card__content">
                <h3 class="event-empty-card__title">{noUpcomingEventsTitle}</h3>
                <p class="event-empty-card__text">{noUpcomingEventsBody}</p>
                <p class="event-empty-card__text event-empty-card__text--contact">
                  <a href={safeNoUpcomingEventsContactHref} class="event-empty-card__link">
                    {noUpcomingEventsContactText}
                  </a>
                </p>
              </div>
            </li>
          )
        }
      </ul>
      <div class="section-cta">
        <Button variant="secondary" href={safeEventsCtaHref}>
          {eventsCtaLabel}
        </Button>
      </div>
    </div>
  </section>

  <!-- ───── JOIN US ───── -->
  <section class="section hp-section--alt join-section" aria-labelledby="join-heading">
    <div class="container">
      <h2 id="join-heading" class="section-heading">{joinHeading}</h2>
      <p class="section-subtitle">
        {joinSubtitle}
      </p>
      <div class="join-layout">
        <LightboxImageTrigger
          group="home-join"
          src={joinImagePath}
          alt={joinImageAlt}
          caption={joinHeading}
          buttonClass="join-image-wrapper"
          overlayClass="join-image-overlay"
          ariaLabel="Click to view image larger"
        >
          <img
            {...joinImage}
            alt={joinImageAlt}
            class="join-image"
            loading="lazy"
            decoding="async"
          />
        </LightboxImageTrigger>
        <blockquote class="quote-block">
          <p>
            &ldquo;{joinQuoteLineOne}&rdquo;
          </p>
          <p>
            {joinQuoteLineTwo}
          </p>
        </blockquote>
      </div>
      <div class="section-cta">
        <Button variant="secondary-alt" href={safeJoinCtaHref}>{joinCtaLabel}</Button>
      </div>
    </div>
  </section>

  <!-- ───── SUPPORT THE MISSION ───── -->
  <section class="section hp-section--white support-section" aria-labelledby="support-heading">
    <div class="container">
      <h2 id="support-heading" class="section-heading">{supportSectionHeading}</h2>
      <div class="highlight-card highlight-card--centered">
        <p class="prose-text">{supportCardText}</p>
        <div class="section-cta">
          <Button variant="secondary" href={safeSupportCtaHref} external>{supportCtaLabel}</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Lightbox overlay ── -->
  <Lightbox id="home-lightbox" hasNav label="Image viewer" lightboxGroup="home-gallery" />
  <Lightbox id="home-join-lightbox" label="Join image viewer" lightboxGroup="home-join" />
</BaseLayout>

<style is:global>
  /* ── Homepage section spacing ── */
  .section {
    padding-block: var(--space-3xl);
  }

  /* Override global left-align for homepage centered layout */
  .section-heading {
    text-align: center;
    padding-left: 0;
  }

  .section-heading::before {
    display: none;
  }

  .section-heading::after {
    left: 50%;
    transform: translateX(-50%);
    width: 80px;
    height: 3px;
    background: var(--color-gb-green);
    right: auto;
  }

  /* ── Mission / Identity section ── */
  .mission-section {
    text-align: center;
    padding-top: var(--space-3xl);
  }

  /* Ensure paragraph text in this section is clearly secondary to headings */
  .mission-section .section-subtitle,
  .mission-body {
    color: var(--color-text-muted);
  }

  .mission-body {
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    margin: 0;
    max-width: var(--content-width-mid);
    margin-inline: auto;
    text-align: center;
  }

  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  /* ── Impact stats row ── */
  .impact-stats {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
    background: var(--color-surface-alt);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
  }

  @media (min-width: 640px) {
    .impact-stats {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .impact-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-xl) var(--space-lg);
    background: var(--color-surface);
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    transition:
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .impact-stat:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .impact-stat__number {
    font-family: var(--font-brand-title);
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
  }

  .impact-stat__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wide);
  }

  .gallery-cta {
    margin-top: var(--space-3xl);
    display: flex;
    justify-content: center;
  }

  /* ── Upcoming events ── */
  .event-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .event-empty-card {
    list-style: none;
    background: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
  }

  .event-empty-card__content {
    padding: var(--space-xl);
    text-align: center;
  }

  .event-empty-card__title {
    margin: 0;
    font-family: var(--font-brand-title);
    font-size: clamp(var(--text-xl), 2.4vw, var(--text-2xl));
    color: var(--color-text);
  }

  .event-empty-card__text {
    margin: var(--space-md) 0 0;
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
  }

  .event-empty-card__text--contact {
    margin-top: var(--space-lg);
    font-weight: var(--weight-medium);
  }

  .event-empty-card__link {
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .event-empty-card__link:hover,
  .event-empty-card__link:focus-visible {
    color: var(--color-gb-green);
    text-decoration: underline;
  }

  /* ── Join section ── */
  .join-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .join-layout {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .join-image-wrapper {
    position: relative;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid var(--color-border);
    padding: 0;
    width: 100%;
    background: none;
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .join-image-wrapper:hover,
  .join-image-wrapper:focus-visible {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-hover);
  }

  .join-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .join-image-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }

  .join-image-wrapper:hover .join-image-overlay,
  .join-image-wrapper:focus-visible .join-image-overlay {
    opacity: 1;
  }

  /* ── Full-bleed section backgrounds ── */
  .hp-section--white {
    background-color: var(--color-surface);
  }

  .hp-section--alt {
    background-color: var(--color-surface-alt);
  }
</style>

<!-- Stat count-up animation -->
<script>
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!reducedMotion) {
    const statEls = document.querySelectorAll<HTMLElement>("[data-count-target]");

    const observer = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const target = parseInt(el.dataset.countTarget ?? "0", 10);
          const suffix = el.dataset.countSuffix ?? "";
          const duration = 1400;
          const startTime = performance.now();

          function tick(now: number) {
            const elapsed = now - startTime;
            const progress = Math.min(elapsed / duration, 1);
            // easeOutQuart
            const ease = 1 - Math.pow(1 - progress, 4);
            el.textContent = Math.round(ease * target) + suffix;
            if (progress < 1) {
              requestAnimationFrame(tick);
            } else {
              el.textContent = target + suffix;
            }
          }

          requestAnimationFrame(tick);
          obs.unobserve(el);
        });
      },
      { threshold: 0.4 },
    );

    statEls.forEach((el) => observer.observe(el));
  }
</script>

<!-- Splide carousel + lightbox -->
<script>
  import Splide from "@splidejs/splide";
  import "@splidejs/splide/css";

  document.addEventListener("DOMContentLoaded", () => {
    const el = document.getElementById("gallery-splide");
    if (!el) return;

    const splide = new Splide(el, {
      type: "loop",
      perPage: 2,
      gap: "1.5rem",
      autoplay: true,
      interval: 7000,
      pauseOnHover: true,
      pauseOnFocus: true,
      pagination: true,
      arrows: true,
      breakpoints: {
        1024: { perPage: 2 },
        640: { perPage: 1 },
      },
    }).mount();

    const lightbox = document.getElementById("home-lightbox") as HTMLElement;
    if (!lightbox) return;

    lightbox.addEventListener("lightbox:open", () => {
      splide.Components.Autoplay?.pause();
    });

    lightbox.addEventListener("lightbox:close", () => {
      splide.Components.Autoplay?.play();
    });
  });
</script>

<style is:global>
  /* ── Splide theme overrides for Ghostbusters dark theme ── */

  /* Arrow buttons */
  #gallery-splide .splide__arrow {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    opacity: 0.85;
    width: 2.5rem;
    height: 2.5rem;
    transition:
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }
  #gallery-splide .splide__arrow:hover {
    background: var(--color-surface-alt);
    border-color: var(--color-gb-green);
    box-shadow: var(--shadow-glow-green);
    opacity: 1;
  }
  #gallery-splide .splide__arrow svg {
    fill: var(--color-text);
    width: 1rem;
    height: 1rem;
  }
  #gallery-splide .splide__arrow:hover svg {
    fill: var(--color-gb-green);
  }

  /* Pagination dots */
  #gallery-splide .splide__pagination {
    bottom: -1.75rem;
  }
  #gallery-splide .splide__pagination__page {
    background: var(--color-border);
    opacity: 0.6;
    width: 8px;
    height: 8px;
    transition: background var(--transition-base);
  }
  #gallery-splide .splide__pagination__page.is-active {
    background: var(--color-gb-green);
    opacity: 1;
  }
  #gallery-splide .splide__pagination__page:hover {
    background: var(--color-gb-green);
    opacity: 1;
  }

  /* Slide content */
  .gallery-slide {
