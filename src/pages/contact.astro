---
/**
 * Contact page — How to reach Ghostbusters Virginia.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("contact");
const settings = await getSiteSettings();

const socialLinks = settings.socialLinks ?? [];
const contactEmail = settings.contactEmail || "info@whoyagonnacall.org";

const pageTitle = (copy?.pageTitle as string) || "Contact Us";
const pageIntro =
  (copy?.pageIntro as string) ||
  "Got a ghost problem? A media inquiry? Just want to say hey? We're listening.";
const quoteLine = (copy?.quoteLine as string) || "You know who to call.";
const reachOutHeading = (copy?.reachOutHeading as string) || "Reach Out";
const reachOutText =
  (copy?.reachOutText as string) ||
  "The best way to reach Ghostbusters Virginia is via email. For faster responses, message us on any of our social media channels below.";
const bookingHeading = (copy?.bookingHeading as string) || "Event Bookings & Appearances";
const bookingText =
  (copy?.bookingText as string) ||
  "Interested in having Ghostbusters Virginia appear at your event, convention, or community gathering? We love supporting charitable and community causes across the Commonwealth. Send us a message with the event details \u2014 date, location, and what you have in mind \u2014 and we'll get back to you as soon as we can.";
const bookingCtaLabel = (copy?.bookingCtaLabel as string) || "Email Us About Your Event";
const metaTitle = (copy?.metaTitle as string) || "Contact";
const metaDescription =
  (copy?.metaDescription as string) ||
  "Get in touch with Ghostbusters Virginia \u2014 reach us via email, social media, or smoke signal.";
const ogTitleVal = (copy?.ogTitle as string) || "Contact Ghostbusters Virginia";
const ogDescriptionVal =
  (copy?.ogDescription as string) ||
  "Reach Ghostbusters Virginia for event bookings, media inquiries, or just to say hey.";
const ogImage = (copy?.ogImage as string) || "/images/ghostbusters-virginia-full-team-photo.jpg";

const bookingImageSrc =
  (copy?.bookingImage as string) || "/images/ghostbusters-virginia-member-with-fan.jpg";
const bookingImageAlt =
  (copy?.bookingImageAlt as string) ||
  "A Ghostbusters Virginia member posing with a young fan at a community event";
const bookingImage = await getResponsiveImageAttrs({
  src: bookingImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/contact"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="contact-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="contact-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <p class="contact-tagline">You know who to call.<br /><span class="contact-tagline-accent">(or in this case, email)</span></p>
        <p class="prose-text prose-text--centered">
          {reachOutText}
        </p>
        <p class="prose-text prose-text--centered">
          <a href={`mailto:${contactEmail}`} class="email-link">{contactEmail}</a>
        </p>

        {
          socialLinks.length > 0 && (
            <div class="social-icons" role="list" aria-label="Social media links">
              {socialLinks.map((link) => {
                const platform = link.platform.toLowerCase();
                return (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="social-icon-link"
                    role="listitem"
                    aria-label={`${link.platform} (opens in new tab)`}
                  >
                    {platform === "facebook" && (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                      </svg>
                    )}
                    {platform === "instagram" && (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                      </svg>
                    )}
                    {platform === "tiktok" && (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.48V13a8.28 8.28 0 005.58 2.16v-3.45a4.85 4.85 0 01-3.77-1.25V6.69h3.77z" />
                      </svg>
                    )}
                    {platform === "youtube" && (
                      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
                      </svg>
                    )}
                  </a>
                );
              })}
            </div>
          )
        }
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{bookingHeading}</SectionHeading>
        <img
          src={bookingImage.src}
          srcset={bookingImage.srcset}
          sizes={bookingImage.sizes}
          alt={bookingImageAlt}
          class="section-image"
          loading="lazy"
          decoding="async"
          width={bookingImage.width}
          height={bookingImage.height}
        />
        <div class="highlight-card highlight-card--alt highlight-card--centered">
          <p class="prose-text">
            {bookingText}
          </p>
          <div class="contact-cta">
            <Button href={`mailto:${contactEmail}?subject=Event%20Booking%20Inquiry`} variant="secondary-alt">
              {bookingCtaLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-link-hover);
  }

  .email-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: var(--weight-medium);
  }

  .email-link:hover,
  .email-link:focus-visible {
    color: var(--color-link-hover);
  }

  .social-icons {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  .social-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition:
      color var(--transition-base),
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .social-icon-link:hover,
  .social-icon-link:focus-visible {
    color: var(--color-gb-green);
    background: var(--color-surface);
    border-color: var(--color-gb-green);
    box-shadow: 0 2px 10px rgba(61, 134, 61, 0.18);
    animation: wiggle 0.5s ease-in-out;
  }

  @keyframes wiggle {
    0% { transform: rotate(0deg); }
    15% { transform: rotate(-12deg); }
    30% { transform: rotate(10deg); }
    45% { transform: rotate(-8deg); }
    60% { transform: rotate(6deg); }
    75% { transform: rotate(-3deg); }
    100% { transform: rotate(0deg); }
  }

  .social-icon-link svg {
    width: 1.25rem;
    height: 1.25rem;
  }

  .contact-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .contact-tagline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    text-align: center;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-heading-section);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-xl);
  }

  .contact-tagline-accent {
    display: block;
    font-size: var(--text-xl);
    color: var(--color-gb-green);
    margin-top: var(--space-xs);
  }

  .prose-text--centered {
    text-align: center;
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--alt {
    background: var(--color-surface-alt);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .contact-tagline {
      font-size: var(--text-2xl);
    }
    .contact-tagline-accent {
      font-size: var(--text-lg);
    }
  }
</style>
