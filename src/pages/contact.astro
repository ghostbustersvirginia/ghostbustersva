---
/**
 * Contact page — How to reach Ghostbusters Virginia.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import SocialLinks from "../components/ui/SocialLinks.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { isSafeExternalUrl } from "../lib/links";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("contact");
const settings = await getSiteSettings();

const socialLinks = (settings.socialLinks ?? []).filter((link) => isSafeExternalUrl(link.url));
const contactEmail = settings.contactEmail || "info@whoyagonnacall.org";

const pageTitle = copy.pageTitle || "Contact Us";
const pageIntro =
  copy.pageIntro || "Got a ghost problem? A media inquiry? Just want to say hey? We're listening.";
const reachOutText =
  copy.reachOutText ||
  "The best way to reach Ghostbusters Virginia is via email. For faster responses, message us on any of our social media channels below.";
const bookingHeading = copy.bookingHeading || "Event Bookings & Appearances";
const bookingText =
  copy.bookingText ||
  "Interested in having Ghostbusters Virginia appear at your event, convention, or community gathering? We love supporting charitable and community causes across the Commonwealth. Send us a message with the event details \u2014 date, location, and what you have in mind \u2014 and we'll get back to you as soon as we can.";
const bookingCtaLabel = copy.bookingCtaLabel || "Email Us About Your Event";
const metaTitle = copy.metaTitle || "Contact";
const metaDescription =
  copy.metaDescription ||
  "Get in touch with Ghostbusters Virginia \u2014 reach us via email, social media, or smoke signal.";
const ogTitleVal = copy.ogTitle || "Contact Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Reach Ghostbusters Virginia for event bookings, media inquiries, or just to say hey.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-full-team-photo.jpg";

const bookingImageSrc = copy.bookingImage || "/images/ghostbusters-virginia-member-with-fan.jpg";
const bookingImageAlt =
  copy.bookingImageAlt ||
  "A Ghostbusters Virginia member posing with a young fan at a community event";
const bookingImage = await getResponsiveImageAttrs({
  src: bookingImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/contact"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="contact-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="contact-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <p class="contact-tagline">
          You know who to call.<br /><span class="contact-tagline-accent"
            >(or in this case, email)</span
          >
        </p>
        <p class="prose-text prose-text--centered">
          {reachOutText}
        </p>
        <p class="prose-text prose-text--centered">
          <a href={`mailto:${contactEmail}`} class="email-link">{contactEmail}</a>
        </p>

        {
          socialLinks.length > 0 && (
            <SocialLinks
              links={socialLinks}
              containerClass="social-icons"
              linkClass="social-icon-link"
            />
          )
        }
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{bookingHeading}</SectionHeading>
        <img
          {...bookingImage}
          alt={bookingImageAlt}
          class="section-image"
          loading="lazy"
          decoding="async"
        />
        <div class="highlight-card highlight-card--alt highlight-card--centered">
          <p class="prose-text">
            {bookingText}
          </p>
          <div class="contact-cta">
            <Button
              href={`mailto:${contactEmail}?subject=Event%20Booking%20Inquiry`}
              variant="secondary-alt"
            >
              {bookingCtaLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-link-hover);
  }

  .email-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: var(--weight-medium);
  }

  .email-link:hover,
  .email-link:focus-visible {
    color: var(--color-link-hover);
  }

  :global(.social-icons) {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  :global(.social-icon-link) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition:
      color var(--transition-base),
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  :global(.social-icon-link:hover),
  :global(.social-icon-link:focus-visible) {
    color: var(--color-gb-green);
    background: var(--color-surface);
    border-color: var(--color-gb-green);
    box-shadow: 0 2px 10px rgba(61, 134, 61, 0.18);
    animation: wiggle 0.5s ease-in-out;
  }

  @keyframes wiggle {
    0% {
      transform: rotate(0deg);
    }
    15% {
      transform: rotate(-12deg);
    }
    30% {
      transform: rotate(10deg);
    }
    45% {
      transform: rotate(-8deg);
    }
    60% {
      transform: rotate(6deg);
    }
    75% {
      transform: rotate(-3deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  :global(.social-icon-link svg) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .contact-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .contact-tagline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    text-align: center;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-heading-section);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-xl);
  }

  .contact-tagline-accent {
    display: block;
    font-size: var(--text-xl);
    color: var(--color-gb-green);
    margin-top: var(--space-xs);
  }

  .prose-text--centered {
    text-align: center;
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--alt {
    background: var(--color-surface-alt);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .contact-tagline {
      font-size: var(--text-2xl);
    }
    .contact-tagline-accent {
      font-size: var(--text-lg);
    }
  }
</style>
