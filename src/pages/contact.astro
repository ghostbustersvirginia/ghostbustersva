---
/**
 * Contact page — How to reach Ghostbusters Virginia.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import LEDScrollbar from "../components/LEDScrollbar.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import SocialLinks from "../components/ui/SocialLinks.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { isSafeExternalUrl } from "../lib/links";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("contact");
const settings = await getSiteSettings();

const socialLinks = (settings.socialLinks ?? []).filter((link) => isSafeExternalUrl(link.url));
const contactEmail = settings.contactEmail || "info@whoyagonnacall.org";
const contactPhone = settings.contactPhone || "(804) 482-1217";
const ledScrollbarText = settings.ledScrollbarText || undefined;
const ledColor = "#ff6b5f";
const ledGlow = "rgba(255, 107, 95, 0.95)";
const showLedScrollbar = copy.showLedScrollbar ?? true;
const ledPlacement = copy.ledPlacement || "after-social";

const pageTitle = copy.pageTitle || "Contact Us";
const pageIntro =
  copy.pageIntro || "Got a ghost problem? A media inquiry? Just want to say hey? We're listening.";
const reachOutText =
  copy.reachOutText ||
  "The best way to reach Ghostbusters Virginia is via email or phone. For faster responses, message us on any of our social media channels below.";
const bookingHeading = copy.bookingHeading || "Event Bookings & Appearances";
const bookingText =
  copy.bookingText ||
  "Interested in having Ghostbusters Virginia appear at your event, convention, or community gathering? We love supporting charitable and community causes across the Commonwealth. Send us a message with the event details \u2014 date, location, and what you have in mind \u2014 and we'll get back to you as soon as we can.";
const bookingCtaLabel = copy.bookingCtaLabel || "Email Us About Your Event";
const metaTitle = copy.metaTitle || "Contact";
const metaDescription =
  copy.metaDescription ||
  "Get in touch with Ghostbusters Virginia \u2014 reach us via email, social media, or smoke signal.";
const ogTitleVal = copy.ogTitle || "Contact Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Reach Ghostbusters Virginia for event bookings, media inquiries, or just to say hey.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-full-team-photo.jpg";

const bookingImageSrc = copy.bookingImage || "/images/ghostbusters-virginia-member-with-fan.jpg";
const bookingImageAlt =
  copy.bookingImageAlt ||
  "A Ghostbusters Virginia member posing with a young fan at a community event";
const bookingImage = await getResponsiveImageAttrs({
  src: bookingImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/contact"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="contact-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="contact-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <p class="contact-tagline">You know who to call.</p>
        <p class="prose-text prose-text--centered">
          {reachOutText}
        </p>
        <div class="contact-methods">
          <div class="contact-chip-group">
            <a
              href={`mailto:${contactEmail}`}
              class="contact-chip"
              aria-label={`Email ${contactEmail}`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                  d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
              >
              <span>{contactEmail}</span>
            </a>
            <button
              type="button"
              class="copy-btn"
              data-copy={contactEmail}
              aria-label="Copy email address"
            >
              <svg
                class="copy-btn__icon copy-btn__icon--copy"
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect width="14" height="14" x="8" y="8" rx="2"></rect><path
                  d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg
              >
              <svg
                class="copy-btn__icon copy-btn__icon--check"
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </button>
          </div>
          <div class="contact-chip-group">
            <a
              href={`tel:${contactPhone.replace(/[^+\d]/g, "")}`}
              class="contact-chip"
              aria-label={`Call ${contactPhone}`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                ></path></svg
              >
              <span>{contactPhone}</span>
            </a>
            <button
              type="button"
              class="copy-btn"
              data-copy={contactPhone}
              aria-label="Copy phone number"
            >
              <svg
                class="copy-btn__icon copy-btn__icon--copy"
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect width="14" height="14" x="8" y="8" rx="2"></rect><path
                  d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg
              >
              <svg
                class="copy-btn__icon copy-btn__icon--check"
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </button>
          </div>
        </div>

        {
          socialLinks.length > 0 && (
            <SocialLinks
              links={socialLinks}
              containerClass="social-icons"
              linkClass="social-icon-link"
            />
          )
        }

        {
          showLedScrollbar && ledPlacement === "after-social" && (
            <div class="led-banner-wrap">
              <LEDScrollbar text={ledScrollbarText} ledColor={ledColor} ledGlow={ledGlow} />
              <img src="/images/slime.png" alt="" aria-hidden="true" class="led-banner-ooze" />
            </div>
          )
        }
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        {
          showLedScrollbar && ledPlacement === "before-booking" && (
            <div class="led-banner-wrap">
              <LEDScrollbar text={ledScrollbarText} ledColor={ledColor} ledGlow={ledGlow} />
              <img src="/images/slime.png" alt="" aria-hidden="true" class="led-banner-ooze" />
            </div>
          )
        }
        <SectionHeading>{bookingHeading}</SectionHeading>
        <img
          {...bookingImage}
          alt={bookingImageAlt}
          class="section-image"
          loading="lazy"
          decoding="async"
        />
        <div class="highlight-card highlight-card--alt highlight-card--centered">
          <p class="prose-text">
            {bookingText}
          </p>
          <div class="contact-cta">
            <Button
              href={`mailto:${contactEmail}?subject=Event%20Booking%20Inquiry`}
              variant="secondary-alt"
            >
              {bookingCtaLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-link-hover);
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-xl);
  }

  .contact-chip-group {
    display: flex;
    align-items: stretch;
  }

  .contact-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border: 1px solid rgba(61, 134, 61, 0.25);
    border-radius: var(--radius-md);
    background: rgba(61, 134, 61, 0.06);
    color: var(--color-text);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      background var(--transition-base),
      color var(--transition-base);
    cursor: pointer;
  }

  .contact-chip:hover,
  .contact-chip:focus-visible {
    border-color: var(--color-gb-green);
    color: var(--color-gb-green);
    background: rgba(61, 134, 61, 0.1);
    box-shadow: 0 2px 8px rgba(61, 134, 61, 0.15);
  }

  .contact-chip svg {
    flex-shrink: 0;
    color: var(--color-gb-green);
    transition: color var(--transition-base);
  }

  .contact-chip-group .contact-chip {
    border-top-right-radius: 0;
    border-bottom-right-radius: 0;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgba(61, 134, 61, 0.25);
    border-left: 0;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    background: rgba(61, 134, 61, 0.1);
    color: var(--color-text-muted);
    cursor: pointer;
    transition:
      border-color var(--transition-base),
      background var(--transition-base),
      color var(--transition-base);
  }

  .copy-btn:hover,
  .copy-btn:focus-visible {
    border-color: var(--color-gb-green);
    color: var(--color-gb-green);
    background: rgba(61, 134, 61, 0.15);
  }

  .copy-btn__icon--check {
    display: none;
  }

  .copy-btn.copied .copy-btn__icon--copy {
    display: none;
  }

  .copy-btn.copied .copy-btn__icon--check {
    display: block;
    color: var(--color-gb-green);
  }

  :global(.social-icons) {
    display: flex;
    justify-content: center;
    gap: var(--space-xl);
    margin-top: var(--space-xl);
  }

  :global(.social-icon-link) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
    transition:
      color var(--transition-base),
      background var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  :global(.social-icon-link:hover),
  :global(.social-icon-link:focus-visible) {
    color: var(--color-gb-green);
    background: var(--color-surface);
    border-color: var(--color-gb-green);
    box-shadow: 0 2px 10px rgba(61, 134, 61, 0.18);
    animation: wiggle 0.5s ease-in-out;
  }

  @keyframes wiggle {
    0% {
      transform: rotate(0deg);
    }
    15% {
      transform: rotate(-12deg);
    }
    30% {
      transform: rotate(10deg);
    }
    45% {
      transform: rotate(-8deg);
    }
    60% {
      transform: rotate(6deg);
    }
    75% {
      transform: rotate(-3deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  :global(.social-icon-link svg) {
    width: 1.25rem;
    height: 1.25rem;
  }

  .contact-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .contact-tagline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--weight-bold);
    text-align: center;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-heading-section);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-xl);
  }

  .led-banner-wrap {
    position: relative;
    margin-top: var(--space-xl);
    border-radius: var(--radius-md);
    overflow: visible;
  }

  .led-banner-ooze {
    position: absolute;
    bottom: 0;
    right: -3.5px;
    width: 68px;
    height: auto;
    pointer-events: none;
    z-index: 2;
    transform: translateY(100%);
    opacity: 0.75;
  }

  .prose-text--centered {
    text-align: center;
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--alt {
    background: var(--color-surface-alt);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  @media (max-width: 640px) {
    .contact-tagline {
      font-size: var(--text-2xl);
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 2000);
      } catch {
        // Fallback: select into a temp input
        const tmp = document.createElement("input");
        tmp.value = text;
        document.body.appendChild(tmp);
        tmp.select();
        document.execCommand("copy");
        document.body.removeChild(tmp);
        btn.classList.add("copied");
        setTimeout(() => btn.classList.remove("copied"), 2000);
      }
    });
  });
</script>
