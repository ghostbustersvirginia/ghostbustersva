---
/**
 * Contact page — How to reach Ghostbusters Virginia.
 */
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import LEDScrollbar from "../components/LEDScrollbar.astro";
import ContactBookingPanel from "../components/contact/ContactBookingPanel.astro";
import ContactMethodsPanel from "../components/contact/ContactMethodsPanel.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { isSafeExternalUrl } from "../lib/links";
import { inquiryTypeOptions, serializeEventInquiryAllowlist } from "../lib/contact-form";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("contact");
const settings = await getSiteSettings();

const socialLinks = (settings.socialLinks ?? []).filter((link) => isSafeExternalUrl(link.url));
const contactEmail = settings.contactEmail || "info@whoyagonnacall.org";
const contactPhone = settings.contactPhone || "(804) 482-1217";
const ledScrollbarText = settings.ledScrollbarText || undefined;
const ledColor = "var(--color-led-alert)";
const ledGlow = "var(--color-led-alert-glow)";
const showLedScrollbar = copy.showLedScrollbar ?? true;
const ledPlacement = copy.ledPlacement || "after-social";

const pageTitle = copy.pageTitle || "Contact Us";
const pageIntro =
  copy.pageIntro ||
  "Interested in having Ghostbusters Virginia appear at your event, convention, or community gathering? We love supporting charitable and community causes across the Commonwealth. Contact us today to learn more.";
const bookingHeading = copy.bookingHeading || "You know who to Call";
const bookingSectionHeading = copy.bookingSectionHeading || "Event Bookings & Appearances";
const contactFormDescription =
  copy.contactFormDescription ||
  "Got a ghost problem? A media inquiry? Just want to say hey? We're listening.";
const defaultFormAction = "https://formspree.io/f/xpqybzjj";
const formspreeAction =
  settings.contactFormActionUrl && isSafeExternalUrl(settings.contactFormActionUrl)
    ? settings.contactFormActionUrl
    : defaultFormAction;
const contactFormSubmitLabel = copy.contactFormSubmitLabel || "Send Message";
const inquiryOptions = inquiryTypeOptions.map((value) => ({ value, label: value }));
const eventInquiryAllowlistJson = serializeEventInquiryAllowlist();
const metaTitle = copy.metaTitle || "Contact";
const metaDescription =
  copy.metaDescription ||
  "Get in touch with Ghostbusters Virginia \u2014 reach us via email, social media, or smoke signal.";
const ogTitleVal = copy.ogTitle || "Contact Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Reach Ghostbusters Virginia for event bookings, media inquiries, or just to say hey.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-full-team-photo.jpg";

const bookingImageSrc = copy.bookingImage || "/images/ghostbusters-virginia-two-gbva-members.jpg";
const bookingImageAlt =
  copy.bookingImageAlt || "Two Ghostbusters Virginia members posing together at a community event";
const bookingImage = await getResponsiveImageAttrs({
  src: bookingImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/contact"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="contact-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="contact-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{bookingHeading}</SectionHeading>
        {
          showLedScrollbar && ledPlacement === "after-social" && (
            <div class="led-banner-wrap">
              <LEDScrollbar text={ledScrollbarText} ledColor={ledColor} ledGlow={ledGlow} />
            </div>
          )
        }
        <ContactMethodsPanel
          contactPhone={contactPhone}
          contactEmail={contactEmail}
          socialLinks={socialLinks}
        />
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        {
          showLedScrollbar && ledPlacement === "before-booking" && (
            <div class="led-banner-wrap">
              <LEDScrollbar text={ledScrollbarText} ledColor={ledColor} ledGlow={ledGlow} />
            </div>
          )
        }
        <ContactBookingPanel
          bookingSectionHeading={bookingSectionHeading}
          bookingImage={bookingImage}
          bookingImageAlt={bookingImageAlt}
          contactFormDescription={contactFormDescription}
          formspreeAction={formspreeAction}
          inquiryOptions={inquiryOptions}
          eventInquiryAllowlistJson={eventInquiryAllowlistJson}
          contactFormSubmitLabel={contactFormSubmitLabel}
        />
      </div>
    </div>

    <Lightbox
      id="contact-lightbox"
      label="Contact page image viewer"
      lightboxGroup="contact-gallery"
    />
  </section>
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css"
  />
</BaseLayout>

<script is:inline src="/contact-form-client.js"></script>

<style>
  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-link-hover);
  }

  .led-banner-wrap {
    position: relative;
    margin-top: var(--space-xl);
    width: 100%;
    max-width: 42rem;
    margin-left: auto;
    margin-right: auto;
    border-radius: var(--radius-md);
    overflow: visible;
  }

  :global(.flatpickr-wrapper) {
    width: 100%;
  }

  :global(.flatpickr-input[readonly]) {
    cursor: pointer;
  }

  :global(.flatpickr-calendar) {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    box-shadow: var(--shadow-hover);
    margin-top: 0.25rem;
    z-index: 1100;
  }

  :global(.flatpickr-months) {
    padding: 0.2rem 0.35rem 0;
  }

  :global(.flatpickr-months .flatpickr-prev-month),
  :global(.flatpickr-months .flatpickr-next-month) {
    color: var(--color-text);
    fill: var(--color-text);
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
  }

  :global(.flatpickr-months .flatpickr-prev-month:hover),
  :global(.flatpickr-months .flatpickr-next-month:hover) {
    background: var(--color-surface-alt);
  }

  :global(.flatpickr-current-month) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding-top: 0.25rem;
  }

  :global(.flatpickr-current-month .cur-month) {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: var(--weight-normal);
    color: var(--color-text);
  }

  :global(.flatpickr-current-month .numInputWrapper) {
    width: 4.4rem;
  }

  :global(.flatpickr-current-month .numInputWrapper span) {
    display: none;
  }

  :global(.flatpickr-current-month input.cur-year) {
    appearance: textfield;
    -moz-appearance: textfield;
    -webkit-appearance: none;
    border: 1px solid transparent;
    border-radius: var(--radius-sm);
    background: transparent;
    padding: 0.1rem 0.25rem;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: var(--weight-normal);
    color: var(--color-text);
    transition: border-color var(--transition-fast);
  }

  :global(.flatpickr-current-month input.cur-year:hover),
  :global(.flatpickr-current-month input.cur-year:focus-visible) {
    border-color: var(--color-border);
    outline: none;
  }

  :global(.flatpickr-months .flatpickr-month),
  :global(.flatpickr-current-month input.cur-year) {
    color: var(--color-text);
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
  }

  :global(.flatpickr-weekday) {
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
  }

  :global(.flatpickr-day:hover),
  :global(.flatpickr-day:focus-visible) {
    background: var(--color-surface-alt);
    border-color: var(--color-border);
    color: var(--color-text);
  }

  :global(.flatpickr-day.selected),
  :global(.flatpickr-day.startRange),
  :global(.flatpickr-day.endRange) {
    background: var(--color-gb-green);
    border-color: var(--color-gb-green);
    color: var(--color-surface);
  }

  :global(.flatpickr-day.today) {
    border-color: var(--color-accent);
  }
</style>
