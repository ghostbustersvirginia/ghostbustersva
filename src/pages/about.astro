---
/**
 * About page — Who we are, mission, and history.
 * PRD 005: About Page Redesign
 *
 * Layout: Zigzag alternating image/text rows with mixed aspect ratios
 * (landscape + portrait) for visual variety. Images open in a lightbox.
 * Followed by a mission callout.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import LightboxImageTrigger from "../components/ui/LightboxImageTrigger.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("about");

const pageTitle = copy.pageTitle || "About Ghostbusters Virginia";
const pageIntro =
  copy.pageIntro ||
  "Ghostbusters Virginia is a fan-powered nonprofit built to welcome you in, get you involved, and turn shared fandom into local impact.";

const ogImage = copy.ogImage || "/images/ghostbusters-virginia-pke-meter-closeup.jpg";
const teamImageSrc = copy.teamImage || "/images/ghostbusters-virginia-full-team-photo.jpg";
const teamImageAlt =
  copy.teamImageAlt || "The full Ghostbusters Virginia team in uniform at a community event";

/* --- Zigzag section images --- */
/* Landscape thumbnails (4:3 native photos) */
const landscapeSizes = "(max-width: 768px) 100vw, 440px";
const landscapeWidths: [number, ...number[]] = [400, 600, 880];

/* Portrait thumbnails (3:4 native photos) */
const portraitSizes = "(max-width: 768px) 100vw, 380px";
const portraitWidths: [number, ...number[]] = [380, 560, 760];

/* Row 1 — landscape: Alamo Drafthouse team event (1440×1080, 4:3) */
const teamImage = await getResponsiveImageAttrs({
  src: teamImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 1440,
  height: 1080,
  quality: 75,
});

/* Row 2 — portrait: Convention booth (1536×2040, ~3:4) */
const divisionsImageSrc =
  copy.divisionsImage || "/images/ghostbusters-virginia-convention-booth.jpg";
const divisionsImageAlt =
  copy.divisionsImageAlt || "Ghostbusters Virginia convention booth showcasing regional divisions";
const divisionsImage = await getResponsiveImageAttrs({
  src: divisionsImageSrc,
  widths: portraitWidths,
  sizes: portraitSizes,
  width: 1536,
  height: 2040,
  quality: 75,
});

/* Row 3 — landscape: Ecto under the lights (1440×999, ~3:2) */
const communityImageSrc =
  copy.communityImage || "/images/ghostbusters-virginia-ecto-night-lights.jpg";
const communityImageAlt =
  copy.communityImageAlt ||
  "Ghostbusters Virginia members posing with the Ecto vehicle at night with colorful decorative lights";
const communityImage = await getResponsiveImageAttrs({
  src: communityImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 1440,
  height: 999,
  quality: 75,
});

/* Row 4 — landscape: Police community event (2048×1536, 4:3) */
const togetherImageSrc =
  copy.togetherImage || "/images/ghostbusters-virginia-police-community-event.jpg";
const togetherImageAlt =
  copy.togetherImageAlt ||
  "Ghostbusters Virginia members at a community event with local first responders";
const togetherImage = await getResponsiveImageAttrs({
  src: togetherImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 2048,
  height: 1536,
  quality: 75,
});

const metaTitle = copy.metaTitle || "About";
const metaDescription =
  copy.metaDescription || "Learn the history and mission of Ghostbusters Virginia since 2001.";
const ogTitleVal = copy.ogTitle || "About Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Discover who we are, how we serve the community, and why Ghostbusters Virginia exists.";

const whoWeAreBodyOne =
  copy.whoWeAreBodyOne ||
  "Ghostbusters Virginia is a 501(c)3 nonprofit uniting fans across the Commonwealth to turn our love of Ghostbusters into real community impact.";
const whoWeAreBodyTwo =
  copy.whoWeAreBodyTwo ||
  "Since 2001, neighbors, families, and fans have joined us to raise funds for local causes through events, appearances, and community partnerships. When you donate, you help turn costumes, props, and fandom energy into direct support for people who need it.";
const whoWeAreBodyThree =
  copy.whoWeAreBodyThree ||
  "You do not need special experience to be part of this mission - just a willingness to show up and help. Join us at events, volunteer your time, or contribute a donation to keep this work moving in every region of Virginia.";
const whoWeAreBodyFour =
  copy.whoWeAreBodyFour ||
  "If you have ever wanted your fandom to do good in the real world, this is your invitation. Join Ghostbusters Virginia or donate today to help us keep serving communities across the Commonwealth.";

const missionHeading = copy.missionHeading || "Our Mission";
const missionCardTitle = copy.missionCardTitle || "Mission Priorities";
const missionItems = copy.missionItems || [
  "Celebrate and promote the Ghostbusters franchise across the Commonwealth of Virginia",
  "Support charitable causes and give back to our local communities",
  "Provide a welcoming space for fans of all ages and backgrounds",
  "Unite Virginia\u2019s regional Ghostbusters groups under one banner",
];
const missionCtaLabel = copy.missionCtaLabel || "See us in Action";
const missionCtaHref = copy.missionCtaHref || "/press";
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/about"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="about-title">
    <!-- Page header -->
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="about-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <!-- Zigzag row 1: landscape image left, text right -->
    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <div class="zigzag">
          <div class="zigzag__media">
            <LightboxImageTrigger
              group="about-gallery"
              src={teamImageSrc}
              alt={teamImageAlt}
              buttonClass="zigzag__thumb"
              overlayClass="zigzag__overlay"
            >
              <img
                {...teamImage}
                alt={teamImageAlt}
                class="zigzag__img"
                loading="eager"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyOne}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 2: text left, portrait image right -->
    <div class="page-band page-band--white">
      <div class="container container--wide">
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media zigzag__media--portrait">
            <LightboxImageTrigger
              group="about-gallery"
              src={divisionsImageSrc}
              alt={divisionsImageAlt}
              buttonClass="zigzag__thumb"
              overlayClass="zigzag__overlay"
            >
              <img
                {...divisionsImage}
                alt={divisionsImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyTwo}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 3: landscape image left, text right -->
    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <div class="zigzag">
          <div class="zigzag__media">
            <LightboxImageTrigger
              group="about-gallery"
              src={communityImageSrc}
              alt={communityImageAlt}
              buttonClass="zigzag__thumb"
              overlayClass="zigzag__overlay"
            >
              <img
                {...communityImage}
                alt={communityImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyThree}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 4: text left, landscape image right -->
    <div class="page-band page-band--white">
      <div class="container container--wide">
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media">
            <LightboxImageTrigger
              group="about-gallery"
              src={togetherImageSrc}
              alt={togetherImageAlt}
              buttonClass="zigzag__thumb"
              overlayClass="zigzag__overlay"
            >
              <img
                {...togetherImage}
                alt={togetherImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyFour}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Mission callout -->
    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{missionHeading}</SectionHeading>
        <div class="mission-card">
          <h4 class="mission-card__title">
            {missionCardTitle}
            <img src="/images/slime.png" alt="" aria-hidden="true" class="mission-card__ooze" />
          </h4>
          <ul class="mission-list" role="list">
            {missionItems.map((item) => <li class="mission-list__item">{item}</li>)}
          </ul>
        </div>
        <div class="mission-cta">
          <Button variant="secondary" href={missionCtaHref}>{missionCtaLabel}</Button>
        </div>
      </div>
    </div>

    <Lightbox id="about-lightbox" label="About page image viewer" lightboxGroup="about-gallery" />
  </section>
</BaseLayout>

<style is:global>
  /* --- Zigzag layout --- */
  .zigzag {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 769px) {
    .zigzag {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .zigzag--reverse .zigzag__media {
      order: 2;
    }

    .zigzag--reverse .zigzag__text {
      order: 1;
    }
  }

  /* --- Thumbnail button (lightbox trigger) --- */
  .zigzag__thumb {
    position: relative;
    display: block;
    width: 100%;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .zigzag__thumb:hover,
  .zigzag__thumb:focus-visible {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .zigzag__thumb:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .zigzag__thumb:hover .zigzag__img {
    transform: scale(1.03);
  }

  /* --- Dark overlay with expand icon --- */
  .zigzag__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    border-radius: var(--radius-md);
  }

  .zigzag__thumb:hover .zigzag__overlay,
  .zigzag__thumb:focus-visible .zigzag__overlay {
    opacity: 1;
  }

  /* --- Image styles --- */
  .zigzag__img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
    transition: transform 0.2s ease;
  }

  /* Landscape images: cap height so they don't overpower text */
  .zigzag__media:not(.zigzag__media--portrait) .zigzag__img {
    aspect-ratio: 4 / 3;
  }

  /* Portrait images: use natural tall ratio, capped for balance */
  .zigzag__media--portrait .zigzag__img {
    aspect-ratio: 3 / 4;
    max-height: 480px;
  }

  /* Text column */
  .zigzag__text {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: var(--space-xs);
  }

  /* --- Wider container for zigzag rows --- */
  .container--wide {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  /* --- Prose text (shared) --- */
  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  /* --- Mission card --- */
  .mission-card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-panel);
    max-width: 760px;
    margin-inline: auto;
  }

  .mission-card__title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    margin: 0;
    padding: var(--space-lg) var(--space-2xl);
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: visible;
  }

  .mission-card__ooze {
    position: absolute;
    bottom: 0;
    right: -4px;
    width: 68px;
    height: auto;
    pointer-events: none;
    z-index: 1;
    transform: translateY(100%);
    opacity: 0.75;
  }

  .mission-list {
    list-style: none;
    padding: var(--space-xl) var(--space-2xl) var(--space-2xl);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .mission-list__item {
    position: relative;
    padding-left: 2rem;
    padding-block: var(--space-xs);
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    cursor: default;
    transition: color var(--transition-base);
  }

  .mission-list__item:hover {
    color: var(--color-text);
  }

  .mission-list__item::before {
    content: "✔";
    position: absolute;
    left: 0.25rem;
    top: var(--space-xs);
    color: var(--color-gb-green);
    font-weight: var(--weight-bold);
    font-size: var(--text-base);
    display: inline-block;
    transition: transform var(--transition-base);
  }

  .mission-list__item:hover::before {
    transform: scale(1.4);
  }

  .mission-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }
</style>
