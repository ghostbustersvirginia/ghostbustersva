---
/**
 * About page — Who we are, mission, and history.
 * PRD 005: About Page Redesign
 *
 * Layout: Zigzag alternating image/text rows with mixed aspect ratios
 * (landscape + portrait) for visual variety. Images open in a lightbox.
 * Followed by a mission callout and community initiatives section.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("about");

const pageTitle = (copy?.pageTitle as string) || "About Ghostbusters Virginia";
const pageIntro =
  (copy?.pageIntro as string) || "Who we are, where we came from, and why we do what we do.";

const protonPetsImageSrc =
  (copy?.protonPetsImage as string) || "/images/news/ghostbusters-virginia-proton-pets-rescue.jpeg";
const protonPetsImageAlt =
  (copy?.protonPetsImageAlt as string) ||
  "Proton Pets \u2014 Ghostbusters Virginia community fundraiser for local pet shelters";
const protonPetsText =
  (copy?.protonPetsText as string) ||
  "Every April, Ghostbusters Virginia calls on franchises across the globe to join Proton Pets \u2014 a month-long, community-driven fundraiser supporting local pet shelters and pet pantries.";
const protonPetsLinkLabel = (copy?.protonPetsLinkLabel as string) || "Learn About Proton Pets";
const protonPetsLinkUrl =
  (copy?.protonPetsLinkUrl as string) || "https://whoyagonnacall.org/proton-pets";
const ogImage = (copy?.ogImage as string) || "/images/ghostbusters-virginia-pke-meter-closeup.jpg";
const teamImageSrc =
  (copy?.teamImage as string) || "/images/ghostbusters-virginia-full-team-photo.jpg";
const teamImageAlt =
  (copy?.teamImageAlt as string) ||
  "The full Ghostbusters Virginia team in uniform at a community event";

/* --- Zigzag section images --- */
/* Landscape thumbnails (4:3 native photos) */
const landscapeSizes = "(max-width: 768px) 100vw, 440px";
const landscapeWidths: [number, ...number[]] = [400, 600, 880];

/* Portrait thumbnails (3:4 native photos) */
const portraitSizes = "(max-width: 768px) 100vw, 380px";
const portraitWidths: [number, ...number[]] = [380, 560, 760];

/* Row 1 — landscape: Alamo Drafthouse team event (1440×1080, 4:3) */
const teamImage = await getResponsiveImageAttrs({
  src: teamImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 1440,
  height: 1080,
  quality: 75,
});

/* Row 2 — portrait: Convention booth (1536×2040, ~3:4) */
const divisionsImageSrc = "/images/ghostbusters-virginia-convention-booth.jpg";
const divisionsImageAlt = "Ghostbusters Virginia convention booth showcasing regional divisions";
const divisionsImage = await getResponsiveImageAttrs({
  src: divisionsImageSrc,
  widths: portraitWidths,
  sizes: portraitSizes,
  width: 1536,
  height: 2040,
  quality: 75,
});

/* Row 3 — landscape: Ecto under the lights (1440×999, ~3:2) */
const communityImageSrc = "/images/ghostbusters-virginia-ecto-night-lights.jpg";
const communityImageAlt = "Ghostbusters Virginia members posing with the Ecto vehicle at night with colorful decorative lights";
const communityImage = await getResponsiveImageAttrs({
  src: communityImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 1440,
  height: 999,
  quality: 75,
});

/* Row 4 — landscape: Police community event (2048×1536, 4:3) */
const togetherImageSrc = "/images/ghostbusters-virginia-police-community-event.jpg";
const togetherImageAlt = "Ghostbusters Virginia members at a community event with local first responders";
const togetherImage = await getResponsiveImageAttrs({
  src: togetherImageSrc,
  widths: landscapeWidths,
  sizes: landscapeSizes,
  width: 2048,
  height: 1536,
  quality: 75,
});

const protonPetsImage = await getResponsiveImageAttrs({
  src: protonPetsImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 900px",
  width: 1200,
  height: 675,
  quality: 75,
});

const metaTitle = (copy?.metaTitle as string) || "About";
const metaDescription =
  (copy?.metaDescription as string) ||
  "Learn the history, mission, and community initiatives of Ghostbusters Virginia since 2001.";
const ogTitleVal = (copy?.ogTitle as string) || "About Ghostbusters Virginia";
const ogDescriptionVal =
  (copy?.ogDescription as string) ||
  "Discover who we are, how we serve the community, and why Ghostbusters Virginia exists.";

const whoWeAreBodyOne =
  (copy?.whoWeAreBodyOne as string) ||
  "Ghostbusters Virginia (GBVA) was established in 2001 by a lifelong Ghosthead and rather young member of the Ghostbusters community. Since then GBVA has ebbed and flowed with popularity and activity, culminating in 2011 with a spike in popularity that established GBVA as the premier Ghostbusters franchise in the Commonwealth of Virginia.";
const whoWeAreBodyTwo =
  (copy?.whoWeAreBodyTwo as string) ||
  "Our mission has always been straightforward: celebrate and promote the Ghostbusters franchise, support charitable causes, and create a welcoming space for fans of all ages and backgrounds. We visit children\u2019s hospitals in full gear, appear at parades and conventions, and raise money and awareness for local charities \u2014 all in a safe, fun, and family-friendly way.";
const whoWeAreBodyThree =
  (copy?.whoWeAreBodyThree as string) ||
  "Unlike other states where multiple groups operate independently, GBVA functions as a large umbrella for all Ghostbusters fans in Virginia. Individual groups maintain their own identity while proudly flying the GBVA banner and participating in events like conventions, fundraisers, and build parties. The three primary groups are The Richmond Division, District 757 protecting Southeastern Virginia, and the NOVA Division keeping the northern border of Virginia safe and sound.";
const whoWeAreBodyFour =
  (copy?.whoWeAreBodyFour as string) ||
  "Under the GBVA banner these groups pool their resources and cooperate at a level that makes the whole stronger than its parts. Alongside members from across Virginia \u2014 including the Eastern Shore \u2014 they are what make GBVA such a fantastic franchise, with a future filled with good fun, memories, and lifelong friendships.";

const missionHeading = (copy?.missionHeading as string) || "Our Mission";
const missionItems = (copy?.missionItems as string[]) || [
  "Celebrate and promote the Ghostbusters franchise across the Commonwealth of Virginia",
  "Support charitable causes and give back to our local communities",
  "Provide a welcoming space for fans of all ages and backgrounds",
  "Unite Virginia\u2019s regional Ghostbusters groups under one banner",
];

const initiativesHeading = (copy?.initiativesHeading as string) || "Community Initiatives";
const initiativeTitle = (copy?.initiativeTitle as string) || "Proton Pets";

/** Expand icon SVG reused across all four zigzag thumbs */
const expandIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/about"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="about-title">
    <!-- Page header -->
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="about-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <!-- Zigzag row 1: landscape image left, text right -->
    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <div class="zigzag">
          <div class="zigzag__media">
            <button
              class="zigzag__thumb"
              type="button"
              data-lightbox-src={teamImageSrc}
              data-lightbox-alt={teamImageAlt}
              aria-label={`View full image: ${teamImageAlt}`}
            >
              <img
                src={teamImage.src}
                srcset={teamImage.srcset}
                sizes={teamImage.sizes}
                alt={teamImageAlt}
                class="zigzag__img"
                loading="eager"
                decoding="async"
                width={teamImage.width}
                height={teamImage.height}
              />
              <span class="zigzag__overlay" aria-hidden="true">
                <Fragment set:html={expandIcon} />
              </span>
            </button>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyOne}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 2: text left, portrait image right -->
    <div class="page-band page-band--white">
      <div class="container container--wide">
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media zigzag__media--portrait">
            <button
              class="zigzag__thumb"
              type="button"
              data-lightbox-src={divisionsImageSrc}
              data-lightbox-alt={divisionsImageAlt}
              aria-label={`View full image: ${divisionsImageAlt}`}
            >
              <img
                src={divisionsImage.src}
                srcset={divisionsImage.srcset}
                sizes={divisionsImage.sizes}
                alt={divisionsImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
                width={divisionsImage.width}
                height={divisionsImage.height}
              />
              <span class="zigzag__overlay" aria-hidden="true">
                <Fragment set:html={expandIcon} />
              </span>
            </button>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyTwo}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 3: landscape image left, text right -->
    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <div class="zigzag">
          <div class="zigzag__media">
            <button
              class="zigzag__thumb"
              type="button"
              data-lightbox-src={communityImageSrc}
              data-lightbox-alt={communityImageAlt}
              aria-label={`View full image: ${communityImageAlt}`}
            >
              <img
                src={communityImage.src}
                srcset={communityImage.srcset}
                sizes={communityImage.sizes}
                alt={communityImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
                width={communityImage.width}
                height={communityImage.height}
              />
              <span class="zigzag__overlay" aria-hidden="true">
                <Fragment set:html={expandIcon} />
              </span>
            </button>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyThree}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Zigzag row 4: text left, landscape image right -->
    <div class="page-band page-band--white">
      <div class="container container--wide">
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media">
            <button
              class="zigzag__thumb"
              type="button"
              data-lightbox-src={togetherImageSrc}
              data-lightbox-alt={togetherImageAlt}
              aria-label={`View full image: ${togetherImageAlt}`}
            >
              <img
                src={togetherImage.src}
                srcset={togetherImage.srcset}
                sizes={togetherImage.sizes}
                alt={togetherImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
                width={togetherImage.width}
                height={togetherImage.height}
              />
              <span class="zigzag__overlay" aria-hidden="true">
                <Fragment set:html={expandIcon} />
              </span>
            </button>
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{whoWeAreBodyFour}</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Mission callout -->
    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{missionHeading}</SectionHeading>
        <ul class="mission-list" role="list">
          {missionItems.map((item) => (
            <li class="mission-list__item">{item}</li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Community Initiatives -->
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{initiativesHeading}</SectionHeading>
        <h3 class="initiative-title">{initiativeTitle}</h3>
        <img
          src={protonPetsImage.src}
          srcset={protonPetsImage.srcset}
          sizes={protonPetsImage.sizes}
          alt={protonPetsImageAlt}
          class="initiative-image"
          loading="lazy"
          decoding="async"
          width={protonPetsImage.width}
          height={protonPetsImage.height}
        />
        <p class="prose-text">{protonPetsText}</p>
        <div class="initiative-cta">
          <Button variant="secondary" href={protonPetsLinkUrl} external>
            {protonPetsLinkLabel}
          </Button>
        </div>
      </div>
    </div>

    <Lightbox id="about-lightbox" label="About page image viewer" />
  </section>
</BaseLayout>

<script>
  import { setLightboxPreviousFocus } from "../lib/lightbox";

  const lightbox = document.getElementById("about-lightbox") as HTMLElement | null;
  const lbImage = lightbox?.querySelector(".lightbox__image") as HTMLImageElement | null;

  const thumbs = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".zigzag__thumb[data-lightbox-src]"),
  );

  function openAboutLightbox(index: number) {
    if (!lightbox || !lbImage) return;
    const thumb = thumbs[index];
    lbImage.src = thumb.dataset.lightboxSrc ?? "";
    lbImage.alt = thumb.dataset.lightboxAlt ?? "";
    setLightboxPreviousFocus(lightbox, thumb, "about-thumb");
    lightbox.hidden = false;
    document.body.style.overflow = "hidden";
    lightbox.querySelector<HTMLButtonElement>(".lightbox__close")?.focus();
  }

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener("click", () => openAboutLightbox(i));
  });
</script>

<style>
  /* --- Zigzag layout --- */
  .zigzag {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 769px) {
    .zigzag {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .zigzag--reverse .zigzag__media {
      order: 2;
    }

    .zigzag--reverse .zigzag__text {
      order: 1;
    }
  }

  /* --- Thumbnail button (lightbox trigger) --- */
  .zigzag__thumb {
    position: relative;
    display: block;
    width: 100%;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .zigzag__thumb:hover,
  .zigzag__thumb:focus-visible {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .zigzag__thumb:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .zigzag__thumb:hover .zigzag__img {
    transform: scale(1.03);
  }

  /* --- Dark overlay with expand icon --- */
  .zigzag__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
    border-radius: var(--radius-md);
  }

  .zigzag__thumb:hover .zigzag__overlay,
  .zigzag__thumb:focus-visible .zigzag__overlay {
    opacity: 1;
  }

  /* --- Image styles --- */
  .zigzag__img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
    transition: transform 0.2s ease;
  }

  /* Landscape images: cap height so they don't overpower text */
  .zigzag__media:not(.zigzag__media--portrait) .zigzag__img {
    aspect-ratio: 4 / 3;
  }

  /* Portrait images: use natural tall ratio, capped for balance */
  .zigzag__media--portrait .zigzag__img {
    aspect-ratio: 3 / 4;
    max-height: 480px;
  }

  /* Text column */
  .zigzag__text {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    padding-top: var(--space-xs);
  }

  /* --- Wider container for zigzag rows --- */
  .container--wide {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  /* --- Prose text (shared) --- */
  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  /* --- Mission callout --- */
  .mission-list {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .mission-list__item {
    position: relative;
    padding-left: var(--space-2xl);
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    cursor: default;
    transition: color var(--transition-base);
  }

  .mission-list__item:hover {
    color: var(--color-text);
  }

  .mission-list__item::before {
    content: "\2714";
    position: absolute;
    left: 0;
    color: var(--color-gb-green);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    display: inline-block;
    transition: transform var(--transition-base);
  }

  .mission-list__item:hover::before {
    transform: scale(1.4);
  }

  /* --- Initiative section --- */
  .initiative-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    color: var(--color-heading-section);
    letter-spacing: var(--tracking-wide);
    text-align: center;
    margin-bottom: var(--space-lg);
  }

  .initiative-image {
    width: 100%;
    max-height: 320px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-lg);
  }

  .initiative-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }
</style>
