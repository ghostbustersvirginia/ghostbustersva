---
/**
 * About page — Who we are, mission, and history.
 * PRD 005: About Page Redesign
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Panel from "../components/ui/Panel.astro";
import Button from "../components/ui/Button.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getPageCopy } from "../lib/page-copy";

const copy = (await getPageCopy("about")) as {
  pageTitle?: string;
  pageIntro?: string;
  missionItems?: string[];
  protonPetsImage?: string;
  protonPetsImageAlt?: string;
  protonPetsText?: string;
  protonPetsLinkLabel?: string;
  protonPetsLinkUrl?: string;
} | null;

const protonPetsImageSrc = copy?.protonPetsImage || "/images/news/proton-pets.jpeg";
const protonPetsImage = await getResponsiveImageAttrs({
  src: protonPetsImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 900px",
  width: 1200,
  height: 675,
  quality: 75,
});

const missionItems = copy?.missionItems ?? [
  "Celebrate and promote the Ghostbusters franchise across the Commonwealth of Virginia",
  "Support charitable causes and give back to our local communities",
  "Provide a welcoming space for fans of all ages and backgrounds",
  "Unite Virginia's regional Ghostbusters groups under one banner",
];
---

<BaseLayout
  title="About"
  description="Learn the history, mission, and community initiatives of Ghostbusters Virginia since 2001."
  canonical="/about"
  ogTitle="About Ghostbusters Virginia"
  ogDescription="Discover who we are, how we serve the community, and why Ghostbusters Virginia exists."
  ogImage="/images/gbv-gallery-10.jpg"
>
  <section class="container page" aria-labelledby="about-title">
    <h1 id="about-title" class="page-title">{copy?.pageTitle || "About Ghostbusters Virginia"}</h1>
    <p class="page-intro">
      {copy?.pageIntro || "Who we are, where we came from, and why we do what we do."}
    </p>

    <Panel heading="Who We Are">
      <p>
        Ghostbusters, Virginia (GBVA) was <strong class="glow">established in 2001</strong> by a lifelong
        Ghosthead and rather young member of the Ghostbusters community. Since then GBVA has (like many
        things) ebbed and flowed with popularity and activity, culminating in 2011 with a spike in popularity
        that has established GBVA as
        <strong class="glow">the premier Ghostbusters franchise</strong> in the grand Commonwealth of
        Virginia.
      </p>
      <hr class="divider" />
      <p>
        GBVA is unique, in that unlike other states where multiple groups manifest themselves in
        different pockets of fandom, we act as
        <strong class="glow">a large umbrella for all Ghostbusters fans in Virginia</strong>.
        Individual groups can maintain their group identity while proudly flying the GBVA banner and
        participating in GBVA events like conventions, fundraisers, build parties, and more. The
        three primary GBVA groups are
        <strong class="glow">The Richmond Division</strong>, serving the greater Richmond metro
        area, <strong class="glow">District 757</strong> protecting Southeastern Virginia from all manner
        of spooks, specters, and ghosts, and
        <strong class="glow">the NOVA Division</strong> keeping the northern border of Virginia safe and
        sound.
      </p>
      <hr class="divider" />
      <p>
        These groups are unique in their own way, but under the GBVA banner they are able to pool
        their resources and together be a stronger franchise and participate with unparalleled
        cooperation at GBVA events.
        <strong class="glow">We are stronger together than we are separate.</strong> These three groups,
        along with members from all over Virginia (including the Eastern Shore), are what make GBVA such
        a fantastic franchise and lend us a strong future filled with
        <strong class="glow">good fun, memories, and lifelong friendships</strong>.
      </p>
    </Panel>

    <Panel heading="Our Mission">
      <ul class="mission-list glow-list" role="list">
        {missionItems.map((item) => <li>{item}</li>)}
      </ul>
    </Panel>

    <Panel heading="Community Initiatives">
      <h3 class="initiative-title">Proton Pets</h3>
      <img
        src={protonPetsImage.src}
        srcset={protonPetsImage.srcset}
        sizes={protonPetsImage.sizes}
        alt={copy?.protonPetsImageAlt ||
          "Proton Pets — Ghostbusters Virginia community fundraiser for local pet shelters"}
        class="initiative-image"
        loading="lazy"
        decoding="async"
        width={protonPetsImage.width}
        height={protonPetsImage.height}
      />
      <p>
        {
          copy?.protonPetsText ||
            "Every April, Ghostbusters Virginia calls on franchises across the globe to join Proton Pets — a month-long, community-driven fundraiser supporting local pet shelters and pet pantries."
        }
      </p>
      <div class="initiative-cta">
        <Button
          variant="secondary"
          href={copy?.protonPetsLinkUrl || "https://whoyagonnacall.org/proton-pets"}
          external
        >
          {copy?.protonPetsLinkLabel || "Learn About Proton Pets"}
        </Button>
      </div>
    </Panel>
  </section>
</BaseLayout>

<style>
  /* ── Panel sizing ── */
  .page :global(.panel) {
    width: 100%;
  }

  .page :global(.panel) p {
    line-height: var(--leading-loose);
    margin-bottom: 0;
  }

  /* ── Initiative title ── */
  .initiative-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: var(--weight-semibold);
    color: var(--color-heading-section);
    text-shadow: 0 0 10px var(--color-glow-atmospheric);
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-md);
  }

  .initiative-image {
    width: 100%;
    max-height: 320px;
    object-fit: cover;
    border-radius: var(--radius-md);
    margin-bottom: var(--space-lg);
  }

  .initiative-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .page :global(.panel) a {
    color: var(--color-accent-hover);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .page :global(.panel) a:hover,
  .page :global(.panel) a:focus-visible {
    color: var(--color-link-hover);
    text-shadow: 0 0 8px var(--color-glow-atmospheric);
  }

  /* ── Mission list (uses global .glow-list) ── */
  .mission-list {
    gap: var(--space-md);
  }
</style>
