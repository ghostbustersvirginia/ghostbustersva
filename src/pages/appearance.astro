---
/**
 * Request an Appearance — multi-step form for booking Ghostbusters Virginia.
 */

import SectionHeading from "../components/ui/SectionHeading.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import AppearanceRequestForm from "../components/AppearanceRequestForm/AppearanceRequestForm.tsx";

---

<BaseLayout
  title="Request an Appearance"
  description="Request an appearance by Ghostbusters Virginia at your event, convention, or community gathering."
  canonical="/request-appearance"
  ogTitle="Request a Ghostbusters Virginia Appearance"
  ogDescription="Planning an event? Fill out our multi-step request form and we'll get back to you about bringing Ghostbusters Virginia to your event."
  ogImage="/images/ghostbusters-virginia-full-team-photo.jpg"
>
  <section class="page" aria-labelledby="request-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading id="request-section-heading" level={2}>
          Request an Appearance
        </SectionHeading>
        <p class="page-intro">
          Planning an event and want Ghostbusters Virginia to be part of it? Fill out the form below and we'll be in touch. Required fields are marked with an asterisk (*).
        </p>
        <AppearanceRequestForm client:load />
      </div>
    </div>
  </section>
</BaseLayout>
