---
/**
 * Join page — How to become a member.
 * PRD 007: Join, Contact & Donate Pages Redesign
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Panel from "../components/ui/Panel.astro";
import { getPageCopy } from "../lib/page-copy";

const copy = (await getPageCopy("join")) as {
  pageTitle?: string;
  pageIntro?: string;
  quoteLineOne?: string;
  quoteLineTwo?: string;
  whatWeLookForText?: string;
  requiredGearItems?: string[];
  beltGizmoItems?: string[];
  applyText?: string;
  applyLinkLabel?: string;
  applyLinkUrl?: string;
  noteText?: string;
} | null;

const requiredGear = copy?.requiredGearItems ?? [
  "A flight suit",
  "Black boots",
  "White web belt",
  "Elbow pads",
  "At least one belt gizmo",
];
const beltGizmos = copy?.beltGizmoItems ?? [
  "MT500 Motorola Walkie Talkie",
  "Belt Gizmo (circuit board + daughter board)",
  "Leather belt fobs with clips",
  "LifeGard 2",
  "PKE Meter",
];
const applyLinkUrl = copy?.applyLinkUrl || "https://www.facebook.com/GhostbustersVA";
const applyLinkLabel = copy?.applyLinkLabel || "Facebook page";
---

<BaseLayout
  title="Join"
  description="Learn membership requirements and how to join Ghostbusters Virginia as an active community volunteer."
  canonical="/join"
  ogTitle="Join Ghostbusters Virginia"
  ogDescription="Suit up with Ghostbusters Virginia and become part of our statewide nonprofit franchise."
  ogImage="/images/gbv-gallery-05.jpg"
>
  <section class="container page" aria-labelledby="join-title">
    <h1 id="join-title" class="page-title">{copy?.pageTitle || "Join Ghostbusters Virginia"}</h1>
    <p class="page-intro">
      {
        copy?.pageIntro ||
          "Think you have what it takes? Here's how to suit up and join our franchise."
      }
    </p>

    <blockquote class="quote-block">
      <p>
        "{
          copy?.quoteLineOne ||
            "Do you believe in UFOs, astral projections, mental telepathy, ESP, clairvoyance, spirit photography, telekinetic movement, full trance mediums, the Loch Ness monster and the theory of Atlantis?"
        }"
      </p>
      <p>
        {
          copy?.quoteLineTwo ||
            "Ready to get out there and start busting some ghosts? Excellent news rookie, we have openings!"
        }
      </p>
    </blockquote>

    <Panel heading="What We Look For">
      <p>
        {
          copy?.whatWeLookForText ||
            "To apply for membership in Ghostbusters, Virginia we simply ask that you review our Code of Conduct, and have at least one Ghostbusters canon costume. To meet these requirements, a canon costume needs to include the following:"
        }
      </p>
      <div class="gear-columns">
        <div class="gear-col">
          <h4 class="gear-col-title">Required Gear</h4>
          <ul class="glow-list" role="list">
            {requiredGear.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="gear-col">
          <h4 class="gear-col-title">Belt Gizmo Examples</h4>
          <ul class="glow-list" role="list">
            {beltGizmos.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </div>
    </Panel>

    <Panel heading="How to Apply">
      <p>
        {
          copy?.applyText ||
            "Got all your gear and ready to show us you ain't afraid of no ghosts? Message our"
        }
        {
          !copy?.applyText && (
            <a href={applyLinkUrl} target="_blank" rel="noopener noreferrer">
              {applyLinkLabel}
              <span class="sr-only"> (opens in new tab)</span>
            </a>
          )
        }
        {
          !copy?.applyText &&
            " and let us know; you will be provided a link to the membership survey and once complete, you will be notified of results following Membership Liaison Officer verification."
        }
      </p>

      <div class="callout">
        <p>
          <strong>Please Note:</strong>
          {
            copy?.noteText ||
              "We ask all applicants be able to pass a high-level background check to verify no felonies are on their record; this includes a verification with no results found on the national sex offender registry."
          }
        </p>
      </div>
    </Panel>
  </section>
</BaseLayout>

<style>
  /* ── Panel sizing ── */
  .page :global(.panel) {
    width: 100%;
  }

  .quote-block {
    width: 100%;
  }

  /* ── Gear columns layout ── */
  .gear-columns {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    margin-top: var(--space-lg);
  }

  @media (min-width: 768px) {
    .gear-columns {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .gear-col-title {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: var(--color-heading-section);
    margin-bottom: var(--space-md);
  }

  .gear-columns .glow-list {
    columns: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .gear-columns .glow-list li {
    margin-bottom: 0;
  }

  /* ── Callout note override ── */
  .callout {
    margin-top: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .callout p {
    font-size: var(--text-sm) !important;
    color: var(--color-text-muted);
    margin-bottom: 0 !important;
  }
</style>
