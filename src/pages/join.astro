---
/**
 * Join page — How to become a member.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import LightboxImageTrigger from "../components/ui/LightboxImageTrigger.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import Button from "../components/ui/Button.astro";
import CardListPanel from "../components/ui/CardListPanel.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("join");

const pageTitle = copy.pageTitle || "Join Ghostbusters Virginia";
const pageIntro =
  copy.pageIntro || "Think you have what it takes? Here's how to suit up and join our franchise.";
const quoteLineOne =
  copy.quoteLineOne ||
  "Do you believe in UFOs, astral projections, mental telepathy, ESP, clairvoyance, spirit photography, telekinetic movement, full trance mediums, the Loch Ness monster and the theory of Atlantis?";
const quoteLineTwo =
  copy.quoteLineTwo ||
  "Ready to get out there and start busting some ghosts? Excellent news rookie, we have openings!";
const whatWeLookForText =
  copy.whatWeLookForText ||
  "To apply for membership in Ghostbusters, Virginia we simply ask that you review our Code of Conduct, and have at least one Ghostbusters canon costume. To meet these requirements, a canon costume needs to include the following:";
const requiredGear = copy.requiredGearItems || [
  "A flight suit",
  "Black boots",
  "White web belt",
  "Elbow pads",
  "At least one belt gizmo",
];
const beltGizmos = copy.beltGizmoItems || [
  "MT500 Motorola Walkie Talkie",
  "Belt Gizmo (circuit board + daughter board)",
  "Leather belt fobs with clips",
  "LifeGard 2",
  "PKE Meter",
];
const showBeltGizmoSublist = copy.showBeltGizmoSublist ?? true;
const beltGizmoParentIndex = requiredGear.findIndex((item) => /belt gizmo/i.test(item));
const beltGizmoNestIndex =
  beltGizmoParentIndex >= 0 ? beltGizmoParentIndex : requiredGear.length - 1;
const notePrefix = copy.notePrefix || "Please Note:";
const noteText =
  copy.noteText ||
  "We ask all applicants be able to pass a high-level background check to verify no felonies are on their record; this includes a verification with no results found on the national sex offender registry.";
const whatWeLookForHeading = copy.whatWeLookForHeading || "What We Look For";
const requiredGearHeading = copy.requiredGearHeading || "Required Gear";
const metaTitle = copy.metaTitle || "Join";
const metaDescription =
  copy.metaDescription ||
  "Learn membership requirements and how to join Ghostbusters Virginia as an active community volunteer.";
const ogTitleVal = copy.ogTitle || "Join Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Suit up with Ghostbusters Virginia and become part of our statewide nonprofit franchise.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-movie-premiere.jpg";

const whatWeLookForImageSrc = copy.whatWeLookForImage || "/images/gbv-community-photo.jpg";
const whatWeLookForImageAlt =
  copy.whatWeLookForImageAlt || "Ghostbusters Virginia community members in full gear";
const whatWeLookForImage = await getResponsiveImageAttrs({
  src: whatWeLookForImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/join"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="join-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="join-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <blockquote class="quote-block">
          <p>&ldquo;{quoteLineOne}&rdquo;</p>
          <p>{quoteLineTwo}</p>
        </blockquote>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{whatWeLookForHeading}</SectionHeading>
        <p class="prose-text">
          {whatWeLookForText}
        </p>
        <div class="gear-layout">
          <LightboxImageTrigger
            group="join-gallery"
            src={whatWeLookForImage.src}
            alt={whatWeLookForImageAlt}
            buttonClass="page-image-lightbox"
            overlayClass="page-image-lightbox__overlay"
          >
            <img
              {...whatWeLookForImage}
              alt={whatWeLookForImageAlt}
              class="gear-layout__image"
              loading="lazy"
              decoding="async"
            />
          </LightboxImageTrigger>
          <div class="gear-card-column">
            <CardListPanel title={requiredGearHeading} listClass="card-list-panel__list--gear">
              {
                requiredGear.map((item, index) => (
                  <li>
                    {item}
                    {showBeltGizmoSublist && index === beltGizmoNestIndex && (
                      <ul class="sub-list" role="list">
                        {beltGizmos.map((gizmo) => (
                          <li>{gizmo}</li>
                        ))}
                      </ul>
                    )}
                  </li>
                ))
              }
            </CardListPanel>
            <div class="join-cta-wrapper">
              <Button variant="secondary-alt" href="/contact">Join Today</Button>
            </div>
          </div>
        </div>
        <div class="callout" style="margin-top: var(--space-3xl);">
          <p>
            <strong>{notePrefix}</strong>
            {noteText}
          </p>
        </div>
      </div>
    </div>
  </section>

  <Lightbox id="join-lightbox" label="Join page image viewer" lightboxGroup="join-gallery" />
</BaseLayout>

<style>
  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  @media (max-width: 767px) {
    .prose-text {
      text-align: center;
    }
  }

  .quote-block {
    width: 100%;
    max-width: var(--content-width-mid);
    margin-inline: auto;
  }

  .join-cta-wrapper {
    margin-top: var(--space-2xl);
    text-align: center;
  }

  .join-cta-wrapper .btn {
    min-width: 200px;
  }

  .gear-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    margin-top: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 768px) {
    .gear-layout {
      grid-template-columns: 1fr 1fr;
    }
  }

  .gear-layout__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
  }

  :global(.card-list-panel__list--gear > li) {
    text-transform: capitalize;
  }

  :global(.card-list-panel__list--gear > li:last-child) {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  :global(.card-list-panel__list--gear > li:last-child::before) {
    top: var(--space-md);
  }

  /* ---- Sub-list (belt gizmo examples) ---- */
  .sub-list {
    list-style: none;
    padding: 0;
    margin-top: var(--space-md);
    margin-left: 0.25rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .sub-list li {
    position: relative;
    padding-left: 1.5rem;
    padding-block: 2px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    cursor: default;
    transition: color var(--transition-base);
  }

  .sub-list li:hover {
    color: var(--color-text);
  }

  .sub-list li::before {
    content: "\2014";
    position: absolute;
    left: 0;
    top: 2px;
    color: var(--color-gb-green);
    font-size: var(--text-xs);
    display: inline-block;
    transition: transform var(--transition-base);
  }

  .sub-list li:hover::before {
    transform: scale(1.4);
  }

  .callout {
    margin-top: var(--space-2xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-lg) var(--space-xl);
    box-shadow: var(--shadow-panel);
  }

  .callout p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  a:hover,
  a:focus-visible {
    color: var(--color-link-hover);
  }
</style>
