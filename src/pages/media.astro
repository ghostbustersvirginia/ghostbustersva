---
/**
 * Media page — Gallery, videos, and news coverage.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import { getCollection } from "astro:content";
import { getResponsiveImageAttrs } from "../lib/images";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("media");

/* ── Data ── */
const gallery = await getCollection("gallery");
const videos = await getCollection("videos");
const news = await getCollection("news");

/* Sort news newest-first */
const sortedNews = [...news].sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

/* Pre-compute responsive gallery images */
const galleryImages = await Promise.all(
  gallery.map(async (item) => ({
    ...item,
    responsive: await getResponsiveImageAttrs({
      src: item.data.image,
      widths: [320, 640, 960],
      sizes: "(max-width: 480px) 100vw, (max-width: 768px) 50vw, 33vw",
      width: 640,
      height: 480,
    }),
  })),
);

const pageTitle = (copy?.pageTitle as string) || "Media";
const pageIntro =
  (copy?.pageIntro as string) ||
  "Photos, videos, and press coverage of our adventures across Virginia.";
const galleryHeading = (copy?.galleryHeading as string) || "Gallery";
const videosHeading = (copy?.videosHeading as string) || "Videos";
const newsHeading = (copy?.newsHeading as string) || "In The News";
const showMoreGalleryLabel = (copy?.showMoreGalleryLabel as string) || "Show More";
const showLessGalleryLabel = (copy?.showLessGalleryLabel as string) || "Show Less";
const showMoreNewsLabel = (copy?.showMoreNewsLabel as string) || "Show More";
const showLessNewsLabel = (copy?.showLessNewsLabel as string) || "Show Less";
const metaTitle = (copy?.metaTitle as string) || "Media";
const metaDescription =
  (copy?.metaDescription as string) ||
  "Browse the Ghostbusters Virginia photo gallery, watch videos, and read news coverage from across the Commonwealth.";
const ogTitleVal = (copy?.ogTitle as string) || "Media | Ghostbusters Virginia";
const ogDescriptionVal =
  (copy?.ogDescription as string) ||
  "Photos, videos, and news coverage of Ghostbusters Virginia events and appearances.";
const ogImage = (copy?.ogImage as string) || "/images/ghostbusters-virginia-full-team-photo.jpg";
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/media"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="media-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="media-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    {/* ── Gallery ── */}
    {
      galleryImages.length > 0 && (
        <div class="page-band page-band--alt">
          <div class="container">
            <SectionHeading id="gallery">{galleryHeading}</SectionHeading>
            <div class="gallery-grid" id="gallery-grid">
              {galleryImages.map((item, index) => (
                <button
                  class={`gallery-thumb${index >= 12 ? " gallery-hidden" : ""}`}
                  type="button"
                  data-lightbox-src={item.data.image}
                  data-lightbox-alt={item.data.alt}
                  aria-label={`View: ${item.data.title}`}
                >
                  <img
                    src={item.responsive.src}
                    srcset={item.responsive.srcset}
                    sizes={item.responsive.sizes}
                    alt={item.data.alt}
                    width={item.responsive.width}
                    height={item.responsive.height}
                    loading={index < 6 ? "eager" : "lazy"}
                    decoding="async"
                  />
                  <span class="gallery-thumb__expand" aria-hidden="true">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="15 3 21 3 21 9" />
                      <polyline points="9 21 3 21 3 15" />
                      <line x1="21" y1="3" x2="14" y2="10" />
                      <line x1="3" y1="21" x2="10" y2="14" />
                    </svg>
                  </span>
                </button>
              ))}
            </div>
            {galleryImages.length > 12 && (
              <div class="show-toggle">
                <Button variant="secondary-alt" type="button" class="toggle-btn" id="gallery-show-more">
                  {showMoreGalleryLabel} ({galleryImages.length - 12} more)
                </Button>
                <Button
                  variant="secondary-alt"
                  type="button"
                  class="toggle-btn"
                  id="gallery-show-less"
                  hidden
                >
                  {showLessGalleryLabel}
                </Button>
              </div>
            )}
          </div>
        </div>
      )
    }

    {/* ── Videos ── */}
    {
      videos.length > 0 && (
        <div class="page-band page-band--white">
          <div class="container">
            <SectionHeading id="videos">{videosHeading}</SectionHeading>
            <div class="video-grid">
              {videos.map((video) => (
                <div class="video-card">
                  <div class="video-embed">
                    <lite-youtube
                      videoid={video.data.youtubeId}
                      playlabel={`Play: ${video.data.title}`}
                    >
                      <a
                        href={`https://youtube.com/watch?v=${video.data.youtubeId}`}
                        class="lty-playbtn"
                        title={`Play: ${video.data.title}`}
                      >
                        <span class="lyt-visually-hidden">Play: {video.data.title}</span>
                      </a>
                    </lite-youtube>
                  </div>
                  <h3 class="video-title">{video.data.title}</h3>
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {/* ── News ── */}
    {
      sortedNews.length > 0 && (
        <div class="page-band page-band--alt">
          <div class="container">
            <SectionHeading id="news">{newsHeading}</SectionHeading>
            <ul class="news-list" id="news-grid" role="list">
              {sortedNews.map((article, index) => (
                <li class={`news-item${index >= 6 ? " news-hidden" : ""}`}>
                  <a
                    href={article.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="news-link"
                  >
                    {article.data.image && (
                      <div class="news-link__image-wrapper">
                        <img
                          class="news-link__image"
                          src={article.data.image}
                          alt=""
                          loading="lazy"
                          decoding="async"
                        />
                      </div>
                    )}
                    <div class="news-link__body">
                      <span class="news-link__title">{article.data.title}</span>
                      <p class="news-link__excerpt">{article.data.excerpt}</p>
                      <div class="news-link__footer">
                        <span class="news-link__source">{article.data.source}</span>
                        {article.data.location && (
                          <span class="news-link__location">
                            <svg
                              class="news-link__footer-icon"
                              xmlns="http://www.w3.org/2000/svg"
                              width="14"
                              height="14"
                              viewBox="0 0 24 24"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              aria-hidden="true"
                            >
                              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
                              <circle cx="12" cy="10" r="3" />
                            </svg>
                            <span>{article.data.location}</span>
                          </span>
                        )}
                      </div>
                    </div>
                    <svg
                      class="news-link__external"
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                      <polyline points="15 3 21 3 21 9" />
                      <line x1="10" y1="14" x2="21" y2="3" />
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
            {sortedNews.length > 6 && (
              <div class="show-toggle">
                <Button variant="secondary-alt" type="button" class="toggle-btn" id="news-show-more">
                  {showMoreNewsLabel} ({sortedNews.length - 6} more)
                </Button>
                <Button
                  variant="secondary-alt"
                  type="button"
                  class="toggle-btn"
                  id="news-show-less"
                  hidden
                >
                  {showLessNewsLabel}
                </Button>
              </div>
            )}
          </div>
        </div>
      )
    }

    <Lightbox id="gallery-lightbox" hasNav label="Gallery viewer" />
  </section>
</BaseLayout>

{/* ── lite-youtube embed (lightweight YouTube facade) ── */}
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.3/src/lite-yt-embed.min.css"
/>
<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/lite-youtube-embed@0.3.3/src/lite-yt-embed.min.js"></script>

<script>
  import { setLightboxPreviousFocus } from "../lib/lightbox";

  /* ── Gallery lightbox ── */
  const lightbox = document.getElementById("gallery-lightbox") as HTMLElement | null;
  const lbImage = lightbox?.querySelector(".lightbox__image") as HTMLImageElement | null;
  const lbPrev = lightbox?.querySelector(".lightbox__nav--prev") as HTMLButtonElement | null;
  const lbNext = lightbox?.querySelector(".lightbox__nav--next") as HTMLButtonElement | null;

  const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-lightbox-src]"));
  let currentIndex = 0;

  function openLightbox(index: number) {
    if (!lightbox || !lbImage) return;
    currentIndex = index;
    const thumb = thumbs[index];
    lbImage.src = thumb.dataset.lightboxSrc ?? "";
    lbImage.alt = thumb.dataset.lightboxAlt ?? "";
    setLightboxPreviousFocus(lightbox, thumb, "gallery-thumb");
    lightbox.hidden = false;
    document.body.style.overflow = "hidden";
    lightbox.querySelector<HTMLButtonElement>(".lightbox__close")?.focus();
  }

  thumbs.forEach((thumb, i) => {
    thumb.addEventListener("click", () => openLightbox(i));
  });

  lbPrev?.addEventListener("click", () => {
    openLightbox((currentIndex - 1 + thumbs.length) % thumbs.length);
  });

  lbNext?.addEventListener("click", () => {
    openLightbox((currentIndex + 1) % thumbs.length);
  });

  lightbox?.querySelector(".lightbox__close")?.addEventListener("click", () => {
    if (!lightbox) return;
    lightbox.hidden = true;
    document.body.style.overflow = "";
    const prevId = lightbox.dataset.previousFocus;
    if (prevId) document.getElementById(prevId)?.focus();
  });

  lightbox?.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") {
      lightbox.querySelector<HTMLButtonElement>(".lightbox__close")?.click();
    } else if (e.key === "ArrowLeft") {
      lbPrev?.click();
    } else if (e.key === "ArrowRight") {
      lbNext?.click();
    }
  });

  /* ── Show more / less toggles ── */
  function setupToggle(
    showMoreId: string,
    showLessId: string,
    hiddenClass: string,
    containerId: string,
  ) {
    const showMore = document.getElementById(showMoreId) as HTMLButtonElement | null;
    const showLess = document.getElementById(showLessId) as HTMLButtonElement | null;
    const container = document.getElementById(containerId);
    if (!showMore || !showLess || !container) return;

    showMore.addEventListener("click", () => {
      container.querySelectorAll<HTMLElement>(`.${hiddenClass}`).forEach((el) => {
        el.classList.remove(hiddenClass);
      });
      showMore.hidden = true;
      showLess.hidden = false;
    });

    showLess.addEventListener("click", () => {
      container.querySelectorAll<HTMLElement>(`:scope > :nth-child(n+13)`).forEach((el) => {
        el.classList.add(hiddenClass);
      });
      showLess.hidden = true;
      showMore.hidden = false;
      container.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  }

  setupToggle("gallery-show-more", "gallery-show-less", "gallery-hidden", "gallery-grid");
  setupToggle("news-show-more", "news-show-less", "news-hidden", "news-grid");
</script>

<style>
  .media-section {
    width: 100%;
  }

  /* ── Gallery grid ── */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-md);
  }

  @media (min-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
  }

  .gallery-thumb {
    position: relative;
    background: none;
    border: none;
    border-radius: var(--radius-md);
    padding: 0;
    cursor: pointer;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    transition: box-shadow 0.2s ease;
  }

  .gallery-thumb:hover,
  .gallery-thumb:focus-visible {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .gallery-thumb:hover img {
    transform: scale(1.03);
  }

  .gallery-thumb__expand {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }

  .gallery-thumb:hover .gallery-thumb__expand,
  .gallery-thumb:focus-visible .gallery-thumb__expand {
    opacity: 1;
  }

  .gallery-hidden {
    display: none;
  }

  /* ── Video grid ── */
  .video-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
  }

  @media (min-width: 768px) {
    .video-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .video-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .video-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .video-embed {
    aspect-ratio: 16 / 9;
    width: 100%;
  }

  .video-embed lite-youtube {
    width: 100%;
    height: 100%;
  }

  .video-title {
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
  }

  /* ── News list (single column, event-card style) ── */
  .news-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .news-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      color var(--transition-base);
  }

  @media (min-width: 769px) {
    .news-item {
      color: var(--color-text-muted);
    }
    .news-item:hover {
      color: var(--color-text);
    }
  }

  .news-item:hover {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-hover);
  }

  .news-link {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .news-link__image-wrapper {
    flex-shrink: 0;
    width: 260px;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .news-link__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .news-link__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .news-link__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: inherit;
    line-height: var(--leading-tight);
    transition: color var(--transition-base);
  }

  @media (min-width: 769px) {
    .news-item:hover .news-link__title {
      color: var(--color-accent);
    }
  }

  .news-link__meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
  }

  .news-link__excerpt {
    font-size: var(--text-base);
    color: inherit;
    line-height: var(--leading-normal);
    margin: 0;
    transition: color var(--transition-base);
  }

  .news-link__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1;
    transition: color var(--transition-base);
  }

  .news-link__source {
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
  }

  .news-link__location {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin-left: auto;
  }

  .news-link__footer-icon {
    flex-shrink: 0;
  }

  @media (min-width: 769px) {
    .news-item:hover .news-link__footer {
      color: var(--color-gb-green);
    }
  }

  .news-link__external {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
  }

  .news-item:hover .news-link__external {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .news-link {
      flex-direction: column;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }
    .news-link__image-wrapper {
      width: 100%;
      max-height: 200px;
    }
  }

  .news-hidden {
    display: none;
  }

  .show-toggle {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }
</style>
