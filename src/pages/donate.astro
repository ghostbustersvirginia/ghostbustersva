---
/**
 * Donate page — Supporting Ghostbusters Virginia's charitable mission.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import Lightbox from "../components/ui/Lightbox.astro";
import LightboxImageTrigger from "../components/ui/LightboxImageTrigger.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import DonationMeter from "../components/DonationMeter.astro";
import CardListPanel from "../components/ui/CardListPanel.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSafeHref, isSafeExternalUrl } from "../lib/links";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("donate");
const settings = await getSiteSettings();
const defaultDonateUrl =
  "https://secure2.wish.org/site/TR;jsessionid=00000000.app20002b?team_id=58435&fr_id=7464&pg=team&NONCE_TOKEN=16AE47C509ECB858ECB963CD3D174802";
const donateUrl = settings.donateUrl || defaultDonateUrl;
const safeDonateUrl = isSafeExternalUrl(donateUrl) ? donateUrl : defaultDonateUrl;

const pageTitle = copy.pageTitle || "Support Our Mission";
const pageIntro =
  copy.pageIntro ||
  "Every dollar helps us keep busting ghosts and supporting communities across Virginia.";
const donationHeading = copy.donationHeading || "Make a Donation";
const donationText =
  copy.donationText ||
  "Ghostbusters Virginia is a volunteer-run, community-focused franchise. Your generous donations help us fund charitable events, maintain the Ecto, purchase supplies for community outreach, and keep the franchise running strong.";
const donationCardHeading = copy.donationCardHeading || "Often Donated to Toys for Tots";
const donationItems = copy.donationItems || [
  "New, unwrapped toys",
  "Board games and puzzles",
  "Action figures and dolls",
  "Building sets and STEM kits",
  "Books and educational toys",
  "Sports balls and outdoor play items",
];
const donationImageSrc =
  copy.donationImage || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";
const donationImageAlt =
  copy.donationImageAlt ||
  "Ghostbusters Virginia members supporting a Toys for Tots donation drive";
const donationCtaLabel = copy.donationCtaLabel || "Donate to Make-A-Wish";
const communityHeading = copy.communityHeading || "Community Partners";
const communityText =
  copy.communityText ||
  "Ghostbusters Virginia partners with schools, nonprofits, shelters, and event organizers to bring positive, family-friendly experiences to communities.";
const communityParagraphs = String(communityText)
  .split(/\n\s*\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const volunteerHeading = copy.volunteerHeading || "Volunteer With Us";
const volunteerText =
  copy.volunteerText ||
  "Volunteers help Ghostbusters Virginia deliver welcoming, community-first events that raise awareness and support local causes.";
const volunteerParagraphs = String(volunteerText)
  .split(/\n\s*\n+/)
  .map((paragraph) => paragraph.trim())
  .filter(Boolean);
const volunteerCtaLabel = copy.volunteerCtaLabel || "Join the Team";
const volunteerCtaHref = copy.volunteerCtaHref || "/join";
const communityCtaLabel = copy.communityCtaLabel || "Contact Us";
const communityCtaHref = copy.communityCtaHref || "/contact";
const safeCommunityCtaHref = getSafeHref(communityCtaHref) || "/contact";
const safeVolunteerCtaHref = getSafeHref(volunteerCtaHref) || "/join";
const communityImageSrc =
  copy.communityImage || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";
const communityImageAlt =
  copy.communityImageAlt || "Ghostbusters Virginia members at a Toys for Tots charity drive";
const volunteerImageSrc =
  copy.volunteerImage || "/images/ghostbusters-virginia-firefighters-visit.jpg";
const volunteerImageAlt =
  copy.volunteerImageAlt || "Ghostbusters Virginia members visiting a local fire station";
const metaTitle = copy.metaTitle || "Donate";
const metaDescription =
  copy.metaDescription ||
  "Support Ghostbusters Virginia through donations, community partnerships, and volunteer opportunities.";
const ogTitleVal = copy.ogTitle || "Donate | Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Help fund Ghostbusters Virginia's charitable events and community outreach across the Commonwealth.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";

const communityImage = await getResponsiveImageAttrs({
  src: communityImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
const volunteerImage = await getResponsiveImageAttrs({
  src: volunteerImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
const donationImage = await getResponsiveImageAttrs({
  src: donationImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 440px",
  width: 1200,
  height: 1200,
  quality: 75,
});
const mtftfLogo = await getResponsiveImageAttrs({
  src: "/images/MTFTF-Official-Logo-Transparent-background.png",
  widths: [360, 560, 760],
  sizes: "(max-width: 768px) 75vw, 420px",
  width: 760,
  height: 760,
  quality: 90,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/donate"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="donate-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="donate-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <div class="meter-top">
          <DonationMeter />
          <p class="meter-caption">
            The needle shows our team&rsquo;s total raised for Make-A-Wish Greater Virginia since
            2021, measured against the current campaign goal.
          </p>
        </div>
        <div class="impact-stats">
          <div class="impact-stat">
            <span class="impact-stat__value">Wish Your Way</span>
            <span class="impact-stat__label"
              >Make-A-Wish's peer-to-peer fundraising challenge. Teams form around a shared personal
              goal&mdash;a run, a cosplay weekend, a community event&mdash;and raise money in its
              honor. We bring the Ecto-1, the suits, and the commitment.</span
            >
          </div>
          <div class="impact-stat">
            <span class="impact-stat__value">Since 2021</span>
            <span class="impact-stat__label"
              >Ghostbusters Virginia has been a registered fundraising team in the Make-A-Wish
              Greater Virginia chapter since 2021. Every appearance, every dollar, and every fan
              interaction is part of that effort.</span
            >
          </div>
          <div class="impact-stat">
            <span class="impact-stat__value">Make-A-Wish VA</span>
            <span class="impact-stat__label"
              >Make-A-Wish Greater Virginia grants life-changing wishes to children facing critical
              illnesses across the Commonwealth. Each wish is funded entirely by community
              giving&mdash;no government support.</span
            >
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{donationHeading}</SectionHeading>
        <p class="prose-text prose-text--centered-mobile">{donationText}</p>
        <div class="donation-layout">
          <div class="donation-layout__image-col">
            <img
              {...donationImage}
              alt={donationImageAlt}
              class="donation-layout__image"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="donation-support-block">
            <CardListPanel title={donationCardHeading}>
              {donationItems.map((item) => <li>{item}</li>)}
              <div slot="footer" class="donate-cta donate-cta--card">
                <Button variant="secondary" href={safeDonateUrl} external>
                  {donationCtaLabel}
                </Button>
              </div>
            </CardListPanel>

            <img
              {...mtftfLogo}
              class="donation-support-block__logo"
              alt="MTFTF official logo"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <SectionHeading>{communityHeading}</SectionHeading>
        <div class="zigzag">
          <div class="zigzag__media">
            <LightboxImageTrigger
              group="donate-gallery"
              src={communityImage.src}
              alt={communityImageAlt}
              buttonClass="page-image-lightbox"
              overlayClass="page-image-lightbox__overlay"
            >
              <img
                {...communityImage}
                alt={communityImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <div class="zigzag__copy">
              {communityParagraphs.map((paragraph) => <p class="prose-text">{paragraph}</p>)}
            </div>
            <div class="donate-cta donate-cta--right">
              <Button variant="secondary" href={safeCommunityCtaHref}>
                {communityCtaLabel}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--wide">
        <SectionHeading>{volunteerHeading}</SectionHeading>
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media">
            <LightboxImageTrigger
              group="donate-gallery"
              src={volunteerImage.src}
              alt={volunteerImageAlt}
              buttonClass="page-image-lightbox"
              overlayClass="page-image-lightbox__overlay"
            >
              <img
                {...volunteerImage}
                alt={volunteerImageAlt}
                class="zigzag__img"
                loading="lazy"
                decoding="async"
              />
            </LightboxImageTrigger>
          </div>
          <div class="zigzag__text">
            <div class="zigzag__copy">
              {volunteerParagraphs.map((paragraph) => <p class="prose-text">{paragraph}</p>)}
            </div>
            <div class="donate-cta">
              <Button variant="secondary-alt" href={safeVolunteerCtaHref}>
                {volunteerCtaLabel}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <Lightbox
      id="donate-lightbox"
      label="Donate page image viewer"
      lightboxGroup="donate-gallery"
    />
  </section>
</BaseLayout>

<style>
  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
    margin-bottom: 0;
  }

  .donate-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .donate-cta--card {
    margin-top: var(--space-lg);
  }

  .meter-caption {
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-loose);
    text-align: center;
  }

  .meter-top {
    margin-top: 0;
  }

  .impact-stats {
    margin-top: var(--space-xl);
    display: grid;
    gap: var(--space-md);
  }

  .impact-stat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    box-shadow: var(--shadow-panel);
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .impact-stat:hover {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-elevated-soft);
    transform: translateY(-2px);
  }

  .impact-stat:hover .impact-stat__value {
    color: var(--color-accent);
  }

  .impact-stat__value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-text);
    transition: color var(--transition-base);
  }

  .impact-stat__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  .donation-layout {
    margin-top: var(--space-xl);
    display: grid;
    gap: var(--space-xl);
    align-items: start;
  }

  .donation-layout__image-col {
    overflow: hidden;
    border-radius: var(--radius-md);
  }

  .donation-layout__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    object-position: top;
  }

  .donation-support-block {
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    margin-inline: auto;
  }

  .donation-support-block__logo {
    width: min(100%, 420px);
    height: auto;
    object-fit: contain;
    display: block;
  }

  .zigzag {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: stretch;
  }

  .zigzag__img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-md);
    display: block;
  }

  .zigzag__text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .zigzag__copy {
    display: grid;
    gap: var(--space-md);
  }

  .zigzag__copy .prose-text {
    margin: 0;
  }

  .zigzag__text .donate-cta {
    justify-content: flex-start;
  }

  .zigzag__text .donate-cta--right {
    justify-content: flex-end;
  }

  .container--wide {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  @media (min-width: 769px) {
    .impact-stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-lg);
    }

    .donation-layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 440px);
      gap: var(--space-2xl);
      align-items: start;
    }

    .donation-layout__image-col {
      align-self: stretch;
      position: relative;
      min-height: 200px;
    }

    .donation-layout__image-col .donation-layout__image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: top;
    }

    .zigzag {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .zigzag--reverse .zigzag__media {
      order: 2;
    }

    .zigzag--reverse .zigzag__text {
      order: 1;
    }
  }

  @media (max-width: 768px) {
    .prose-text--centered-mobile {
      text-align: center;
    }

    .zigzag__copy .prose-text {
      text-align: center;
    }

    .zigzag__text .donate-cta {
      justify-content: center;
    }

    .donation-layout__image-col {
      max-height: 300px;
    }
  }
</style>
