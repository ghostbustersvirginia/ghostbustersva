---
/**
 * Donate page — Supporting Ghostbusters Virginia's charitable mission.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import SwagGrid from "../components/SwagGrid.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("donate");
const settings = await getSiteSettings();
const donateUrl = settings.donateUrl || "https://www.paypal.com/paypalme/GhostbustersVA";
const storeUrl = settings.storeUrl || "https://www.teepublic.com/user/ghostbusters-virginia";

const pageTitle = (copy?.pageTitle as string) || "Support Our Mission";
const pageIntro =
  (copy?.pageIntro as string) ||
  "Every dollar helps us keep busting ghosts and supporting communities across Virginia.";
const donationHeading = (copy?.donationHeading as string) || "Make a Donation";
const donationText =
  (copy?.donationText as string) ||
  "Ghostbusters Virginia is a volunteer-run, community-focused franchise. Your generous donations help us fund charitable events, maintain the Ecto, purchase supplies for community outreach, and keep the franchise running strong.";
const donationCtaLabel = (copy?.donationCtaLabel as string) || "Donate";
const swagHeading = (copy?.swagHeading as string) || "Get Some Swag";
const swagIntro =
  (copy?.swagIntro as string) ||
  "Rep the franchise! Every purchase supports Ghostbusters Virginia. Each item opens our TeePublic store in a new tab.";
const swagCtaLabel = (copy?.swagCtaLabel as string) || "Visit Our Store";
const communityHeading = (copy?.communityHeading as string) || "Community Partners";
const communityText =
  (copy?.communityText as string) ||
  "Ghostbusters Virginia partners with schools, nonprofits, shelters, and event organizers to bring positive, family-friendly experiences to communities.";
const volunteerHeading = (copy?.volunteerHeading as string) || "Volunteer With Us";
const volunteerText =
  (copy?.volunteerText as string) ||
  "Volunteers help Ghostbusters Virginia deliver welcoming, community-first events that raise awareness and support local causes.";
const volunteerCtaLabel = (copy?.volunteerCtaLabel as string) || "Join the Team";
const volunteerCtaHref = (copy?.volunteerCtaHref as string) || "/join";
const communityCtaLabel = (copy?.communityCtaLabel as string) || "Contact Us";
const communityCtaHref = (copy?.communityCtaHref as string) || "/contact";
const communityImageSrc =
  (copy?.communityImage as string) || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";
const communityImageAlt =
  (copy?.communityImageAlt as string) ||
  "Ghostbusters Virginia members at a Toys for Tots charity drive";
const volunteerImageSrc =
  (copy?.volunteerImage as string) || "/images/ghostbusters-virginia-firefighters-visit.jpg";
const volunteerImageAlt =
  (copy?.volunteerImageAlt as string) ||
  "Ghostbusters Virginia members visiting a local fire station";
const metaTitle = (copy?.metaTitle as string) || "Donate";
const metaDescription =
  (copy?.metaDescription as string) ||
  "Support Ghostbusters Virginia through donations, swag purchases, and community partnerships.";
const ogTitleVal = (copy?.ogTitle as string) || "Donate | Ghostbusters Virginia";
const ogDescriptionVal =
  (copy?.ogDescription as string) ||
  "Help fund Ghostbusters Virginia's charitable events and community outreach across the Commonwealth.";
const ogImage =
  (copy?.ogImage as string) || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";

const communityImage = await getResponsiveImageAttrs({
  src: communityImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
const volunteerImage = await getResponsiveImageAttrs({
  src: volunteerImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/donate"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="donate-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="donate-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{donationHeading}</SectionHeading>
        <div class="highlight-card highlight-card--centered">
          <p class="prose-text">{donationText}</p>
          <div class="donate-cta">
            <Button variant="secondary" disabled> {donationCtaLabel} </Button>
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container">
        <SectionHeading id="swag">{swagHeading}</SectionHeading>
        <SwagGrid subtitle={swagIntro} ctaLabel={swagCtaLabel} ctaHref={storeUrl} ctaVariant="secondary" />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{communityHeading}</SectionHeading>
        <img
          src={communityImage.src}
          srcset={communityImage.srcset}
          sizes={communityImage.sizes}
          alt={communityImageAlt}
          class="section-image"
          loading="lazy"
          decoding="async"
          width={communityImage.width}
          height={communityImage.height}
        />
        <div class="highlight-card highlight-card--centered">
          <p class="prose-text">{communityText}</p>
          <div class="donate-cta">
            <Button variant="secondary" href={communityCtaHref}>
              {communityCtaLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--mid">
        <SectionHeading>{volunteerHeading}</SectionHeading>
        <img
          src={volunteerImage.src}
          srcset={volunteerImage.srcset}
          sizes={volunteerImage.sizes}
          alt={volunteerImageAlt}
          class="section-image"
          loading="lazy"
          decoding="async"
          width={volunteerImage.width}
          height={volunteerImage.height}
        />
        <div class="highlight-card highlight-card--alt highlight-card--centered">
          <p class="prose-text">{volunteerText}</p>
          <div class="donate-cta">
            <Button variant="secondary-alt" href={volunteerCtaHref}>
              {volunteerCtaLabel}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>

  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--alt {
    background: var(--color-surface-alt);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  .donate-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }


</style>
