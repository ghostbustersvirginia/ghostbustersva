---
/**
 * Donate page — Supporting Ghostbusters Virginia's charitable mission.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/ui/Button.astro";
import PageHeader from "../components/ui/PageHeader.astro";
import SectionHeading from "../components/ui/SectionHeading.astro";
import SwagGrid from "../components/SwagGrid.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { getSafeCmsHref, isSafeExternalUrl } from "../lib/links";
import { getSiteSettings } from "../lib/settings";
import { getPageCopy } from "../lib/page-copy";

const copy = await getPageCopy("donate");
const settings = await getSiteSettings();
const storeUrl = settings.storeUrl || "https://www.teepublic.com/user/ghostbusters-virginia";
const safeStoreUrl = isSafeExternalUrl(storeUrl)
  ? storeUrl
  : "https://www.teepublic.com/user/ghostbusters-virginia";

const pageTitle = copy.pageTitle || "Support Our Mission";
const pageIntro =
  copy.pageIntro ||
  "Every dollar helps us keep busting ghosts and supporting communities across Virginia.";
const donationHeading = copy.donationHeading || "Make a Donation";
const donationText =
  copy.donationText ||
  "Ghostbusters Virginia is a volunteer-run, community-focused franchise. Your generous donations help us fund charitable events, maintain the Ecto, purchase supplies for community outreach, and keep the franchise running strong.";
const donationCtaLabel = copy.donationCtaLabel || "Donate";
const swagHeading = copy.swagHeading || "Get Some Swag";
const swagIntro =
  copy.swagIntro ||
  "Rep the franchise! Every purchase supports Ghostbusters Virginia. Each item opens our TeePublic store in a new tab.";
const swagCtaLabel = copy.swagCtaLabel || "Visit Our Store";
const communityHeading = copy.communityHeading || "Community Partners";
const communityText =
  copy.communityText ||
  "Ghostbusters Virginia partners with schools, nonprofits, shelters, and event organizers to bring positive, family-friendly experiences to communities.";
const volunteerHeading = copy.volunteerHeading || "Volunteer With Us";
const volunteerText =
  copy.volunteerText ||
  "Volunteers help Ghostbusters Virginia deliver welcoming, community-first events that raise awareness and support local causes.";
const volunteerCtaLabel = copy.volunteerCtaLabel || "Join the Team";
const volunteerCtaHref = copy.volunteerCtaHref || "/join";
const communityCtaLabel = copy.communityCtaLabel || "Contact Us";
const communityCtaHref = copy.communityCtaHref || "/contact";
const safeCommunityCtaHref = getSafeCmsHref(communityCtaHref) || "/contact";
const safeVolunteerCtaHref = getSafeCmsHref(volunteerCtaHref) || "/join";
const communityImageSrc =
  copy.communityImage || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";
const communityImageAlt =
  copy.communityImageAlt || "Ghostbusters Virginia members at a Toys for Tots charity drive";
const volunteerImageSrc =
  copy.volunteerImage || "/images/ghostbusters-virginia-firefighters-visit.jpg";
const volunteerImageAlt =
  copy.volunteerImageAlt || "Ghostbusters Virginia members visiting a local fire station";
const metaTitle = copy.metaTitle || "Donate";
const metaDescription =
  copy.metaDescription ||
  "Support Ghostbusters Virginia through donations, swag purchases, and community partnerships.";
const ogTitleVal = copy.ogTitle || "Donate | Ghostbusters Virginia";
const ogDescriptionVal =
  copy.ogDescription ||
  "Help fund Ghostbusters Virginia's charitable events and community outreach across the Commonwealth.";
const ogImage = copy.ogImage || "/images/ghostbusters-virginia-toys-for-tots-drive.jpg";

const communityImage = await getResponsiveImageAttrs({
  src: communityImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
const volunteerImage = await getResponsiveImageAttrs({
  src: volunteerImageSrc,
  widths: [640, 960, 1200],
  sizes: "(max-width: 768px) 100vw, 864px",
  width: 1200,
  height: 675,
  quality: 75,
});
---

<BaseLayout
  title={metaTitle}
  description={metaDescription}
  canonical="/donate"
  ogTitle={ogTitleVal}
  ogDescription={ogDescriptionVal}
  ogImage={ogImage}
>
  <section class="page" aria-labelledby="donate-title">
    <div class="page-band page-band--white">
      <div class="container container--mid">
        <PageHeader id="donate-title" title={pageTitle} subtitle={pageIntro} />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--mid">
        <SectionHeading>{donationHeading}</SectionHeading>
        <div class="highlight-card highlight-card--centered">
          <p class="prose-text">{donationText}</p>
          <div class="donate-cta">
            <Button variant="secondary" disabled> {donationCtaLabel} </Button>
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container">
        <SectionHeading id="swag">{swagHeading}</SectionHeading>
        <SwagGrid
          subtitle={swagIntro}
          ctaLabel={swagCtaLabel}
          ctaHref={safeStoreUrl}
          ctaVariant="secondary"
        />
      </div>
    </div>

    <div class="page-band page-band--alt">
      <div class="container container--wide">
        <SectionHeading>{communityHeading}</SectionHeading>
        <div class="zigzag">
          <div class="zigzag__media">
            <img
              {...communityImage}
              alt={communityImageAlt}
              class="zigzag__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{communityText}</p>
            <div class="donate-cta donate-cta--right">
              <Button variant="secondary" href={safeCommunityCtaHref}>
                {communityCtaLabel}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="page-band page-band--white">
      <div class="container container--wide">
        <SectionHeading>{volunteerHeading}</SectionHeading>
        <div class="zigzag zigzag--reverse">
          <div class="zigzag__media">
            <img
              {...volunteerImage}
              alt={volunteerImageAlt}
              class="zigzag__img"
              loading="lazy"
              decoding="async"
            />
          </div>
          <div class="zigzag__text">
            <p class="prose-text">{volunteerText}</p>
            <div class="donate-cta">
              <Button variant="secondary-alt" href={safeVolunteerCtaHref}>
                {volunteerCtaLabel}
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .prose-text {
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .highlight-card--alt {
    background: var(--color-surface-alt);
  }

  .highlight-card--centered {
    text-align: center;
  }

  .highlight-card .prose-text {
    margin-bottom: 0;
  }

  .donate-cta {
    display: flex;
    justify-content: center;
    margin-top: var(--space-xl);
  }

  .zigzag {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .zigzag__img {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-md);
    display: block;
  }

  .zigzag__text {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .zigzag__text .donate-cta {
    justify-content: flex-start;
  }

  .zigzag__text .donate-cta--right {
    justify-content: flex-end;
  }

  .container--wide {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: var(--space-xl);
  }

  @media (min-width: 769px) {
    .zigzag {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-3xl);
    }

    .zigzag--reverse .zigzag__media {
      order: 2;
    }

    .zigzag--reverse .zigzag__text {
      order: 1;
    }
  }

  @media (max-width: 768px) {
    .zigzag__text .donate-cta {
      justify-content: center;
    }
  }
</style>
