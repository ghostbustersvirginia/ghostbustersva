---
interface Props {
  class?: string;
}

const { class: className } = Astro.props as Props;

const ARC_START_DEG = -90;
const ARC_END_DEG = 90;
const CENTER_X = 300;
const CENTER_Y = 248;
const TICK_OUTER_RADIUS = 210;
const TICK_INNER_MINOR = 199;
const TICK_INNER_MAJOR = 189;
const DANGER_START_PERCENT = 80;
const DANGER_INNER_RADIUS = 187;

function pointOnArc(angleDeg: number, radius: number) {
  const angleRad = (angleDeg * Math.PI) / 180;

  return {
    x: CENTER_X + Math.sin(angleRad) * radius,
    y: CENTER_Y - Math.cos(angleRad) * radius,
  };
}

const arcStart = pointOnArc(ARC_START_DEG, TICK_OUTER_RADIUS);
const arcEnd = pointOnArc(ARC_END_DEG, TICK_OUTER_RADIUS);
const arcPath = `M ${arcStart.x} ${arcStart.y} A ${TICK_OUTER_RADIUS} ${TICK_OUTER_RADIUS} 0 1 1 ${arcEnd.x} ${arcEnd.y}`;

const dangerStartDeg = ARC_START_DEG + (DANGER_START_PERCENT / 100) * (ARC_END_DEG - ARC_START_DEG);
const dangerOuterStart = pointOnArc(dangerStartDeg, TICK_OUTER_RADIUS);
const dangerOuterEnd = pointOnArc(ARC_END_DEG, TICK_OUTER_RADIUS);
const dangerInnerStart = pointOnArc(dangerStartDeg, DANGER_INNER_RADIUS);
const dangerInnerEnd = pointOnArc(ARC_END_DEG, DANGER_INNER_RADIUS);
const dangerSectorPath =
  `M ${dangerOuterStart.x} ${dangerOuterStart.y} ` +
  `A ${TICK_OUTER_RADIUS} ${TICK_OUTER_RADIUS} 0 0 1 ${dangerOuterEnd.x} ${dangerOuterEnd.y} ` +
  `L ${dangerInnerEnd.x} ${dangerInnerEnd.y} ` +
  `A ${DANGER_INNER_RADIUS} ${DANGER_INNER_RADIUS} 0 0 0 ${dangerInnerStart.x} ${dangerInnerStart.y} Z`;

const ticks = Array.from({ length: 51 }, (_, index) => {
  const percent = index * 2;
  const angle = ARC_START_DEG + (percent / 100) * (ARC_END_DEG - ARC_START_DEG);
  const isMajor = percent % 10 === 0;
  const innerRadius = isMajor ? TICK_INNER_MAJOR : TICK_INNER_MINOR;
  const outer = pointOnArc(angle, TICK_OUTER_RADIUS);
  const inner = pointOnArc(angle, innerRadius);

  return {
    percent,
    isMajor,
    isDanger: percent >= DANGER_START_PERCENT,
    x1: inner.x,
    y1: inner.y,
    x2: outer.x,
    y2: outer.y,
  };
});

const scaleLabels = [
  { percent: 0, value: 0, radius: 180, anchor: "start" },
  { percent: 20, value: 5000, radius: 180, anchor: "middle" },
  { percent: 40, value: 10000, radius: 180, anchor: "middle" },
  { percent: 60, value: 15000, radius: 180, anchor: "middle" },
  { percent: 80, value: 20000, radius: 180, anchor: "middle" },
  { percent: 100, value: 25000, radius: 180, anchor: "end" },
].map(({ percent, value, radius, anchor }) => {
  const angle = ARC_START_DEG + (percent / 100) * (ARC_END_DEG - ARC_START_DEG);
  const point = pointOnArc(angle, radius);

  return {
    value,
    x: point.x,
    y: point.y,
    anchor,
  };
});
---

<div class:list={["donation-meter", className]} data-donation-meter data-state="loading">
  <p class="sr-only donation-meter__status" data-meter-status aria-live="polite" aria-atomic="true">
    Donation meter loading.
  </p>
  <svg
    class="donation-meter__svg"
    viewBox="0 0 600 400"
    role="img"
    aria-labelledby="donation-meter-title"
  >
    <defs>
      <radialGradient id="meter-face-gradient" cx="50%" cy="44%" r="70%">
        <stop offset="0%" class="donation-meter__stop-face-center"></stop>
        <stop offset="100%" class="donation-meter__stop-face-edge"></stop>
      </radialGradient>

      <radialGradient id="meter-bezel-gradient" cx="48%" cy="40%" r="70%">
        <stop offset="0%" class="donation-meter__stop-bezel-outer"></stop>
        <stop offset="58%" class="donation-meter__stop-bezel-mid"></stop>
        <stop offset="100%" class="donation-meter__stop-bezel-inner"></stop>
      </radialGradient>

      <radialGradient id="meter-pivot-gradient" cx="42%" cy="35%" r="70%">
        <stop offset="0%" class="donation-meter__stop-pivot-center"></stop>
        <stop offset="100%" class="donation-meter__stop-pivot-edge"></stop>
      </radialGradient>

      <pattern id="meter-face-texture" width="4" height="4" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.32" class="donation-meter__texture-dot"></circle>
        <circle cx="3" cy="3" r="0.32" class="donation-meter__texture-dot"></circle>
      </pattern>

      <pattern
        id="meter-bezel-brush"
        width="6"
        height="6"
        patternUnits="userSpaceOnUse"
        patternTransform="rotate(18)"
      >
        <line x1="0" y1="0" x2="0" y2="6" class="donation-meter__bezel-brush-line"></line>
      </pattern>
    </defs>

    <rect x="6" y="6" width="588" height="388" rx="4" class="donation-meter__panel"></rect>
    <rect x="12" y="12" width="576" height="376" rx="3" class="donation-meter__bezel"></rect>
    <rect x="12" y="12" width="576" height="376" rx="3" class="donation-meter__bezel-brush"></rect>
    <rect x="18" y="18" width="564" height="336" rx="2" class="donation-meter__face"></rect>
    <rect x="18" y="18" width="564" height="336" rx="2" class="donation-meter__face-texture"></rect>

    <path d={arcPath} class="donation-meter__arc"></path>
    <path d={dangerSectorPath} class="donation-meter__danger-zone"></path>

    {
      ticks.map((tick) => (
        <line
          x1={tick.x1}
          y1={tick.y1}
          x2={tick.x2}
          y2={tick.y2}
          class:list={[
            "donation-meter__tick",
            tick.isMajor && "donation-meter__tick--major",
            tick.isDanger && "donation-meter__tick--danger",
          ]}
        />
      ))
    }

    {
      scaleLabels.map((label) => (
        <text
          x={label.x}
          y={label.y}
          class="donation-meter__scale-label"
          text-anchor={label.anchor}
          dominant-baseline="middle"
        >
          {label.value.toLocaleString("en-US")}
        </text>
      ))
    }

    <text
      id="donation-meter-title"
      x={CENTER_X}
      y="304"
      class="donation-meter__dial-title"
      text-anchor="middle">D.C.DONATIONERES</text
    >
    <text x={CENTER_X} y="328" class="donation-meter__dial-range" text-anchor="middle">
      <tspan data-meter-raised class="donation-meter__dial-value donation-meter__dial-value--raised"
        >$0</tspan
      >
      <tspan> OF </tspan>
      <tspan data-meter-goal class="donation-meter__dial-value donation-meter__dial-value--goal"
        >$25,000</tspan
      >
      <tspan> GOAL</tspan>
    </text>

    <text x="32" y="345" class="donation-meter__serial" text-anchor="start">501-C3</text>

    <rect x="12" y="354" width="576" height="34" rx="3" class="donation-meter__bottom-rail"></rect>

    <text x={CENTER_X} y="371" class="donation-meter__giveback-readout" text-anchor="middle">
      GIVEBACK <tspan data-meter-giveback-raised class="donation-meter__dial-value donation-meter__dial-value--giveback">$—</tspan>
    </text>

    <g data-meter-needle-giveback transform={`rotate(${ARC_START_DEG} ${CENTER_X} ${CENTER_Y})`}>
      <path
        d="M 299.1 248 L 300.9 248 L 301.5 66 L 300 46 L 298.5 66 Z"
        class="donation-meter__needle--giveback"></path>
      <path
        d="M 299.4 248 L 300.6 248 L 300.4 266 L 299.6 266 Z"
        class="donation-meter__needle-tail--giveback"></path>
    </g>

    <g data-meter-needle transform={`rotate(${ARC_START_DEG} ${CENTER_X} ${CENTER_Y})`}>
      <path
        d="M 299.1 248 L 300.9 248 L 301.5 66 L 300 46 L 298.5 66 Z"
        class="donation-meter__needle"></path>
      <path
        d="M 299.4 248 L 300.6 248 L 300.4 266 L 299.6 266 Z"
        class="donation-meter__needle-tail"></path>
    </g>

    <circle cx={CENTER_X} cy={CENTER_Y} r="9" class="donation-meter__pivot-core"></circle>
    <circle cx="298.5" cy="244.6" r="1.7" class="donation-meter__pivot-highlight"></circle>
  </svg>
</div>

<script>
  import { getWishData, isWishRequestTimeoutError } from "../utils/wishData";
  import { getGivebackData, isGivebackRequestTimeoutError } from "../utils/givebackData";

  const ARC_START_DEG = -90;
  const ARC_END_DEG = 90;
  const SCALE_MAX = 25000;
  const FALLBACK_GOAL = 25000;
  const CACHE_KEY = "gbva:donation-meter-cache-v2";
  const PIVOT_X = 300;
  const PIVOT_Y = 248;
  const STARTUP_DURATION_MS = 5000;
  const GIVEBACK_NEEDLE_DURATION_MS = 2500;

  const motionTokens = new WeakMap<SVGGElement, number>();
  const overloadTimers = new WeakMap<SVGGElement, number>();
  const statusTextCache = new WeakMap<HTMLElement, string>();

  const currencyFormatter = new Intl.NumberFormat("en-US", {
    style: "currency",
    currency: "USD",
    maximumFractionDigits: 0,
  });

  function clamp(value: number, min: number, max: number): number {
    return Math.min(max, Math.max(min, value));
  }

  function hasReducedMotion(): boolean {
    const root = document.documentElement;
    return (
      root.classList.contains("reduce-motion") ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    );
  }

  function lerp(start: number, end: number, progress: number): number {
    return start + (end - start) * progress;
  }

  function toNeedleAngle(ratio: number): number {
    return ARC_START_DEG + clamp(ratio, 0, 1) * (ARC_END_DEG - ARC_START_DEG);
  }

  function setNeedle(needle: SVGGElement, ratio: number): void {
    const angle = toNeedleAngle(ratio);
    needle.setAttribute("transform", `rotate(${angle} ${PIVOT_X} ${PIVOT_Y})`);
  }

  function setNeedleAngle(needle: SVGGElement, angle: number): void {
    needle.setAttribute("transform", `rotate(${angle} ${PIVOT_X} ${PIVOT_Y})`);
  }

  function bumpMotionToken(needle: SVGGElement): number {
    const currentToken = motionTokens.get(needle) ?? 0;
    const nextToken = currentToken + 1;
    motionTokens.set(needle, nextToken);
    return nextToken;
  }

  function isCurrentToken(needle: SVGGElement, token: number): boolean {
    return (motionTokens.get(needle) ?? 0) === token;
  }

  function stopOverloadTeeter(needle: SVGGElement): void {
    const timer = overloadTimers.get(needle);

    if (timer === undefined) {
      return;
    }

    window.clearInterval(timer);
    overloadTimers.delete(needle);
  }

  function easeOutCubic(progress: number): number {
    const clamped = clamp(progress, 0, 1);
    return 1 - (1 - clamped) ** 3;
  }

  function easeOutQuint(progress: number): number {
    const clamped = clamp(progress, 0, 1);
    return 1 - (1 - clamped) ** 5;
  }

  function easeInOutSine(progress: number): number {
    const clamped = clamp(progress, 0, 1);
    return -(Math.cos(Math.PI * clamped) - 1) / 2;
  }

  function setCurrencyText(node: Element, amount: number): void {
    node.textContent = currencyFormatter.format(Math.max(0, Math.round(amount)));
  }

  type MeterRgb = {
    r: number;
    g: number;
    b: number;
  };

  type MeterRaisedPalette = {
    low: MeterRgb;
    mid: MeterRgb;
    high: MeterRgb;
  };

  function parseHexColor(colorValue: string): MeterRgb | null {
    const normalized = colorValue.trim();

    if (!normalized.startsWith("#")) {
      return null;
    }

    if (normalized.length === 4) {
      const r = Number.parseInt(normalized[1] + normalized[1], 16);
      const g = Number.parseInt(normalized[2] + normalized[2], 16);
      const b = Number.parseInt(normalized[3] + normalized[3], 16);
      return { r, g, b };
    }

    if (normalized.length === 7) {
      const r = Number.parseInt(normalized.slice(1, 3), 16);
      const g = Number.parseInt(normalized.slice(3, 5), 16);
      const b = Number.parseInt(normalized.slice(5, 7), 16);
      return { r, g, b };
    }

    return null;
  }

  function parseRgbColor(colorValue: string): MeterRgb | null {
    const match = colorValue.trim().match(/^rgba?\((\d{1,3})\s*,\s*(\d{1,3})\s*,\s*(\d{1,3})/i);

    if (!match) {
      return null;
    }

    return {
      r: clamp(Number.parseInt(match[1], 10), 0, 255),
      g: clamp(Number.parseInt(match[2], 10), 0, 255),
      b: clamp(Number.parseInt(match[3], 10), 0, 255),
    };
  }

  function parseColor(colorValue: string): MeterRgb | null {
    return parseHexColor(colorValue) ?? parseRgbColor(colorValue);
  }

  function resolveTokenColor(tokenName: string, fallback: string): MeterRgb {
    const computed = getComputedStyle(document.documentElement).getPropertyValue(tokenName).trim();
    const resolved = parseColor(computed) ?? parseColor(fallback);

    if (resolved) {
      return resolved;
    }

    return { r: 0, g: 0, b: 0 };
  }

  function getRaisedPalette(): MeterRaisedPalette {
    return {
      low: resolveTokenColor("--color-meter-readout-raised-low", "#bf2218"),
      mid: resolveTokenColor("--color-meter-readout-raised-mid", "#c4950a"),
      high: resolveTokenColor("--color-meter-readout-raised-high", "#1e8040"),
    };
  }

  function rgbToCss(color: MeterRgb): string {
    return `rgb(${Math.round(color.r)} ${Math.round(color.g)} ${Math.round(color.b)})`;
  }

  function setRaisedFill(
    root: HTMLElement,
    amount: number,
    goal: number,
    palette: MeterRaisedPalette,
  ): void {
    const ratio = goal > 0 ? clamp(amount / goal, 0, 1) : 0;

    let color: MeterRgb;

    if (ratio <= 0.5) {
      const t = ratio * 2;
      color = {
        r: lerp(palette.low.r, palette.mid.r, t),
        g: lerp(palette.low.g, palette.mid.g, t),
        b: lerp(palette.low.b, palette.mid.b, t),
      };
    } else {
      const t = (ratio - 0.5) * 2;
      color = {
        r: lerp(palette.mid.r, palette.high.r, t),
        g: lerp(palette.mid.g, palette.high.g, t),
        b: lerp(palette.mid.b, palette.high.b, t),
      };
    }

    root.style.setProperty("--meter-raised-readout", rgbToCss(color));
  }

  function setLiveStatus(statusNode: HTMLElement, raisedAmount: number, goalAmount: number): void {
    const normalizedRaised = Math.max(0, Math.round(raisedAmount));
    const normalizedGoal = Math.max(0, Math.round(goalAmount));
    const nextStatus =
      normalizedGoal > 0
        ? `Raised ${currencyFormatter.format(normalizedRaised)} of ${currencyFormatter.format(normalizedGoal)} goal.`
        : `Raised ${currencyFormatter.format(normalizedRaised)}. Goal unavailable.`;

    if (statusTextCache.get(statusNode) === nextStatus) {
      return;
    }

    statusTextCache.set(statusNode, nextStatus);
    statusNode.textContent = nextStatus;
  }

  function updateReadout(
    root: HTMLElement,
    raisedEl: Element,
    goalEl: Element,
    statusNode: HTMLElement,
    raisedAmount: number,
    goalAmount: number,
    palette: MeterRaisedPalette,
  ): void {
    setCurrencyText(raisedEl, raisedAmount);
    setRaisedFill(root, raisedAmount, goalAmount, palette);
    setCurrencyText(goalEl, goalAmount);
    setLiveStatus(statusNode, raisedAmount, goalAmount);
  }

  function getProgressRatio(raised: number, goal: number): number {
    if (goal > 0) {
      return clamp(raised / goal, 0, 1);
    }

    return clamp(raised / SCALE_MAX, 0, 1);
  }

  function getMechanicalAngle(progress: number, startAngle: number, targetAngle: number): number {
    const dipAngle = startAngle - 8.5;
    const overshootAngle = clamp(targetAngle + 4.3, ARC_START_DEG - 10, ARC_END_DEG + 3.5);
    const recoilAngle = targetAngle - 1.9;

    if (progress <= 0.12) {
      const phase = clamp(progress / 0.12, 0, 1);
      return lerp(startAngle, dipAngle, easeInOutSine(phase));
    }

    if (progress <= 0.68) {
      const phase = clamp((progress - 0.12) / 0.56, 0, 1);
      return lerp(dipAngle, overshootAngle, easeOutCubic(phase));
    }

    if (progress <= 0.82) {
      const phase = clamp((progress - 0.68) / 0.14, 0, 1);
      return lerp(overshootAngle, recoilAngle, easeInOutSine(phase));
    }

    const phase = clamp((progress - 0.82) / 0.18, 0, 1);
    return lerp(recoilAngle, targetAngle, easeOutQuint(phase));
  }

  function startOverloadTeeter(needle: SVGGElement, baseAngle: number, token: number): void {
    stopOverloadTeeter(needle);

    let phase = 0;
    const timer = window.setInterval(() => {
      if (!isCurrentToken(needle, token)) {
        stopOverloadTeeter(needle);
        return;
      }

      phase += 0.72;
      const wobble = Math.sin(phase * 1.13) * 0.58 + Math.sin(phase * 0.47) * 0.26;
      setNeedleAngle(needle, baseAngle + wobble);
    }, 60);

    overloadTimers.set(needle, timer);
  }

  async function animateNeedleAndAmount(
    root: HTMLElement,
    needle: SVGGElement,
    raisedEl: Element,
    goalEl: Element,
    statusNode: HTMLElement,
    palette: MeterRaisedPalette,
    fromRatio: number,
    ratio: number,
    fromAmount: number,
    toAmount: number,
    fromGoal: number,
    toGoal: number,
    durationMs: number,
    mechanical: boolean,
    overload: boolean,
  ): Promise<void> {
    const targetRatio = clamp(ratio, 0, 1);
    const startRatio = clamp(fromRatio, 0, 1);
    const startAmount = Math.max(0, fromAmount);
    const endAmount = Math.max(0, toAmount);
    const startGoal = Math.max(0, fromGoal);
    const endGoal = Math.max(0, toGoal);
    const startAngle = toNeedleAngle(startRatio);
    const targetAngle = toNeedleAngle(targetRatio);
    const token = bumpMotionToken(needle);

    stopOverloadTeeter(needle);

    if (hasReducedMotion()) {
      setNeedle(needle, targetRatio);
      updateReadout(root, raisedEl, goalEl, statusNode, endAmount, endGoal, palette);
      return;
    }

    await new Promise<void>((resolve) => {
      const start = performance.now();
      const frameDuration = Math.max(220, durationMs);

      const frame = (now: number) => {
        if (!isCurrentToken(needle, token)) {
          resolve();
          return;
        }

        const progress = clamp((now - start) / frameDuration, 0, 1);
        const amountProgress = easeOutQuint(progress);
        const amountValue = lerp(startAmount, endAmount, amountProgress);
        const goalValue = lerp(startGoal, endGoal, amountProgress);
        updateReadout(root, raisedEl, goalEl, statusNode, amountValue, goalValue, palette);

        const angle = mechanical
          ? getMechanicalAngle(progress, startAngle, targetAngle)
          : lerp(startAngle, targetAngle, easeInOutSine(progress));

        setNeedleAngle(needle, angle);

        if (progress < 1) {
          window.requestAnimationFrame(frame);
          return;
        }

        resolve();
      };

      window.requestAnimationFrame(frame);
    });

    if (!isCurrentToken(needle, token)) {
      return;
    }

    setNeedleAngle(needle, targetAngle);
    updateReadout(root, raisedEl, goalEl, statusNode, endAmount, endGoal, palette);

    if (overload) {
      startOverloadTeeter(needle, targetAngle, token);
    }
  }

  async function animateNeedlePosition(
    needle: SVGGElement,
    fromRatio: number,
    toRatio: number,
    durationMs: number,
    mechanical: boolean,
  ): Promise<void> {
    const targetRatio = clamp(toRatio, 0, 1);
    const startRatio = clamp(fromRatio, 0, 1);
    const startAngle = toNeedleAngle(startRatio);
    const targetAngle = toNeedleAngle(targetRatio);
    const token = bumpMotionToken(needle);

    stopOverloadTeeter(needle);

    if (hasReducedMotion()) {
      setNeedle(needle, targetRatio);
      return;
    }

    await new Promise<void>((resolve) => {
      const start = performance.now();
      const frameDuration = Math.max(220, durationMs);

      const frame = (now: number) => {
        if (!isCurrentToken(needle, token)) {
          resolve();
          return;
        }

        const progress = clamp((now - start) / frameDuration, 0, 1);
        const angle = mechanical
          ? getMechanicalAngle(progress, startAngle, targetAngle)
          : lerp(startAngle, targetAngle, easeInOutSine(progress));

        setNeedleAngle(needle, angle);

        if (progress < 1) {
          window.requestAnimationFrame(frame);
          return;
        }

        resolve();
      };

      window.requestAnimationFrame(frame);
    });

    if (!isCurrentToken(needle, token)) {
      return;
    }

    setNeedleAngle(needle, targetAngle);
  }

  type MeterCache = {
    raised: number;
    goal: number;
    updatedAt: number;
  };

  function readCachedMeter(): MeterCache | null {
    try {
      const raw = window.localStorage.getItem(CACHE_KEY);
      if (!raw) {
        return null;
      }

      const parsed = JSON.parse(raw) as Partial<MeterCache>;
      const raised = Number(parsed.raised);
      const goal = Number(parsed.goal);
      const updatedAt = Number(parsed.updatedAt);

      if (!Number.isFinite(raised) || !Number.isFinite(goal) || !Number.isFinite(updatedAt)) {
        return null;
      }

      return {
        raised: Math.max(0, raised),
        goal: Math.max(0, goal),
        updatedAt,
      };
    } catch {
      return null;
    }
  }

  function writeCachedMeter(raised: number, goal: number): void {
    try {
      const payload: MeterCache = {
        raised: Math.max(0, raised),
        goal: Math.max(0, goal),
        updatedAt: Date.now(),
      };
      window.localStorage.setItem(CACHE_KEY, JSON.stringify(payload));
    } catch {
      /* localStorage unavailable or blocked */
    }
  }

  function startIdleMotion(
    root: HTMLElement,
    needle: SVGGElement,
    raisedEl: Element,
    goalEl: Element,
    statusNode: HTMLElement,
    palette: MeterRaisedPalette,
  ): () => {
    ratio: number;
    amount: number;
  } {
    const start = performance.now();
    let latestAmount = 0;
    let latestRatio = 0.06;

    const timer = window.setInterval(() => {
      const elapsed = performance.now() - start;
      const progress = clamp(elapsed / 1200, 0, 1);
      const eased = easeOutCubic(progress);
      latestAmount = 2200 * eased;
      latestRatio = 0.06 + Math.sin(elapsed / 230) * 0.0035;

      updateReadout(root, raisedEl, goalEl, statusNode, latestAmount, FALLBACK_GOAL, palette);
      setNeedle(needle, latestRatio);
    }, 60);

    return () => {
      window.clearInterval(timer);
      return {
        ratio: latestRatio,
        amount: latestAmount,
      };
    };
  }

  async function hydrateMeter(root: HTMLElement): Promise<void> {
    const needle = root.querySelector<SVGGElement>("[data-meter-needle]");
    const givebackNeedle = root.querySelector<SVGGElement>("[data-meter-needle-giveback]");
    const raisedNode = root.querySelector<SVGTSpanElement>("[data-meter-raised]");
    const goalNode = root.querySelector<SVGTSpanElement>("[data-meter-goal]");
    const givebackRaisedNode = root.querySelector<Element>("[data-meter-giveback-raised]");
    const statusNode = root.querySelector<HTMLElement>("[data-meter-status]");

    if (!needle || !raisedNode || !goalNode || !statusNode) {
      return;
    }

    const palette = getRaisedPalette();
    setNeedle(needle, 0);
    if (givebackNeedle) setNeedle(givebackNeedle, 0);
    root.dataset.state = "loading";
    updateReadout(root, raisedNode, goalNode, statusNode, 0, FALLBACK_GOAL, palette);
    statusNode.textContent = "Donation meter loading latest totals.";

    const cached = readCachedMeter();

    // Start giveback fetch in parallel with wish fetch
    const givebackDataPromise = getGivebackData();

    // Animate the giveback needle independently — it has its own goal and
    // does not need to wait for wish data to resolve.
    if (givebackNeedle) {
      (async () => {
        try {
          const { raised: givebackRaised, goal: givebackGoal } = await givebackDataPromise;
          const givebackRatio = getProgressRatio(givebackRaised, givebackGoal);
          if (givebackRaisedNode) setCurrencyText(givebackRaisedNode, givebackRaised);
          await animateNeedlePosition(
            givebackNeedle,
            0,
            givebackRatio,
            GIVEBACK_NEEDLE_DURATION_MS,
            true,
          );
        } catch (givebackError) {
          if (isGivebackRequestTimeoutError(givebackError)) {
            console.warn("Giveback donation meter request timed out.", givebackError);
          } else {
            console.warn("Giveback donation meter failed to load.", givebackError);
          }
          if (givebackRaisedNode) givebackRaisedNode.textContent = "—";
        }
      })();
    }

    try {
      let currentAmount = 0;
      let currentGoal = FALLBACK_GOAL;
      let currentRatio = 0;

      const wishDataPromise = getWishData();

      if (cached && cached.goal > 0) {
        currentAmount = cached.raised;
        currentGoal = cached.goal;
        currentRatio = getProgressRatio(cached.raised, cached.goal);

        await animateNeedleAndAmount(
          root,
          needle,
          raisedNode,
          goalNode,
          statusNode,
          palette,
          0,
          currentRatio,
          0,
          currentAmount,
          FALLBACK_GOAL,
          currentGoal,
          1350,
          true,
          false,
        );
      }

      let stopIdle: (() => { ratio: number; amount: number }) | null = null;
      if (!cached && !hasReducedMotion()) {
        stopIdle = startIdleMotion(root, needle, raisedNode, goalNode, statusNode, palette);
      }

      const { raised: raisedAmount, goal: goalAmount } = await wishDataPromise;

      if (stopIdle) {
        const idleSnapshot = stopIdle();
        currentAmount = idleSnapshot.amount;
        currentRatio = idleSnapshot.ratio;
      }

      const normalizedGoal = goalAmount > 0 ? goalAmount : currentGoal;
      const ratio = getProgressRatio(raisedAmount, normalizedGoal);
      const goalReached = normalizedGoal > 0 && raisedAmount >= normalizedGoal;
      const isOverload = goalReached;
      const ratioDelta = Math.abs(ratio - currentRatio);
      const duration =
        cached || ratioDelta > 0.07 ? STARTUP_DURATION_MS : Math.round(1800 + ratioDelta * 3000);

      await animateNeedleAndAmount(
        root,
        needle,
        raisedNode,
        goalNode,
        statusNode,
        palette,
        currentRatio,
        ratio,
        currentAmount,
        raisedAmount,
        currentGoal,
        normalizedGoal,
        duration,
        true,
        isOverload,
      );

      writeCachedMeter(raisedAmount, normalizedGoal);
      root.dataset.state = normalizedGoal > 0 ? (isOverload ? "goal" : "ready") : "fallback";
    } catch (error) {
      bumpMotionToken(needle);
      stopOverloadTeeter(needle);

      if (isWishRequestTimeoutError(error)) {
        if (cached && cached.goal > 0) {
          setNeedle(needle, getProgressRatio(cached.raised, cached.goal));
          updateReadout(
            root,
            raisedNode,
            goalNode,
            statusNode,
            cached.raised,
            cached.goal,
            palette,
          );
        } else {
          setNeedle(needle, 0);
          updateReadout(root, raisedNode, goalNode, statusNode, 0, FALLBACK_GOAL, palette);
        }

        root.dataset.state = "fallback";
        statusNode.textContent = "Donation meter request timed out. Showing fallback values.";
        console.warn("Wish donation meter request timed out.", error);
        return;
      }

      setNeedle(needle, 0);
      updateReadout(root, raisedNode, goalNode, statusNode, 0, 0, palette);
      root.dataset.state = "error";
      statusNode.textContent = "Donation meter unavailable right now.";
      console.error("Wish donation meter failed to load.", error);
    }
  }

  const meterRoots = document.querySelectorAll<HTMLElement>("[data-donation-meter]");

  meterRoots.forEach((root) => {
    hydrateMeter(root);
  });
</script>

