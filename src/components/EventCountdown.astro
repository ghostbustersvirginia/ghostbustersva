---
/**
 * EventCountdown — live countdown timer for multi-day events.
 * Counts down to event start, shows "Event In Progress" during,
 * and then switches to an informational completed state.
 */
import { getResponsiveImageAttrs } from "../lib/images";

interface Props {
  startDate: Date;
  endDate: Date;
}

const { startDate, endDate } = Astro.props;
const countdownOozeImage = await getResponsiveImageAttrs({
  src: "/images/slime.png",
  widths: [136],
  sizes: "68px",
  width: 136,
  height: 91,
  quality: 80,
});
// "End" means the end of the last day → midnight of the next day
const endTimestamp = new Date(endDate.getTime() + 86400000).toISOString();
---

<div
  class="event-countdown"
  data-countdown-start={startDate.toISOString()}
  data-countdown-end={endTimestamp}
  data-countdown-ooze-src={countdownOozeImage.src}
>
  <div class="countdown-timer">
    <div class="countdown-segment">
      <span class="countdown-value" data-unit="days">--</span>
      <span class="countdown-label">Days</span>
    </div>
    <span class="countdown-separator">:</span>
    <div class="countdown-segment">
      <span class="countdown-value" data-unit="hours">--</span>
      <span class="countdown-label">Hours</span>
    </div>
    <span class="countdown-separator">:</span>
    <div class="countdown-segment">
      <span class="countdown-value" data-unit="mins">--</span>
      <span class="countdown-label">Mins</span>
    </div>
    <span class="countdown-separator">:</span>
    <div class="countdown-segment">
      <span class="countdown-value" data-unit="secs">--</span>
      <span class="countdown-label">Secs</span>
    </div>
  </div>
</div>

<script>
  function initEventCountdowns() {
    // Start live countdown timers
    document.querySelectorAll<HTMLElement>(".event-countdown").forEach((el) => {
      const startStr = el.getAttribute("data-countdown-start");
      const endStr = el.getAttribute("data-countdown-end");
      const countdownOozeImageSrc = el.getAttribute("data-countdown-ooze-src") || "";
      if (!startStr || !endStr) return;

      const start = new Date(startStr);
      const end = new Date(endStr);

      function tick() {
        const now = new Date();

        // Event has ended
        if (now >= end) {
          const timer = el.querySelector(".countdown-timer");
          if (timer && !timer.classList.contains("is-complete")) {
            timer.innerHTML = '<span class="countdown-complete">Event Completed</span>';
            timer.classList.add("is-complete");
          }
          return;
        }

        // Event is in progress
        if (now >= start) {
          const timer = el.querySelector(".countdown-timer");
          if (timer && !timer.classList.contains("is-live")) {
            timer.innerHTML = '<span class="countdown-status">Happening Now!</span>';
            timer.classList.add("is-live");
            // Bubble live state to parent event card for accent styling
            const card = el.closest(".event-item");
            if (card) {
              card.classList.add("event-item--live");
              // Inject slime accent into the countdown timer box
              if (!timer.querySelector(".card-ooze")) {
                const img = document.createElement("img");
                img.src = countdownOozeImageSrc;
                img.alt = "";
                img.setAttribute("aria-hidden", "true");
                img.className = "card-ooze";
                timer.appendChild(img);
              }
            }
          }
          setTimeout(tick, 60_000);
          return;
        }

        // Countdown to start
        const diff = start.getTime() - now.getTime();
        const days = Math.floor(diff / 86_400_000);
        const hours = Math.floor((diff % 86_400_000) / 3_600_000);
        const mins = Math.floor((diff % 3_600_000) / 60_000);
        const secs = Math.floor((diff % 60_000) / 1_000);

        const d = el.querySelector('[data-unit="days"]');
        const h = el.querySelector('[data-unit="hours"]');
        const m = el.querySelector('[data-unit="mins"]');
        const s = el.querySelector('[data-unit="secs"]');

        if (d) d.textContent = String(days).padStart(2, "0");
        if (h) h.textContent = String(hours).padStart(2, "0");
        if (m) m.textContent = String(mins).padStart(2, "0");
        if (s) s.textContent = String(secs).padStart(2, "0");

        // Inject slime accent into the countdown timer box
        const timer = el.querySelector(".countdown-timer");
        if (timer && !timer.querySelector(".card-ooze")) {
          const img = document.createElement("img");
          img.src = countdownOozeImageSrc;
          img.alt = "";
          img.setAttribute("aria-hidden", "true");
          img.className = "card-ooze";
          timer.appendChild(img);
        }

        setTimeout(tick, 1_000);
      }

      tick();
    });
  }

  // Astro scripts are deferred modules — DOM is ready
  initEventCountdowns();
</script>

<style>
  .event-countdown {
    margin-top: var(--space-sm);
    margin-inline: auto;
    padding: var(--space-sm) var(--space-md);
    text-align: center;
    width: fit-content;
  }

  /* Live state — soft green-tint band */
  :global(.event-item--live) .event-countdown {
    position: relative;
    overflow: visible;
    width: calc(100% + (var(--space-xl) * 2));
    margin-left: calc(var(--space-xl) * -1);
    margin-top: var(--space-md);
    padding: var(--space-md) var(--space-xl);
    background: rgba(61, 134, 61, 0.07);
    border-top: 1px solid rgba(61, 134, 61, 0.2);
    border-bottom: 1px solid rgba(61, 134, 61, 0.2);
  }

  @media (max-width: 768px) {
    :global(.event-item--live) .event-countdown {
      width: calc(100% + (var(--space-lg) * 2));
      margin-left: calc(var(--space-lg) * -1);
      padding: var(--space-md) var(--space-lg);
    }
  }

  .countdown-timer {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-xs);
    position: relative;
    background: var(--color-surface, #ffffff);
    border: 1px solid var(--color-border, #d1d5db);
    border-radius: var(--radius-md, 0.5rem);
    border-bottom-right-radius: 0;
    padding: var(--space-lg) var(--space-2xl);
    box-shadow: var(--shadow-panel, 0 1px 3px rgba(8, 9, 9, 0.06));
    width: fit-content;
    margin-inline: auto;
    overflow: visible;
    overflow: visible;
  }

  .countdown-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 2.5rem;
  }

  .countdown-value {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 600;
    color: var(--color-text);
    line-height: 1;
  }

  .countdown-separator {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    color: var(--color-text-muted);
    line-height: 1;
  }

  .countdown-label {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: var(--tracking-wider);
    margin-top: 0.2rem;
    font-weight: 500;
  }
</style>

<!-- Global styles for dynamically injected elements (innerHTML in <script>) -->
<style is:global>
  .countdown-status {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-brand-title, "Elan Bold", "Graduate", sans-serif);
    font-size: var(--text-xl, 1.25rem);
    font-weight: var(--weight-bold, 700);
    color: var(--color-gb-green, #3d863d);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide, 0.025em);
    padding: 0;
    line-height: 1.2;
  }

  .card-ooze {
    position: absolute;
    bottom: 0;
    right: -3.5px;
    width: 68px;
    height: auto;
    pointer-events: none;
    z-index: 2;
    transform: translateY(100%);
    opacity: 0.75;
  }

  .countdown-complete {
    font-family: var(--font-body, sans-serif);
    font-size: var(--text-sm, 0.875rem);
    font-weight: var(--weight-medium, 500);
    color: var(--color-text-muted, #4a4f54);
  }
</style>
