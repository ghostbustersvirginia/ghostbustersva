---
import EventCountdown from "./EventCountdown.astro";
import { formatEventDate, type EventEntry } from "../lib/events";
import type { ResponsiveImageAttrs } from "../lib/images";

interface Props {
  event: EventEntry;
  showCountdown: boolean;
  hasImage: boolean;
  eventImage: ResponsiveImageAttrs | null;
}

const { event, showCountdown, hasImage, eventImage } = Astro.props;
---

{
  hasImage && (
    <div class="event-link__image-wrapper">
      <img
        src={eventImage!.src}
        srcset={eventImage!.srcset}
        sizes={eventImage!.sizes}
        alt={`Photo for ${event.data.title}`}
        loading="lazy"
        decoding="async"
        width={eventImage!.width}
        height={eventImage!.height}
        class="event-link__image"
      />
    </div>
  )
}
<div class="event-link__body">
  <div class="event-link__title-row">
    <span class="event-link__title">{event.data.title}</span>
    {
      showCountdown && (
        <span class="event-link__date-chip">
          {formatEventDate(event.data.date, event.data.endDate)}
        </span>
      )
    }
  </div>
  <p class="event-link__summary">{event.data.summary}</p>
  {
    showCountdown && (
      <EventCountdown startDate={event.data.date} endDate={event.data.endDate ?? event.data.date} />
    )
  }
  <div class="event-link__footer">
    <time class="event-link__date" datetime={event.data.date.toISOString().split("T")[0]}>
      {formatEventDate(event.data.date, event.data.endDate)}
    </time>
    {event.data.location && <span class="event-link__venue">{event.data.location}</span>}
    {
      event.data.address && (
        <span class="event-link__address">
          <svg
            class="event-link__footer-icon"
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          <span>{event.data.address}</span>
        </span>
      )
    }
  </div>
</div>

<style>
  .event-link__image-wrapper {
    flex-shrink: 0;
    width: 200px;
    overflow: hidden;
    border-radius: var(--radius-sm);
  }

  .event-link__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    background: var(--color-surface);
    display: block;
  }

  .event-link__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .event-link__title-row {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .event-link__title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: inherit;
    line-height: var(--leading-tight);
    transition: color var(--transition-base);
  }

  .event-link__date-chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-xs) var(--space-md);
    background: var(--color-accent);
    color: var(--color-text-inverse);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    border-radius: var(--radius-full);
    white-space: nowrap;
    line-height: 1.2;
  }

  /* Blue title on hover (desktop only) — disable on live cards */
  @media (min-width: 769px) {
    :global(.event-item:not(.event-item--live):hover) .event-link__title {
      color: var(--color-accent);
    }
  }

  .event-link__summary {
    font-size: var(--text-base);
    color: inherit;
    line-height: var(--leading-normal);
    margin: 0;
    transition: color var(--transition-base);
  }

  .event-link__footer {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: baseline;
    column-gap: 1rem;
    margin-top: var(--space-lg);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    transition: color var(--transition-base);
  }

  .event-link__date {
    grid-column: 1;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: inherit;
    font-weight: var(--weight-normal);
    letter-spacing: var(--tracking-wide);
    text-align: left;
  }

  .event-link__venue {
    grid-column: 2;
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: inherit;
  }

  .event-link__address {
    grid-column: 3;
    grid-row: 1;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    justify-content: flex-end;
    text-align: right;
    border-top: none;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-normal);
    color: inherit;
  }

  .event-link__footer-icon {
    flex-shrink: 0;
  }

  /* Footer stays muted on hover — no competing green */
  @media (min-width: 769px) {
    :global(.event-item:not(.event-item--live):hover) .event-link__footer {
      color: var(--color-text-muted);
    }
  }

  @media (max-width: 768px) {
    .event-link__image-wrapper {
      width: 100%;
      max-height: 200px;
    }

    .event-link__title {
      font-size: var(--text-xl);
    }

    .event-link__footer {
      display: flex;
      flex-direction: column;
      gap: var(--space-xs);
    }

    .event-link__date,
    .event-link__venue,
    .event-link__address {
      text-align: left;
      justify-content: flex-start;
    }
  }
</style>
