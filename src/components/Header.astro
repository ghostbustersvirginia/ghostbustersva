---
/**
 * Site header with responsive navigation.
 * Desktop (≥768px): full horizontal nav inline — executive decision, not hamburger
 *   (see brand-guide.md — hamburger-only was in PRD 015 but violates UX best practices
 *    for desktop screens where full navigation is the expected pattern).
 * Mobile (<768px): hamburger <details> menu — no JS required, fully accessible.
 * Reads logo, title, and nav items from site settings.
 */
import { getSiteSettings } from "../lib/settings";
import { getResponsiveImageAttrs } from "../lib/images";

const settings = await getSiteSettings();
const currentPath = Astro.url.pathname;

const normalizePath = (path: string) => {
  const trimmed = path.replace(/\/+$/, "");
  if (!trimmed || trimmed === "") return "/";
  return trimmed;
};

const isActivePage = (href: string) => {
  const current = normalizePath(currentPath);
  const target = normalizePath(href);

  if (target === "/") {
    return current === "/";
  }

  return current === target || current.startsWith(`${target}/`);
};

const navItems = settings.navItems;
const safeNavItems = navItems
  .map((link) => {
    const href = getSafeCmsHref(link.href);
    if (!href) return null;
    return { ...link, href };
  })
  .filter((link): link is NonNullable<typeof link> => Boolean(link));
const isMoreActive = moreDropdownItems.some((link) => isActivePage(link.href));
const navLogoImage = await getResponsiveImageAttrs({
  src: settings.navLogo,
  widths: [44, 88],
  sizes: "44px",
  width: 44,
  height: 44,
  quality: 82,
});
const navTitle = settings.navTitle?.trim() || "Ghostbusters";
const navSubtitle = settings.navSubtitle?.trim() || "Virginia";
const logoIndex = navTitle.toLowerCase().indexOf("o");
const titleBeforeLogo = logoIndex >= 0 ? navTitle.slice(0, logoIndex) : navTitle;
const titleAfterLogo = logoIndex >= 0 ? navTitle.slice(logoIndex + 1) : "";
const useLogoAsO = logoIndex >= 0;
---

<header class="site-header">
  <div class="header-trim"></div>
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label={`${settings.siteName} — home`}>
      <span class="logo-wordmark" aria-hidden="true">
        <span class="logo-wordmark-main">
          {titleBeforeLogo}
          {
            useLogoAsO && (
              <img
                src={navLogoImage.src}
                srcset={navLogoImage.srcset}
                sizes={navLogoImage.sizes}
                alt=""
                width={navLogoImage.width}
                height={navLogoImage.height}
                class="logo-o"
                loading="eager"
                decoding="async"
              />
            )
          }
          {titleAfterLogo}
          <span class="logo-wordmark-sub">{navSubtitle}</span>
        </span>
      </span>
    </a>

    {/* Desktop nav — full horizontal, visible on ≥768px */}
    <nav class="desktop-nav" aria-label="Main navigation">
      <ul>
        {
          safeNavItems.map((link) => (
            <li>
              <a
                href={link.href}
                class="desktop-nav__link"
                aria-current={isActivePage(link.href) ? "page" : undefined}
                {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              >
                {link.label}
                {link.external && <span class="sr-only"> (opens in new tab)</span>}
              </a>
            </li>
          ))
        }
        {
          moreDropdownItems.length > 0 && (
            <li class="desktop-nav__group">
              <button
                type="button"
                class:list={[
                  "desktop-nav__link",
                  "desktop-nav__more-button",
                  { "desktop-nav__more-button--active": isMoreActive },
                ]}
                aria-expanded="false"
                aria-controls="more-submenu-desktop"
                data-submenu-toggle="more-submenu-desktop"
              >
                More
                <svg
                  class="desktop-nav__caret"
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <ul
                id="more-submenu-desktop"
                class="desktop-nav__submenu"
                aria-label="More menu"
                hidden
              >
                {moreDropdownItems.map((subLink) => (
                  <li>
                    <a
                      href={subLink.href}
                      class="desktop-nav__submenu-link"
                      aria-current={isActivePage(subLink.href) ? "page" : undefined}
                      {...(subLink.external
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                    >
                      {subLink.label}
                      {subLink.external && <span class="sr-only"> (opens in new tab)</span>}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          )
        }
      </ul>
    </nav>

    {/* Mobile hamburger — visible on <768px only */}
    <details class="mobile-menu">
      <summary aria-label="Open navigation menu">
        <span class="hamburger" aria-hidden="true">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </summary>
      <nav class="mobile-nav-links" aria-label="Main navigation">
        <ul>
          {
            safeNavItems.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="mobile-nav__link"
                  aria-current={isActivePage(link.href) ? "page" : undefined}
                  {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                  {link.external && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </li>
            ))
          }
          {
            moreDropdownItems.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="mobile-nav__link"
                  aria-current={isActivePage(link.href) ? "page" : undefined}
                  {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                >
                  {link.label}
                  {link.external && <span class="sr-only"> (opens in new tab)</span>}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </details>
  </div>
  <div class="header-stripe" aria-hidden="true">
    <div class="caution-divider"></div>
  </div>
</header>

<style>
  .site-header {
    --trim-height: 10px;

    --font-logo-wordmark-ratio: 0.4;
    --font-logo-wordmark-size: 8dvw;

    background-color: var(--color-bg);
    position: sticky;
    top: 0;
    z-index: 100;
    margin: 0;
  }

  .header-stripe {
    line-height: 0;
  }

  //.header-trim {
  //  line-height: 0;
  //  height: var(--trim-height);
  //  background-color: color-mix(in oklab, var(--color-gb-red) 90%, black);
  //  border-width: 0 0 calc(var(--trim-height) * 0.3) 0;
  //  border-style: solid;
  //  border-color: var(--color-gb-chrome);
  //  margin-bottom: calc(var(--trim-height) * 0.3);
  //}

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-lg);
    gap: var(--space-xl);
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-text);
    position: relative;
    z-index: 2;
    flex-shrink: 0;
    transition: opacity var(--transition-fast);
  }

  .site-logo:hover {
    opacity: 0.85;
  }

  .logo-wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .logo-wordmark-main {
    font-family: var(--font-brand-title, var(--font-display)), sans-serif;
    font-weight: var(--weight-bold);
    font-size: calc(var(--font-logo-wordmark-size) * var(--font-logo-wordmark-ratio));
    letter-spacing: var(--tracking-heading);
    color: var(--color-text);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    gap: 0;
  }

  .logo-wordmark-sub {
    font-family: var(--font-brand-title, var(--font-display)), sans-serif;
    font-weight: var(--weight-bold);
    font-size: calc(var(--font-logo-wordmark-size) * var(--font-logo-wordmark-ratio) * 0.6);
    letter-spacing: calc(var(--font-logo-wordmark-size) * var(--font-logo-wordmark-ratio) * 0.16);
    color: var(--color-text-muted);
    line-height: 1;
    margin-left: 0.32ch;
  }

  .logo-o {
    width: 1.02em;
    height: 1.02em;
    object-fit: contain;
    margin-inline: 0;
    transform: translateY(0.03em);
    flex-shrink: 0;
    filter: var(--shadow-logo-default);
  }

  .desktop-nav {
    display: none;
  }

  .desktop-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .desktop-nav__link {
    display: block;
    text-decoration: none;
    font-family: var(--font-heading), sans-serif;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
    white-space: nowrap;
    color: var(--color-text-muted);
    padding: var(--space-xs) var(--space-md);
    border-bottom: 3px solid transparent;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .desktop-nav__link:hover,
  .desktop-nav__link:focus-visible {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .desktop-nav__link[aria-current="page"] {
    color: var(--color-accent);
    background-color: var(--color-accent);
  }

  /* More button - styled as nav link but with button reset */
  .desktop-nav__more-button {
    appearance: none;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin: 0;
    padding: var(--space-xs) var(--space-md);
    min-height: 2.25rem;
    line-height: 1;
    border-radius: var(--radius-sm);
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
    white-space: nowrap;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .desktop-nav__more-button:hover,
  .desktop-nav__more-button:focus-visible,
  .desktop-nav__more-button--active {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  .desktop-nav__more-button--active .desktop-nav__caret {
    color: var(--color-accent);
  }

  .desktop-nav__more-button[aria-expanded="true"] {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  .desktop-nav__more-button:hover .desktop-nav__caret,
  .desktop-nav__more-button:focus-visible .desktop-nav__caret {
    color: var(--color-accent);
  }

  .desktop-nav__caret {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .desktop-nav__more-button[aria-expanded="true"] .desktop-nav__caret {
    transform: rotate(180deg);
  }

  .desktop-nav__submenu {
    list-style: none;
    margin: 0;
    padding: 0;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 6.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-panel);
    display: flex;
    flex-direction: column;
    gap: 0;
    z-index: 250;
    overflow: hidden;
  }

  .desktop-nav__submenu[hidden] {
    display: none !important;
  }

  .desktop-nav__submenu li {
    width: 100%;
  }

  .desktop-nav__submenu-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    text-decoration: none;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
    text-align: center;
    white-space: nowrap;
    padding: var(--space-sm) var(--space-md);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .desktop-nav__submenu-link:first-child {
    padding-top: var(--space-sm);
  }

  .desktop-nav__submenu-link:last-child {
    padding-bottom: var(--space-sm);
  }

  .desktop-nav__submenu-link:hover,
  .desktop-nav__submenu-link:focus-visible {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  .desktop-nav__submenu-link[aria-current="page"] {
    color: var(--color-accent);
    font-weight: var(--weight-bold, 700);
    border-bottom-color: var(--color-accent);
  }

  .mobile-menu {
    position: relative;
    display: none;
  }

  .mobile-menu summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    transition: background var(--transition-fast);
  }

  .mobile-menu summary:hover {
    background: var(--color-action-secondary-hover);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    width: 22px;
  }

  .hamburger-line {
    display: block;
    height: 2px;
    width: 100%;
    background: var(--color-text);
    border-radius: 1px;
    transition: background var(--transition-fast);
  }

  .mobile-menu[open] .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(4px, 5px);
  }

  .mobile-menu[open] .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu[open] .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -5px);
  }

  .mobile-nav-links {
    position: absolute;
    right: 0;
    top: calc(100% + var(--space-sm));
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-md) var(--space-sm);
    min-width: 12rem;
    box-shadow: var(--shadow-panel);
    z-index: 200;
    overflow: visible;
  }

  .mobile-nav-links ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .mobile-nav__link {
    display: block;
    text-decoration: none;
    font-family: var(--font-heading), sans-serif;
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
    white-space: nowrap;
    color: var(--color-text-muted);
    padding: var(--space-sm) var(--space-lg);
    border-radius: var(--radius-sm);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .mobile-nav__link:hover,
  .mobile-nav__link:focus-visible {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  .mobile-nav__link[aria-current="page"] {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  /* More button styled as a nav link for mobile */
  .mobile-nav__more-button {
    background: transparent;
    border: none;
    border-bottom: 3px solid transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    text-align: left;
    margin: 0;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
  }

  .mobile-nav__more-button:hover,
  .mobile-nav__more-button:focus-visible,
  .mobile-nav__group[data-open="true"] .mobile-nav__more-button,
  .mobile-nav__more-button--active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }

  .mobile-nav__caret {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .mobile-nav__more-button[aria-expanded="true"] .mobile-nav__caret {
    transform: rotate(180deg);
  }

  .mobile-nav__submenu {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    overflow: hidden;
  }

  .mobile-nav__submenu[hidden] {
    display: none !important;
  }

  .mobile-nav__submenu li {
    width: 100%;
  }

  .mobile-nav__submenu-link {
    display: block;
    width: 100%;
    box-sizing: border-box;
    text-decoration: none;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
    text-transform: capitalize;
    color: var(--color-text-muted);
    padding: var(--space-sm) var(--space-lg);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast);
  }

  .mobile-nav__submenu-link:first-child {
    padding-top: var(--space-sm);
  }

  .mobile-nav__submenu-link:last-child {
    padding-bottom: var(--space-sm);
  }

  .mobile-nav__submenu-link:hover,
  .mobile-nav__submenu-link:focus-visible {
    color: var(--color-accent);
    background-color: var(--color-action-secondary-hover);
  }

  .mobile-nav__submenu-link[aria-current="page"] {
    color: var(--color-accent);
    font-weight: var(--weight-bold, 700);
  }

  .mobile-nav__link:focus-visible,
  .desktop-nav__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (min-width: 768px) {
    .desktop-nav {
      display: flex;
      flex: 1;
      justify-content: flex-end;
    }

    .mobile-menu {
      display: none;
    }
  }

  @media (max-width: 350px) {
    .site-header {
      --font-logo-wordmark-ratio: 1;
    }
    .desktop-nav {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .logo-wordmark-main {
    }

    .logo-wordmark-sub {
    }

    .logo-wordmark {
      gap: 0.08em;
    }
  }

  @media (min-width: 351px) and (max-width: 767px) {
    .site-header {
      --font-logo-wordmark-ratio: 1;
    }
    .desktop-nav {
      display: none;
    }

    .mobile-menu {
      display: block;
    }

    .logo-wordmark-main {
    }

    .logo-wordmark-sub {
    }

    .logo-wordmark {
      gap: 0.08em;
    }
  }

  @media (min-width: 768px) and (max-width: 1024px) {
    .logo-wordmark-main {
      font-size: 1.9rem;
    }
  }
</style>
