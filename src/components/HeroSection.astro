---
/**
 * HeroSection — Split-panel hero with solid background.
 * Static Astro component — no client-side JS needed.
 *
 * Layout: two-column on desktop (logo left, copy + CTAs right).
 * Stacked centered on mobile.
 * Light background keeps it clean, modern, and nonprofit-friendly.
 */
import "./HeroSection.css";
import Button from "./ui/Button.astro";
import type { ResponsiveImageAttrs } from "../lib/images";

interface Props {
  heroTitleText: string;
  heroTitleAccent: string;
  heroTagline: string;
  primaryCtaLabel: string;
  primaryCtaHref: string;
  heroLogoSrc: string;
  heroLogoAlt: string;
  heroLogoImage?: ResponsiveImageAttrs;
}

const {
  heroTitleText,
  heroTitleAccent,
  heroTagline,
  primaryCtaLabel,
  primaryCtaHref,
  heroLogoSrc,
  heroLogoAlt,
  heroLogoImage,
} = Astro.props;
---

<section class="hero" aria-labelledby="home-hero-title">
  <div class="hero-inner container">
    <!-- Left column: logo -->
    <div class="hero-logo-col">
      <div class="hero-logo-glow" aria-hidden="true"></div>
      <img
        src={heroLogoImage?.src ?? heroLogoSrc}
        srcset={heroLogoImage?.srcset}
        sizes={heroLogoImage?.sizes}
        alt={heroLogoAlt}
        width={heroLogoImage?.width ?? 360}
        height={heroLogoImage?.height ?? 360}
        class="hero-logo"
        fetchpriority="high"
        decoding="async"
      />
    </div>

    <!-- Right column: copy + CTAs -->
    <div class="hero-content">
      <h1 id="home-hero-title" class="hero-title">
        <span class="hero-title-main">{heroTitleText}</span>
        <span class="hero-title-accent" data-hero-accent>
          <span class="hero-title-accent-inner">{heroTitleAccent}</span>
        </span>
      </h1>

      <p class="hero-tagline">{heroTagline}</p>

      <div class="hero-cta">
        <Button
          variant="primary"
          class="btn--lg btn--donate-hero"
          href={primaryCtaHref}
          icon="heart"
        >
          {primaryCtaLabel}
        </Button>
      </div>
    </div>
  </div>
</section>

<script>
  const logo = document.querySelector(".hero-logo");
  logo?.addEventListener("animationend", () => logo.classList.add("entrance-done"), { once: true });

  const title = document.querySelector(".hero-title");
  const titleMain = title?.querySelector(".hero-title-main");
  const titleAccent = title?.querySelector("[data-hero-accent]");
  const titleAccentInner = title?.querySelector(".hero-title-accent-inner");

  const syncAccentWidth = () => {
    if (!(title instanceof HTMLElement)) return;
    if (!(titleMain instanceof HTMLElement)) return;
    if (!(titleAccentInner instanceof HTMLElement)) return;

    title.style.setProperty("--hero-accent-scale", "1");
    const mainWidth = titleMain.getBoundingClientRect().width;
    const accentWidth = titleAccentInner.getBoundingClientRect().width;
    if (accentWidth <= 0) return;

    const scale = mainWidth / accentWidth;
    title.style.setProperty("--hero-accent-scale", String(scale));
  };

  syncAccentWidth();
  window.addEventListener("load", syncAccentWidth, { once: true });
  document.fonts?.ready.then(syncAccentWidth);

  if (titleMain instanceof HTMLElement && titleAccent instanceof HTMLElement) {
    const resizeObserver = new ResizeObserver(() => syncAccentWidth());
    resizeObserver.observe(titleMain);
    resizeObserver.observe(titleAccent);
    if (titleAccentInner instanceof HTMLElement) resizeObserver.observe(titleAccentInner);
  }
</script>
