---
import Button from "../ui/Button.astro";
import LightboxImageTrigger from "../ui/LightboxImageTrigger.astro";
import OozeDecor from "../ui/OozeDecor.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import StyledDropdown from "../ui/StyledDropdown.astro";

interface DropdownOption {
  value: string;
  label: string;
}

interface ImageAttrs {
  src: string;
  srcset?: string;
  sizes?: string;
  width?: number;
  height?: number;
}

interface Props {
  bookingSectionHeading: string;
  bookingImage: ImageAttrs;
  bookingImageAlt: string;
  contactFormDescription: string;
  formspreeAction: string;
  inquiryOptions: DropdownOption[];
  eventInquiryAllowlistJson: string;
  contactFormSubmitLabel: string;
}

const {
  bookingSectionHeading,
  bookingImage,
  bookingImageAlt,
  contactFormDescription,
  formspreeAction,
  inquiryOptions,
  eventInquiryAllowlistJson,
  contactFormSubmitLabel,
} = Astro.props as Props;
---

<SectionHeading>{bookingSectionHeading}</SectionHeading>
<div class="booking-layout">
  <LightboxImageTrigger
    group="contact-gallery"
    src={bookingImage.src}
    alt={bookingImageAlt}
    buttonClass="page-image-lightbox"
    overlayClass="page-image-lightbox__overlay"
  >
    <img
      {...bookingImage}
      alt={bookingImageAlt}
      class="section-image section-image--booking"
      loading="lazy"
      decoding="async"
    />
  </LightboxImageTrigger>
  <div class="highlight-card contact-form-card">
    <p class="prose-text--centered contact-form-description">
      {contactFormDescription}
    </p>
    <form
      action={formspreeAction}
      method="POST"
      class="contact-form"
      data-event-inquiry-allowlist={eventInquiryAllowlistJson}
    >
      <label class="contact-form__field">
        <span>Name</span>
        <input type="text" name="name" autocomplete="name" required />
      </label>
      <label class="contact-form__field">
        <span>Telephone</span>
        <input type="tel" name="telephone" autocomplete="tel" required />
      </label>
      <label class="contact-form__field contact-form__field--full">
        <span>Email</span>
        <input type="email" name="email" autocomplete="email" required />
      </label>
      <div class="contact-form__field contact-form__field--full">
        <StyledDropdown
          id="inquiryType"
          name="inquiryType"
          label="Inquiry Type"
          required
          placeholder="Select an option"
          options={inquiryOptions}
        />
      </div>
      <label class="contact-form__field contact-form__field--full" data-event-field hidden>
        <span>Location</span>
        <input type="text" name="location" autocomplete="address-level2" data-event-input />
      </label>
      <label class="contact-form__field contact-form__field--full" data-event-field hidden>
        <span>Date</span>
        <div class="contact-form__date-input-wrap">
          <input
            type="text"
            name="eventDate"
            data-event-input
            data-date-input
            placeholder="mm/dd/yyyy"
            inputmode="numeric"
            autocomplete="off"
          />
          <button
            type="button"
            class="contact-form__date-clear"
            data-date-clear
            aria-label="Clear date"
            hidden
          >
            ×
          </button>
        </div>
      </label>
      <div class="sr-only contact-form__status" aria-live="polite" aria-atomic="true"></div>
      <label class="contact-form__field contact-form__field--full" data-event-field hidden>
        <span>End Date (Optional)</span>
        <div class="contact-form__date-input-wrap">
          <input
            type="text"
            name="eventEndDate"
            data-event-optional-input
            data-date-end-input
            placeholder="mm/dd/yyyy"
            inputmode="numeric"
            autocomplete="off"
          />
          <button
            type="button"
            class="contact-form__date-clear"
            data-date-clear
            aria-label="Clear end date"
            hidden
          >
            ×
          </button>
        </div>
      </label>
      <label class="contact-form__field contact-form__field--full">
        <span>Brief Description</span>
        <textarea name="briefDescription" rows="6" required></textarea>
      </label>
      <input
        type="text"
        name="_gotcha"
        tabindex="-1"
        autocomplete="off"
        class="contact-form__honeypot"
      />
      <div class="contact-form__actions">
        <Button type="submit" variant="primary">{contactFormSubmitLabel}</Button>
      </div>
    </form>
    <OozeDecor class="contact-form-ooze" />
  </div>
</div>

<style>
  .prose-text--centered {
    text-align: center;
    margin-top: 0;
    margin-bottom: 0;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-loose);
  }

  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-xl) var(--space-2xl);
    box-shadow: var(--shadow-panel);
  }

  .contact-form-card {
    position: relative;
    overflow: visible;
    border-bottom-right-radius: 0;
    margin-top: 0;
  }

  :global(.contact-form-ooze) {
    position: absolute;
    bottom: 0;
    right: -4px;
    width: 68px;
    height: auto;
    pointer-events: none;
    z-index: 2;
    transform: translate(0, 100%);
    opacity: 0.75;
  }

  .contact-form-description {
    margin-bottom: var(--space-sm);
  }

  .booking-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: var(--space-xl);
    align-items: start;
    margin-bottom: var(--space-xl);
  }

  .booking-layout .page-image-lightbox {
    width: 100%;
    max-width: 41rem;
    justify-self: end;
  }

  .section-image--booking {
    max-height: none;
    height: auto;
    object-fit: contain;
    margin-bottom: 0;
  }

  .contact-form {
    margin-top: var(--space-xl);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .contact-form__field {
    display: grid;
    gap: var(--space-xs);
  }

  .contact-form__field[hidden] {
    display: none !important;
  }

  .contact-form__field span {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
  }

  .contact-form__field input,
  .contact-form__field textarea,
  .contact-form__field select {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0.625rem 0.75rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  .contact-form__field select {
    appearance: none;
    -webkit-appearance: none;
    -moz-appearance: none;
    background-image:
      linear-gradient(45deg, transparent 50%, var(--color-text-muted) 50%),
      linear-gradient(135deg, var(--color-text-muted) 50%, transparent 50%);
    background-repeat: no-repeat;
    background-position:
      calc(100% - 1.05rem) 50%,
      calc(100% - 0.7rem) 50%;
    background-size: 0.38rem 0.38rem;
    padding-right: 2rem;
    padding: 0.75rem 0.875rem;
    cursor: pointer;
  }

  .contact-form__field select::-ms-expand {
    display: none;
  }

  .contact-form__field select option {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .contact-form__field select option:hover,
  .contact-form__field select option:focus {
    background: var(--color-gb-green);
    color: var(--color-surface);
  }

  .contact-form__field input:hover,
  .contact-form__field textarea:hover {
    border-color: var(--color-text-muted);
  }

  .contact-form__field input:focus-visible,
  .contact-form__field textarea:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
    border-color: var(--color-focus);
  }

  .contact-form__field select:hover {
    border-color: var(--color-text-muted);
  }

  .contact-form__field select:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
    border-color: var(--color-focus);
  }

  .contact-form__field--full {
    grid-column: 1 / -1;
  }

  .contact-form__date-input-wrap {
    position: relative;
  }

  .contact-form__date-input-wrap input {
    padding-right: 2.2rem;
  }

  .contact-form__date-clear {
    position: absolute;
    top: 50%;
    right: 0.55rem;
    transform: translateY(-50%);
    width: 1.3rem;
    height: 1.3rem;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-text-muted);
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .contact-form__date-clear:hover,
  .contact-form__date-clear:focus-visible {
    color: var(--color-text);
    background: var(--color-surface-alt);
    outline: none;
  }

  .contact-form__field textarea {
    resize: vertical;
    min-height: 10rem;
  }

  .contact-form__actions {
    grid-column: 1 / -1;
    display: flex;
    justify-content: center;
    margin-top: var(--space-xs);
  }

  .contact-form__honeypot {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .booking-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .contact-form {
      grid-template-columns: 1fr;
    }

    :global(.contact-form-ooze) {
      width: 60px;
      transform: translate(0, 100%);
    }
  }
</style>
