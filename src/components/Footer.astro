---
/**
 * Site footer with compact center content, social row, and credential logos.
 * Reads logos, nav items, social links, and legal link from site settings.
 */
import { siteConfig } from "../config";
import { getSiteSettings } from "../lib/settings";
import SocialLinks from "./ui/SocialLinks.astro";
import { getSafeHref, isSafeExternalUrl } from "../lib/links";

const settings = await getSiteSettings();
const leftLogo = settings.footerLogos[0];
const rightLogo = settings.footerLogos[1];
const navItems = settings.navItems;
const footerCopyright = settings.footerCopyrightText || siteConfig.copyright;
const tagline = settings.siteDescription || siteConfig.description;
const safeCodeOfConductUrl = getSafeHref(settings.codeOfConductUrl) || "/code-of-conduct";
const footerDisclaimerText =
  settings.footerDisclaimerText ||
  "Ghostbusters and all related trademarks are property of Sony Pictures Entertainment Inc. GBVA is an independent fan group with no commercial affiliation.";
const reducedMotionToggleLabel = settings.reducedMotionToggleLabel || "Reduce motion";
const reducedMotionToggleTitle = settings.reducedMotionToggleTitle || reducedMotionToggleLabel;
const reducedMotionToggleEnabledLabel =
  settings.reducedMotionToggleEnabledLabel || "Motion reduced";

const socialLinks = settings.socialLinks
  .map((social) => {
    const href = isSafeExternalUrl(social.url) ? social.url : undefined;
    if (!href) return null;
    return {
      label: social.platform,
      href,
      icon: social.platform.toLowerCase(),
    };
  })
  .filter((social): social is NonNullable<typeof social> => Boolean(social));
---

<footer class="site-footer">
  <div class="footer-stripe" aria-hidden="true">
    <div class="caution-divider"></div>
  </div>
  <div class="container footer-shell">
    <div class="footer-main">
      <div class="footer-content">
        <p class="footer-tagline">{tagline}</p>

        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            {
              navItems.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  >
                    {link.label}
                    {link.external && <span class="sr-only"> (opens in new tab)</span>}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav class="footer-legal" aria-label="Legal links">
          <a href={safeCodeOfConductUrl}>{settings.codeOfConductLabel}</a>
        </nav>
      </div>

      <div class="footer-credentials" role="group" aria-label="Franchise and nonprofit credentials">
        {
          leftLogo && (
            <div class="footer-logo footer-logo--left">
              <img
                src={leftLogo.src}
                alt={leftLogo.alt}
                width="380"
                height="104"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }

        <SocialLinks
          links={socialLinks.map((social) => ({
            platform: social.label,
            url: social.href,
            icon: social.icon,
          }))}
          containerClass="footer-social"
          linkClass="footer-social-link"
        />

        {
          rightLogo && (
            <div class="footer-logo footer-logo--right">
              <img
                src={rightLogo.src}
                alt={rightLogo.alt}
                width="380"
                height="104"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }
      </div>
    </div>

    <p class="copyright">{footerCopyright}</p>
    <p class="footer-disclaimer">{footerDisclaimerText}</p>

    <button
      type="button"
      class="reduced-motion-toggle"
      aria-pressed="false"
      title={reducedMotionToggleTitle}
      data-label-on={reducedMotionToggleEnabledLabel}
      data-label-off={reducedMotionToggleLabel}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        ><circle cx="12" cy="12" r="10"></circle><line x1="4" y1="4" x2="20" y2="20"></line></svg
      >
      <span class="reduced-motion-toggle__label">{reducedMotionToggleLabel}</span>
    </button>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    margin-top: 0;
    padding-block: 0 var(--space-xl);
  }

  .footer-stripe {
    margin-bottom: var(--space-xl);
    line-height: 0;
  }

  .footer-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    width: 100%;
  }

  .footer-tagline {
    margin: 0;
    max-width: 36rem;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: rgba(255, 255, 255, 0.85);
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm) var(--space-md);
    padding: 0;
    margin: 0;
  }

  .footer-nav a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    color: #ffffff;
    transition: color var(--transition-fast);
    padding: 0.25rem 0.35rem;
    border-radius: var(--radius-sm);
  }

  .footer-nav a:hover,
  .footer-nav a:focus-visible {
    color: var(--color-gb-caution);
  }

  .footer-legal {
    display: flex;
    justify-content: center;
  }

  .footer-legal a {
    font-size: var(--text-sm);
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    transition: color var(--transition-fast);
  }

  .footer-legal a:hover,
  .footer-legal a:focus-visible {
    color: #ffffff;
  }

  :global(.site-footer .footer-nav a:link),
  :global(.site-footer .footer-nav a:visited) {
    color: #ffffff !important;
  }

  :global(.site-footer .footer-nav a:hover),
  :global(.site-footer .footer-nav a:focus-visible) {
    color: var(--color-gb-caution) !important;
  }

  :global(.site-footer .footer-legal a:link),
  :global(.site-footer .footer-legal a:visited) {
    color: rgba(255, 255, 255, 0.72) !important;
  }

  :global(.site-footer .footer-legal a:hover),
  :global(.site-footer .footer-legal a:focus-visible) {
    color: #ffffff !important;
  }

  :global(.footer-social) {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  :global(.footer-social-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.08);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  :global(.footer-social-link:hover),
  :global(.footer-social-link:focus-visible) {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.2);
  }

  :global(.footer-social-link svg) {
    width: 1.3rem;
    height: 1.3rem;
  }

  .footer-credentials {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: center;
    justify-items: center;
    width: 100%;
    max-width: 40rem;
  }

  .footer-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .footer-logo img {
    max-height: 96px;
    width: auto;
    object-fit: contain;
  }

  .copyright {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-disclaimer {
    margin: 0;
    max-width: 52rem;
    align-self: center;
    text-align: center;
    font-size: 0.6875rem;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.45);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding-block: 0 var(--space-xl);
    }

    .footer-stripe {
      margin-bottom: var(--space-2xl);
    }

    .footer-main {
      display: grid;
      grid-template-columns: minmax(13rem, 1fr) minmax(0, 42rem) minmax(13rem, 1fr);
      align-items: center;
      gap: var(--space-xl);
    }

    .footer-content {
      grid-column: 2;
      justify-self: center;
    }

    .footer-nav ul {
      gap: var(--space-sm) var(--space-lg);
    }

    .footer-credentials {
      grid-column: 1 / -1;
      grid-template-columns: minmax(13rem, 1fr) auto minmax(13rem, 1fr);
      gap: var(--space-lg);
      max-width: none;
    }

    .footer-logo--left {
      grid-column: 1;
      justify-content: center;
    }

    .footer-logo--right {
      grid-column: 3;
      justify-content: center;
    }

    :global(.footer-social) {
      grid-column: 2;
      align-self: center;
      justify-self: center;
    }

    :global(.footer-social-link) {
      width: 3rem;
      height: 3rem;
    }

    :global(.footer-social-link svg) {
      width: 1.45rem;
      height: 1.45rem;
    }

    .footer-logo img {
      max-height: 132px;
    }
  }

  .reduced-motion-toggle {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: var(--space-sm);
    padding: 0.3rem 0.6rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    background: transparent;
    color: rgba(255, 255, 255, 0.5);
    font-family: var(--font-body);
    font-size: 0.7rem;
    cursor: pointer;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
    align-self: center;
    justify-self: center;
  }

  .reduced-motion-toggle:hover,
  .reduced-motion-toggle:focus-visible {
    color: rgba(255, 255, 255, 0.85);
    border-color: rgba(255, 255, 255, 0.35);
  }

  .reduced-motion-toggle[aria-pressed="true"] {
    color: var(--color-gb-caution);
    border-color: var(--color-gb-caution);
  }

  .reduced-motion-toggle svg {
    width: 0.85rem;
    height: 0.85rem;
    flex-shrink: 0;
  }
</style>

<script>
  /**
   * Reduced-motion toggle — stores preference in localStorage and sets
   * a class on <html> so CSS can respond site-wide.
   */
  (function initReducedMotionToggle() {
    const STORAGE_KEY = "gbva-reduce-motion";
    const CSS_CLASS = "reduce-motion";

    function apply(enabled: boolean): void {
      document.documentElement.classList.toggle(CSS_CLASS, enabled);
      document.querySelectorAll<HTMLButtonElement>(".reduced-motion-toggle").forEach((btn) => {
        btn.setAttribute("aria-pressed", String(enabled));
        const label = btn.querySelector(".reduced-motion-toggle__label");
        const labelOn = btn.dataset.labelOn || "Motion reduced";
        const labelOff = btn.dataset.labelOff || "Reduce motion";
        if (label) label.textContent = enabled ? labelOn : labelOff;
      });
    }

    // Restore saved preference
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved === "true") apply(true);

    // Listen for clicks
    document.querySelectorAll<HTMLButtonElement>(".reduced-motion-toggle").forEach((btn) => {
      btn.addEventListener("click", () => {
        const next = btn.getAttribute("aria-pressed") !== "true";
        localStorage.setItem(STORAGE_KEY, String(next));
        apply(next);
      });
    });
  })();
</script>
