---
/**
 * Site footer with compact center content, social row, and credential logos.
 * Reads logos, nav items, social links, and legal link from CMS settings.
 */
import { siteConfig } from "../config";
import { getSiteSettings } from "../lib/settings";
import SocialLinks from "./ui/SocialLinks.astro";
import { getSafeCmsHref, isSafeExternalUrl } from "../lib/links";

const settings = await getSiteSettings();
const leftLogo = settings.footerLogos[0];
const rightLogo = settings.footerLogos[1];
const navItems = settings.navItems
  .map((link) => {
    const href = getSafeCmsHref(link.href);
    if (!href) return null;
    return { ...link, href };
  })
  .filter((link): link is NonNullable<typeof link> => Boolean(link));
const footerCopyright = settings.footerCopyrightText || siteConfig.copyright;
const tagline = settings.siteDescription || siteConfig.description;
const safeCodeOfConductUrl = getSafeCmsHref(settings.codeOfConductUrl) || "/code-of-conduct";

const findSocial = (platform: string) => {
  const candidate = settings.socialLinks.find(
    (s) => s.platform.toLowerCase() === platform.toLowerCase(),
  )?.url;
  return isSafeExternalUrl(candidate) ? candidate : undefined;
};

const socialLinks = [
  {
    label: "Facebook",
    href: findSocial("facebook") || "https://www.facebook.com/Ghostbusters.Virginia.757",
    icon: "facebook",
  },
  {
    label: "Instagram",
    href: findSocial("instagram") || "https://www.instagram.com/ghostbustersva/",
    icon: "instagram",
  },
  {
    label: "TikTok",
    href: findSocial("tiktok") || "https://www.tiktok.com/@ghostbustersvirginia",
    icon: "tiktok",
  },
  {
    label: "YouTube",
    href: findSocial("youtube") || "https://www.youtube.com/@Ghostbusters_Virginia",
    icon: "youtube",
  },
];
---

<footer class="site-footer">
  <div class="footer-stripe" aria-hidden="true">
    <div class="caution-divider"></div>
  </div>
  <div class="container footer-shell">
    <div class="footer-main">
      <div class="footer-content">
        <p class="footer-tagline">{tagline}</p>

        <nav class="footer-nav" aria-label="Footer navigation">
          <ul>
            {
              navItems.map((link) => (
                <li>
                  <a
                    href={link.href}
                    {...(link.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                  >
                    {link.label}
                    {link.external && <span class="sr-only"> (opens in new tab)</span>}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav class="footer-legal" aria-label="Legal links">
          <a href={safeCodeOfConductUrl}>{settings.codeOfConductLabel}</a>
        </nav>
      </div>

      <div class="footer-credentials" role="group" aria-label="Franchise and nonprofit credentials">
        {
          leftLogo && (
            <div class="footer-logo footer-logo--left">
              <img
                src={leftLogo.src}
                alt={leftLogo.alt}
                width="380"
                height="104"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }

        <SocialLinks
          links={socialLinks.map((social) => ({
            platform: social.label,
            url: social.href,
            icon: social.icon,
          }))}
          containerClass="footer-social"
          linkClass="footer-social-link"
        />

        {
          rightLogo && (
            <div class="footer-logo footer-logo--right">
              <img
                src={rightLogo.src}
                alt={rightLogo.alt}
                width="380"
                height="104"
                loading="lazy"
                decoding="async"
              />
            </div>
          )
        }
      </div>
    </div>

    <p class="copyright">{footerCopyright}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-footer-bg);
    color: var(--color-footer-text);
    margin-top: 0;
    padding-block: 0 var(--space-xl);
  }

  .footer-stripe {
    margin-bottom: var(--space-xl);
    line-height: 0;
  }

  .footer-shell {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .footer-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-md);
    width: 100%;
  }

  .footer-tagline {
    margin: 0;
    max-width: 36rem;
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: rgba(255, 255, 255, 0.85);
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-sm) var(--space-md);
    padding: 0;
    margin: 0;
  }

  .footer-nav a {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
    color: #ffffff;
    transition: color var(--transition-fast);
    padding: 0.25rem 0.35rem;
    border-radius: var(--radius-sm);
  }

  .footer-nav a:hover,
  .footer-nav a:focus-visible {
    color: var(--color-gb-caution);
  }

  .footer-legal {
    display: flex;
    justify-content: center;
  }

  .footer-legal a {
    font-size: var(--text-sm);
    text-decoration: none;
    color: rgba(255, 255, 255, 0.72);
    transition: color var(--transition-fast);
  }

  .footer-legal a:hover,
  .footer-legal a:focus-visible {
    color: #ffffff;
  }

  :global(.site-footer .footer-nav a:link),
  :global(.site-footer .footer-nav a:visited) {
    color: #ffffff !important;
  }

  :global(.site-footer .footer-nav a:hover),
  :global(.site-footer .footer-nav a:focus-visible) {
    color: var(--color-gb-caution) !important;
  }

  :global(.site-footer .footer-legal a:link),
  :global(.site-footer .footer-legal a:visited) {
    color: rgba(255, 255, 255, 0.72) !important;
  }

  :global(.site-footer .footer-legal a:hover),
  :global(.site-footer .footer-legal a:focus-visible) {
    color: #ffffff !important;
  }

  :global(.footer-social) {
    display: flex;
    justify-content: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  :global(.footer-social-link) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius-md);
    color: rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.08);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  :global(.footer-social-link:hover),
  :global(.footer-social-link:focus-visible) {
    color: #ffffff;
    background: rgba(255, 255, 255, 0.2);
  }

  :global(.footer-social-link svg) {
    width: 1.3rem;
    height: 1.3rem;
  }

  .footer-credentials {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: center;
    justify-items: center;
    width: 100%;
    max-width: 40rem;
  }

  .footer-logo {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .footer-logo img {
    max-height: 96px;
    width: auto;
    object-fit: contain;
  }

  .copyright {
    margin: 0;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.55);
    text-align: center;
    padding-top: var(--space-md);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (min-width: 768px) {
    .site-footer {
      padding-block: 0 var(--space-xl);
    }

    .footer-stripe {
      margin-bottom: var(--space-2xl);
    }

    .footer-main {
      display: grid;
      grid-template-columns: minmax(13rem, 1fr) minmax(0, 42rem) minmax(13rem, 1fr);
      align-items: center;
      gap: var(--space-xl);
    }

    .footer-content {
      grid-column: 2;
      justify-self: center;
    }

    .footer-nav ul {
      gap: var(--space-sm) var(--space-lg);
    }

    .footer-credentials {
      grid-column: 1 / -1;
      grid-template-columns: minmax(13rem, 1fr) auto minmax(13rem, 1fr);
      gap: var(--space-lg);
      max-width: none;
    }

    .footer-logo--left {
      grid-column: 1;
      justify-content: center;
    }

    .footer-logo--right {
      grid-column: 3;
      justify-content: center;
    }

    :global(.footer-social) {
      grid-column: 2;
      align-self: center;
      justify-self: center;
    }

    :global(.footer-social-link) {
      width: 3rem;
      height: 3rem;
    }

    :global(.footer-social-link svg) {
      width: 1.45rem;
      height: 1.45rem;
    }

    .footer-logo img {
      max-height: 132px;
    }
  }
</style>
