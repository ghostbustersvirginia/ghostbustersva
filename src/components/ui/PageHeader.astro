---
interface Props {
  title: string;
  subtitle: string;
  id?: string;
  class?: string;
}

const { title, subtitle, id, class: className = "" } = Astro.props;
---

<header class:list={["page-header", className]}>
  <h1 id={id} class="page-title">{title}</h1>
  <p class="page-intro">{subtitle}</p>
</header>

<style>
  .page-header {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
</style>
