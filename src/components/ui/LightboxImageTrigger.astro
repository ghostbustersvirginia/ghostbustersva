---
/**
 * LightboxImageTrigger — small reusable component for lightbox image buttons.
 *
 * Encapsulates button wrapper, data-lightbox-* attributes, aria-label, and overlay icon.
 */
interface Props {
  group: string;
  src: string;
  alt: string;
  caption?: string;
  buttonClass?: string;
  overlayClass?: string;
  ariaLabel?: string;
  buttonStyle?: string;
}

const {
  group,
  src,
  alt,
  caption,
  buttonClass = "page-image-lightbox",
  overlayClass = "page-image-lightbox__overlay",
  ariaLabel,
  buttonStyle,
} = Astro.props;

const computedAriaLabel = ariaLabel || `View full image: ${alt}`;
---

<button
  class={buttonClass}
  type="button"
  aria-label={computedAriaLabel}
  style={buttonStyle}
  data-lightbox-group={group}
  data-lightbox-src={src}
  data-lightbox-alt={alt}
  {...(caption ? { "data-lightbox-caption": caption } : {})}
>
  <slot />
  <span class={overlayClass} aria-hidden="true">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <polyline points="15 3 21 3 21 9" />
      <polyline points="9 21 3 21 3 15" />
      <line x1="21" y1="3" x2="14" y2="10" />
      <line x1="3" y1="21" x2="10" y2="14" />
    </svg>
  </span>
</button>
