---
/**
 * Button — Primary and secondary button component.
 * PRD 002: Theme and Design Foundation
 *
 * Renders as <a> when `href` is provided, <button> otherwise.
 * Accessible focus styles, no page-specific hardcoding.
 *
 * @example
 * <Button variant="primary" href="/join">Join the Team</Button>
 * <Button variant="secondary">Cancel</Button>
 */
interface Props {
  /** Visual variant */
  variant?: "primary" | "secondary" | "secondary-alt";
  /** When provided, renders as an <a> tag */
  href?: string;
  /** Button type attribute (only for <button>) */
  type?: "button" | "submit" | "reset";
  /** Additional CSS class names */
  class?: string;
  /** Disabled state */
  disabled?: boolean;
  /** Open link in new tab */
  external?: boolean;
  /** Optional trailing icon */
  icon?: "arrow-right" | "heart";
  /** Element ID */
  id?: string;
  /** Hidden state */
  hidden?: boolean;
}

import { getSafeHref } from "../../lib/links";

const {
  variant = "primary",
  href,
  type = "button",
  class: className = "",
  disabled = false,
  external = false,
  icon,
  id,
  hidden,
} = Astro.props;

const safeHref = getSafeHref(href);
const externalAttrs = external ? { target: "_blank", rel: "noopener noreferrer" } : {};
---

{
  safeHref ? (
    <a
      href={safeHref}
      class:list={["btn", `btn--${variant}`, className]}
      {...externalAttrs}
      aria-disabled={disabled || undefined}
      id={id}
      hidden={hidden}
      data-trailing-icon={external ? "external" : icon}
    >
      <slot />
      {external && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </svg>
        </span>
      )}
      {icon === "arrow-right" && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      )}
      {icon === "heart" && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
          </svg>
        </span>
      )}
      {external && <span class="sr-only"> (opens in new tab)</span>}
    </a>
  ) : (
    <button
      type={type}
      class:list={["btn", `btn--${variant}`, className]}
      disabled={disabled}
      id={id}
      hidden={hidden}
      data-trailing-icon={icon}
    >
      <slot />
      {icon === "arrow-right" && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </span>
      )}
      {icon === "heart" && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
          </svg>
        </span>
      )}
      {icon === "heart" && (
        <span class="btn-trailing-icon" aria-hidden="true">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" />
          </svg>
        </span>
      )}
    </button>
  )
}

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.625rem 1.5rem;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-decoration: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition:
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      box-shadow var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
    border: 2px solid transparent;
    line-height: var(--leading-tight);
    white-space: nowrap;
    position: relative;
  }

  .btn[data-trailing-icon] {
    padding-left: 2.95rem;
    padding-right: 2.45rem;
  }

  .btn-trailing-icon {
    right: 0.65rem;
    top: 50%;
    transform: translateY(-50%) translateX(-4px);
    opacity: 0;
    position: static;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 0;
    margin-left: 0;
    overflow: hidden;
    pointer-events: none;
    transition:
      width var(--transition-fast),
      margin-left var(--transition-fast),
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .btn:hover .btn-trailing-icon,
  .btn:focus-visible .btn-trailing-icon {
    width: 1.05em;
    margin-left: 0.4rem;
    opacity: 1;
    transform: scale(1);
  }

  @keyframes heart-wiggle-inline {
    0% {
      transform: translateX(0) rotate(0deg) scale(1);
    }
    30% {
      transform: translateX(0) rotate(-8deg) scale(1.05);
    }
    60% {
      transform: translateX(0) rotate(7deg) scale(1.03);
    }
    100% {
      transform: translateX(0) rotate(0deg) scale(1);
    }
  }

  .btn[data-trailing-icon="heart"]:hover .btn-trailing-icon,
  .btn[data-trailing-icon="heart"]:focus-visible .btn-trailing-icon {
    animation: heart-wiggle-inline 0.45s ease-out;
    transform-origin: 50% 60%;
  }

  @keyframes heart-wiggle-inline {
    0% {
      transform: translateX(0) rotate(0deg) scale(1);
    }
    30% {
      transform: translateX(0) rotate(-8deg) scale(1.05);
    }
    60% {
      transform: translateX(0) rotate(7deg) scale(1.03);
    }
    100% {
      transform: translateX(0) rotate(0deg) scale(1);
    }
  }

  .btn[data-trailing-icon="heart"]:hover .btn-trailing-icon,
  .btn[data-trailing-icon="heart"]:focus-visible .btn-trailing-icon {
    animation: heart-wiggle-inline 0.45s ease-out;
    transform-origin: 50% 60%;
  }

  .btn[data-trailing-icon="heart"] {
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }

  .btn[data-trailing-icon="heart"] .btn-trailing-icon {
    position: static;
    right: auto;
    top: auto;
    width: 0;
    margin-left: 0;
    opacity: 0;
    overflow: hidden;
    transform: scale(0.94);
    transition:
      width var(--transition-fast),
      margin-left var(--transition-fast),
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .btn[data-trailing-icon="heart"]:hover .btn-trailing-icon,
  .btn[data-trailing-icon="heart"]:focus-visible .btn-trailing-icon {
    width: 1.05em;
    margin-left: 0.4rem;
    opacity: 1;
    transform: scale(1);
  }

  /* Primary — solid fill */
  .btn--primary {
    background: var(--color-action-primary);
    color: var(--color-text-inverse);
    border-color: var(--color-action-primary);
  }

  .btn--primary:hover,
  .btn--primary:focus-visible {
    background: var(--color-action-primary-hover);
    border-color: var(--color-action-primary-hover);
    box-shadow: 0 2px 8px var(--color-glow);
    transform: translateY(-1px);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  /* Secondary — light green tint + green border */
  .btn--secondary {
    background: var(--color-action-secondary-bg);
    color: var(--color-text);
    border-color: var(--color-action-secondary-border);
  }

  .btn--secondary:hover,
  .btn--secondary:focus-visible {
    border-color: var(--color-action-secondary-hover-border);
    color: var(--color-text);
    background: var(--color-action-secondary-hover-bg);
    box-shadow: 0 2px 8px var(--color-glow-green);
    transform: translateY(-1px);
  }

  .btn--secondary:active {
    transform: translateY(0);
  }

  /* Secondary-alt — light green tint, for use on tinted/alt backgrounds */
  .btn--secondary-alt {
    background: var(--color-action-secondary-bg);
    color: var(--color-text);
    border-color: var(--color-action-secondary-border);
  }

  .btn--secondary-alt:hover,
  .btn--secondary-alt:focus-visible {
    border-color: var(--color-action-secondary-hover-border);
    color: var(--color-text);
    background: var(--color-action-secondary-hover-bg);
    box-shadow: 0 2px 8px var(--color-glow-green);
    transform: translateY(-1px);
  }

  .btn--secondary-alt:active {
    transform: translateY(0);
  }

  /* Focus */
  .btn:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* Disabled */
  .btn:disabled,
  .btn[aria-disabled="true"] {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  /* Large variant — used on hero, full-bleed CTAs */
  .btn--lg {
    padding: 0.75rem 1.75rem;
    font-size: var(--text-base);
  }

  .btn--lg[data-trailing-icon] {
    padding-left: 3.2rem;
    padding-right: 3.2rem;
  }

  .btn--lg[data-trailing-icon="heart"] {
    padding-left: 1.75rem;
    padding-right: 1.75rem;
  }

  /* Hidden — respect the native hidden attribute */
  .btn[hidden] {
    display: none;
  }
</style>
