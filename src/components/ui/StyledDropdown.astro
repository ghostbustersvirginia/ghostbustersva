---
/**
 * StyledDropdown — Accessible custom select widget.
 *
 * Progressive enhancement: native <select> is fully functional when JS
 * is unavailable. Once JS runs, the widget gains an `.is-enhanced` class
 * that visually hides the native select and activates the custom listbox.
 *
 * The native <select> stays in the DOM throughout so the form always
 * submits the correct value. A `change` event is dispatched on it whenever
 * the user picks an option, keeping any external listeners (e.g. the
 * contact-form-client.js inquiry-type handler) working without changes.
 */

export interface DropdownOption {
  value: string;
  label: string;
}

interface Props {
  /** Base ID used to wire all ARIA relationships */
  id: string;
  /** Native select `name` — used for form submission */
  name: string;
  /** Visible label text */
  label: string;
  /** Selectable options */
  options: DropdownOption[];
  /** Text shown when no option is selected */
  placeholder?: string;
  /** Whether the field is required */
  required?: boolean;
  /** Optional hint text shown below the label */
  hint?: string;
  /** Pre-selected value */
  value?: string;
}

const {
  id,
  name,
  label,
  options,
  placeholder = "Select an option",
  required = false,
  hint,
  value = "",
} = Astro.props;

const labelId = `${id}-label`;
const triggerId = `${id}-trigger`;
const triggerTextId = `${id}-trigger-text`;
const listboxId = `${id}-listbox`;
const announcerId = `${id}-announcer`;
const hintId = hint ? `${id}-hint` : undefined;

const selectedOption = options.find((opt) => opt.value === value);
const triggerText = selectedOption?.label ?? placeholder;
const isPlaceholder = !selectedOption;
---

<div class="styled-dropdown" id={`${id}-container`} data-dropdown-id={id}>
  <span id={labelId} class="styled-dropdown__label">{label}</span>

  {
    hint && (
      <p id={hintId} class="styled-dropdown__hint">
        {hint}
      </p>
    )
  }

  <div class="styled-dropdown__control">
    <!-- Custom trigger button — matches input styling -->
    <button
      type="button"
      id={triggerId}
      class="styled-dropdown__trigger"
      aria-haspopup="listbox"
      aria-expanded="false"
      aria-controls={listboxId}
      aria-labelledby={`${labelId} ${triggerTextId}`}
      aria-required={required ? "true" : undefined}
      aria-describedby={hintId}
      aria-activedescendant=""
      data-placeholder={isPlaceholder ? "" : undefined}
    >
      <span id={triggerTextId} class="styled-dropdown__trigger-text">
        {triggerText}
      </span>
      <svg
        class="styled-dropdown__chevron"
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        focusable="false"
      >
        <path d="M6 9l6 6 6-6"></path>
      </svg>
    </button>

    <!-- Custom listbox panel — absolutely positioned below the trigger -->
    <ul
      id={listboxId}
      role="listbox"
      class="styled-dropdown__list"
      aria-labelledby={labelId}
      tabindex="-1"
    >
      {
        options.map((opt) => (
          <li
            id={`${id}-opt-${opt.value.replace(/[^a-z0-9]/gi, "-").toLowerCase()}`}
            role="option"
            class:list={["styled-dropdown__option", { "is-selected": opt.value === value }]}
            data-value={opt.value}
            aria-selected={opt.value === value ? "true" : "false"}
          >
            {opt.label}
          </li>
        ))
      }
    </ul>

    <!--
      Native select — visible fallback without JS.
      Once JS runs and `.is-enhanced` is applied, it is covered by CSS so
      validation tooltips still appear near the trigger, and the form can
      still read and submit its value.
    -->
    <select
      id={id}
      name={name}
      class="styled-dropdown__native"
      required={required || undefined}
      tabindex="-1"
    >
      <option value="" disabled selected={!value || undefined}>{placeholder}</option>
      {
        options.map((opt) => (
          <option value={opt.value} selected={opt.value === value || undefined}>
            {opt.label}
          </option>
        ))
      }
    </select>
  </div>

  <!-- Screen-reader announcer: announces each selection change -->
  <span id={announcerId} class="styled-dropdown__announcer" aria-live="polite" aria-atomic="true"
  ></span>
</div>

<style>
  /* ---- Root layout ---- */
  .styled-dropdown {
    display: grid;
    gap: var(--space-xs);
  }

  /* ---- Label ---- */
  .styled-dropdown__label {
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    color: var(--color-text);
    cursor: default;
  }

  /* ---- Hint text ---- */
  .styled-dropdown__hint {
    margin: 0;
    margin-top: calc(var(--space-xs) * -0.5);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ---- Control wrapper (anchor for the absolute listbox) ---- */
  .styled-dropdown__control {
    position: relative;
  }

  /* ---- Trigger button — matches native input/select appearance ---- */
  .styled-dropdown__trigger {
    appearance: none;
    -webkit-appearance: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    color: var(--color-text);
    padding: 0.625rem 0.75rem;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    text-align: left;
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      box-shadow var(--transition-fast);
  }

  /* Placeholder state: muted text colour when nothing is selected */
  .styled-dropdown__trigger[data-placeholder] .styled-dropdown__trigger-text {
    color: var(--color-text-muted);
  }

  .styled-dropdown__trigger:hover {
    border-color: var(--color-text-muted);
  }

  .styled-dropdown__trigger:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 1px;
    border-color: var(--color-focus);
  }

  /* Open state highlight */
  .styled-dropdown.is-open .styled-dropdown__trigger {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-focus-accent);
  }

  /* ---- Chevron icon ---- */
  .styled-dropdown__chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition:
      transform var(--transition-fast),
      color var(--transition-fast);
  }

  .styled-dropdown.is-open .styled-dropdown__chevron {
    transform: rotate(180deg);
    color: var(--color-accent);
  }

  /* ---- Dropdown panel ---- */
  .styled-dropdown__list {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    right: 0;
    z-index: 200;
    list-style: none;
    margin: 0;
    padding: var(--space-xs) 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-hover);
    max-height: 14rem;
    overflow-y: auto;
  }

  .styled-dropdown.is-open .styled-dropdown__list {
    display: block;
  }

  /* ---- Options ---- */
  .styled-dropdown__option {
    padding: 0.5rem 0.875rem;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: var(--leading-normal);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  /* Keyboard-active / hovered option */
  .styled-dropdown__option.is-active {
    background-color: var(--color-surface-alt);
    color: var(--color-accent);
  }

  /* Currently selected option */
  .styled-dropdown__option.is-selected {
    color: var(--color-accent);
    font-weight: var(--weight-semibold);
  }

  .styled-dropdown__option.is-selected.is-active {
    background-color: var(--color-surface-alt);
  }

  /* ---- Native select: visible by default, hidden once JS enhances ---- */
  .styled-dropdown.is-enhanced .styled-dropdown__native {
    /*
     * Cover the trigger button so browser validation tooltips appear in the
     * right place. Invisible and non-interactive via opacity + pointer-events.
     * tabindex="-1" in HTML keeps it out of the tab order.
     */
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    border: 0;
    margin: 0;
    padding: 0;
  }

  /* ---- Screen-reader announcer ---- */
  .styled-dropdown__announcer {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* ---- Reduced motion ---- */
  @media (prefers-reduced-motion: reduce) {
    .styled-dropdown__trigger,
    .styled-dropdown__chevron,
    .styled-dropdown__option {
      transition: none;
    }
  }
</style>

<script>
  function initStyledDropdown(container: HTMLElement) {
    const id = container.dataset.dropdownId;
    if (!id) return;

    const triggerEl = document.getElementById(`${id}-trigger`);
    const listboxEl = document.getElementById(`${id}-listbox`);
    const nativeEl = document.getElementById(id);

    if (!triggerEl || !listboxEl || !nativeEl) return;

    // Re-bind as concrete non-null types so TypeScript doesn't lose the narrowing inside closures.
    const trigger = triggerEl as HTMLButtonElement;
    const listbox = listboxEl as HTMLUListElement;
    const native = nativeEl as HTMLSelectElement;
    const announcer = document.getElementById(`${id}-announcer`) as HTMLElement | null;

    const optionEls = Array.from(listbox.querySelectorAll<HTMLLIElement>('[role="option"]'));
    let activeIdx = -1;

    // Mark as enhanced — hides the native select via CSS and shows the custom widget.
    container.classList.add("is-enhanced");
    // Remove native select from AT so the custom widget is the sole source of truth.
    native.setAttribute("aria-hidden", "true");

    const isOpen = () => container.classList.contains("is-open");

    function getSelectedIdx() {
      return optionEls.findIndex((o) => o.classList.contains("is-selected"));
    }

    function setActive(idx: number) {
      optionEls.forEach((o) => o.classList.remove("is-active"));
      activeIdx = Math.max(0, Math.min(idx, optionEls.length - 1));
      const opt = optionEls[activeIdx];
      if (!opt) return;
      opt.classList.add("is-active");
      trigger.setAttribute("aria-activedescendant", opt.id);
      opt.scrollIntoView({ block: "nearest" });
    }

    function open() {
      container.classList.add("is-open");
      trigger.setAttribute("aria-expanded", "true");
      const startIdx = getSelectedIdx();
      setActive(startIdx >= 0 ? startIdx : 0);
    }

    function close(refocus = true) {
      container.classList.remove("is-open");
      trigger.setAttribute("aria-expanded", "false");
      trigger.setAttribute("aria-activedescendant", "");
      optionEls.forEach((o) => o.classList.remove("is-active"));
      activeIdx = -1;
      if (refocus) trigger.focus();
    }

    function selectOption(opt: HTMLLIElement) {
      const val = opt.dataset.value ?? "";
      const label = opt.textContent?.trim() ?? "";

      // Update listbox ARIA state
      optionEls.forEach((o) => {
        o.classList.remove("is-selected");
        o.setAttribute("aria-selected", "false");
      });
      opt.classList.add("is-selected");
      opt.setAttribute("aria-selected", "true");

      // Update visible trigger text and clear placeholder colouring
      const textSpan = trigger.querySelector(".styled-dropdown__trigger-text");
      if (textSpan) textSpan.textContent = label;
      trigger.removeAttribute("data-placeholder");

      // Sync the hidden native select so the form submits the correct value,
      // and fire a change event so any external listeners still work.
      native.value = val;
      native.dispatchEvent(new Event("change", { bubbles: true }));

      // Announce the selection to screen readers
      if (announcer) announcer.textContent = `${label} selected`;

      close();
    }

    // --- Trigger interactions ---

    trigger.addEventListener("click", () => {
      isOpen() ? close() : open();
    });

    trigger.addEventListener("keydown", (e) => {
      switch (e.key) {
        case "ArrowDown":
          e.preventDefault();
          isOpen() ? setActive(activeIdx + 1) : open();
          break;
        case "ArrowUp":
          e.preventDefault();
          if (isOpen()) setActive(activeIdx - 1);
          break;
        case "Enter":
        case " ":
          e.preventDefault();
          if (isOpen() && activeIdx >= 0) selectOption(optionEls[activeIdx]);
          else open();
          break;
        case "Escape":
          e.preventDefault();
          if (isOpen()) close();
          break;
        case "Tab":
          // Let Tab move focus naturally; close without refocusing the trigger.
          if (isOpen()) close(false);
          break;
      }
    });

    // --- Option interactions ---

    optionEls.forEach((opt, i) => {
      opt.addEventListener("mouseenter", () => {
        optionEls.forEach((o) => o.classList.remove("is-active"));
        activeIdx = i;
        opt.classList.add("is-active");
        trigger.setAttribute("aria-activedescendant", opt.id);
      });
      opt.addEventListener("click", () => selectOption(opt));
    });

    // --- Click-outside to close ---

    document.addEventListener("click", (e) => {
      if (isOpen() && !container.contains(e.target as Node)) {
        close(false);
      }
    });
  }

  document.querySelectorAll<HTMLElement>("[data-dropdown-id]").forEach(initStyledDropdown);
</script>
