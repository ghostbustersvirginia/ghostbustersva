---
/**
 * Lightbox — Shared full-screen media viewer dialog.
 * PRD 011: Layout, Hierarchy & Visual Polish — Phase 4
 *
 * Supports images, optional video (YouTube embeds), and prev/next navigation.
 * Includes keyboard handling (Escape, Arrow keys) and focus trap.
 *
 * Focus restoration contract:
 * - Opening code should set `lightbox.dataset.previousFocus` to the opener element id.
 * - If omitted, this component will capture the currently focused element as a fallback.
 *
 * Styles are global in theme.css. This component provides markup + behaviour.
 *
 * @example
 * <Lightbox id="gallery-lightbox" hasNav />
 * <Lightbox id="media-lightbox" hasVideo />
 */
interface Props {
  /** Unique element ID (also used to derive child IDs) */
  id?: string;
  /** Show prev/next navigation arrows */
  hasNav?: boolean;
  /** Include video (YouTube iframe) support */
  hasVideo?: boolean;
  /** Accessible label for the dialog */
  label?: string;
  /** Shared trigger group, matched via [data-lightbox-group] */
  lightboxGroup?: string;
}

const {
  id = "lightbox",
  hasNav = false,
  hasVideo = false,
  label = "Media viewer",
  lightboxGroup,
} = Astro.props;
---

<div
  class="lightbox"
  id={id}
  role="dialog"
  aria-modal="true"
  aria-label={label}
  {...lightboxGroup ? { "data-lightbox-group": lightboxGroup } : {}}
  hidden
>
  <button class="lightbox__close" type="button" aria-label="Close viewer">&times;</button>
  {
    hasNav && (
      <>
        <button class="lightbox__nav lightbox__nav--prev" type="button" aria-label="Previous image">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
        </button>
        <button class="lightbox__nav lightbox__nav--next" type="button" aria-label="Next image">
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 6 15 12 9 18" />
          </svg>
        </button>
      </>
    )
  }
  <div class="lightbox__content">
    <img class="lightbox__image" id={`${id}-image`} src="" alt="" />
    {
      hasVideo && (
        <div class="lightbox__video" id={`${id}-video`} hidden>
          <iframe
            id={`${id}-iframe`}
            src=""
            title=""
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          />
        </div>
      )
    }
    <p class="lightbox__caption" id={`${id}-caption`}></p>
  </div>
</div>

<script>
  import { setLightboxPreviousFocus } from "../../lib/lightbox";

  /** Shared lightbox behaviour — auto-initialises all .lightbox elements. */
  const FOCUSABLE =
    'button:not([disabled]), [href], input:not([disabled]), select:not([disabled]), textarea:not([disabled]), [tabindex]:not([tabindex="-1"])';
  const LIGHTBOX_INIT_ATTR = "data-lightbox-initialized";

  function openLightbox(
    lb: HTMLElement,
    triggers: HTMLButtonElement[],
    index: number,
    prefix: string,
  ): number {
    const image = lb.querySelector<HTMLImageElement>(".lightbox__image");
    const caption = lb.querySelector<HTMLParagraphElement>(".lightbox__caption");
    if (!image || triggers.length === 0) return index;

    const normalizedIndex = ((index % triggers.length) + triggers.length) % triggers.length;
    const trigger = triggers[normalizedIndex];
    const src = trigger.dataset.lightboxSrc ?? "";
    if (!src) return normalizedIndex;

    image.src = src;
    image.alt = trigger.dataset.lightboxAlt ?? "";

    if (caption) {
      caption.textContent = trigger.dataset.lightboxCaption ?? "";
    }

    setLightboxPreviousFocus(lb, trigger, prefix);
    lb.hidden = false;
    document.body.style.overflow = "hidden";
    lb.querySelector<HTMLButtonElement>(".lightbox__close")?.focus();
    lb.dispatchEvent(new CustomEvent("lightbox:open", { detail: { index: normalizedIndex } }));

    return normalizedIndex;
  }

  function initLightboxBehaviour() {
    // Close on Escape (global, handles whichever lightbox is open)
    document.addEventListener("keydown", (e) => {
      if (e.key !== "Escape") return;
      const open = document.querySelector<HTMLElement>(".lightbox:not([hidden])");
      if (open) closeLightbox(open);
    });

    // Per-lightbox event binding
    document.querySelectorAll<HTMLElement>(".lightbox").forEach((lb) => {
      if (lb.hasAttribute(LIGHTBOX_INIT_ATTR)) return;
      lb.setAttribute(LIGHTBOX_INIT_ATTR, "true");

      const closeBtn = lb.querySelector<HTMLButtonElement>(".lightbox__close");
      const group = lb.dataset.lightboxGroup;
      const getTriggers = () =>
        group
          ? Array.from(
              document.querySelectorAll<HTMLButtonElement>(
                `[data-lightbox-group="${group}"][data-lightbox-src]`,
              ),
            )
          : [];
      const navPrev = lb.querySelector<HTMLButtonElement>(".lightbox__nav--prev");
      const navNext = lb.querySelector<HTMLButtonElement>(".lightbox__nav--next");
      const focusPrefix = group || `${lb.id || "lightbox"}-trigger`;
      let currentIndex = 0;

      if (group) {
        document.addEventListener("click", (e) => {
          const target = (e.target as Element | null)?.closest<HTMLButtonElement>(
            `[data-lightbox-group="${group}"][data-lightbox-src]`,
          );
          if (!target) return;

          const triggers = getTriggers();
          const index = triggers.indexOf(target);
          if (index === -1) return;

          currentIndex = openLightbox(lb, triggers, index, focusPrefix);
        });
      }

      navPrev?.addEventListener("click", () => {
        const triggers = getTriggers();
        currentIndex = openLightbox(lb, triggers, currentIndex - 1, focusPrefix);
      });

      navNext?.addEventListener("click", () => {
        const triggers = getTriggers();
        currentIndex = openLightbox(lb, triggers, currentIndex + 1, focusPrefix);
      });

      const observer = new MutationObserver(() => {
        if (lb.hidden) return;
        if (lb.dataset.previousFocus) return;
        const active = document.activeElement as HTMLElement | null;
        if (!active || active === document.body) return;
        setLightboxPreviousFocus(lb, active, "lightbox-opener");
      });
      observer.observe(lb, { attributes: true, attributeFilter: ["hidden"] });

      // Close button
      closeBtn?.addEventListener("click", () => closeLightbox(lb));

      // Backdrop click
      lb.addEventListener("click", (e) => {
        const target = e.target as Element;
        if (target === lb || target.classList.contains("lightbox__content")) {
          closeLightbox(lb);
        }
      });

      // Focus trap
      lb.addEventListener("keydown", (e) => {
        if (e.key === "ArrowLeft" && navPrev && !lb.hidden) {
          e.preventDefault();
          navPrev.click();
          return;
        }

        if (e.key === "ArrowRight" && navNext && !lb.hidden) {
          e.preventDefault();
          navNext.click();
          return;
        }

        if (e.key !== "Tab") return;
        const focusable = Array.from(lb.querySelectorAll<HTMLElement>(FOCUSABLE));
        if (focusable.length === 0) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];

        if (e.shiftKey) {
          if (document.activeElement === first) {
            e.preventDefault();
            last.focus();
          }
        } else {
          if (document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }
      });
    });
  }

  function closeLightbox(lb: HTMLElement) {
    lb.hidden = true;
    document.body.style.overflow = "";
    // Clean up image/video src
    const img = lb.querySelector<HTMLImageElement>(".lightbox__image");
    if (img) img.src = "";
    const iframe = lb.querySelector<HTMLIFrameElement>("iframe");
    if (iframe) iframe.src = "";
    const video = lb.querySelector<HTMLElement>(".lightbox__video");
    if (video) video.hidden = true;
    if (img) img.hidden = false;
    // Restore previous focus (stored as data attribute)
    const prevId = lb.dataset.previousFocus;
    if (prevId) {
      const prev = document.getElementById(prevId);
      prev?.focus();
      delete lb.dataset.previousFocus;
    } else {
      // Fallback: blur to body
      (document.activeElement as HTMLElement)?.blur();
    }
    // Dispatch close event for page-specific cleanup
    lb.dispatchEvent(new CustomEvent("lightbox:close"));
  }

  // Run on DOMContentLoaded
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLightboxBehaviour);
  } else {
    initLightboxBehaviour();
  }
</script>
