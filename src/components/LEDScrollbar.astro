---
/**
 * LEDScrollbar.astro — Ghostbusters-themed scrolling LED dot-matrix marquee.
 * Rendering is delegated to the `readyled` library (ghostbustersva/readyled).
 *
 * readyled handles font-waiting, canvas rasterisation, LED painting, and the
 * CSS step-animation internally. This component owns only the outer housing
 * styles and bridges Astro props → readyled via data attributes.
 *
 * Respects `prefers-reduced-motion` (shows a static, non-scrolling sign).
 */

interface Props {
  /** Text to display on the LED sign */
  text?: string;
  /** Number of LED pixel rows — controls vertical resolution */
  pixelHeight?: number;
  /** Pixels scrolled per second (higher = faster) */
  scrollRate?: number;
  /** Font family for text rasterisation */
  font?: string;
  /** CSS colour for lit pixels */
  ledColor?: string;
  /** Glow colour (usually a semi-transparent version of ledColor) */
  ledGlow?: string;
  /** Diameter of each LED dot as css length */
  pixelSize?: string;
  /** Gap between LED dots as css length */
  pixelGap?: string;
  /** Desktop max width for readability */
  desktopMaxWidth?: string;
}

const {
  text = " WE'RE READY TO BELIEVE YOU!     (804) 482-1217  \u2014  ",
  pixelHeight = 9,
  scrollRate = 40,
  font = "Elan Bold",
  ledColor = "#00e676",
  ledGlow = "rgba(0, 230, 118, 0.6)",
  pixelSize = "3px",
  pixelGap = "0.1em",
  desktopMaxWidth = "42rem",
} = Astro.props;
---

<div
  class="led-scrollbar"
  style={`
    --led-desktop-max-width: ${desktopMaxWidth};
    --readyled-pixel-size: ${pixelSize};
    --readyled-pixel-gap: ${pixelGap};
    --readyled-pixel-color: ${ledColor};
    --readyled-pixel-off-color: #121212;
    --readyled-pixel-glow: ${ledGlow};
    --readyled-bg-color: #080808;`}
  data-led-text={text}
  data-led-pixel-height={String(pixelHeight)}
  data-led-scroll-rate={String(scrollRate)}
  data-led-font={font}
  role="marquee"
  aria-label={text.trim()}
></div>

<!-- Scoped: outer housing only -->
<style>
  .led-scrollbar {
    background: #080808;
    border: 2px solid #1a1a1a;
    border-radius: var(--radius-md, 6px);
    border-bottom-right-radius: 0;
    overflow: hidden;
    box-sizing: border-box;
    width: 100%;
    padding: 6px 0;
    box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.9);
    position: relative;
  }

  @media (min-width: 960px) {
    .led-scrollbar {
      max-width: min(100%, var(--led-desktop-max-width, 42rem));
      margin-inline: auto;
      padding-top: 8px;
      padding-bottom: 8px;
    }
  }
</style>

<!-- Global: readyled CSS + reduced-motion guards for its dynamically-created classes -->
<style is:global>
  @import "readyled/dist/readyled.css";

  /* Accessibility: pause scroll for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .readyled-sign-track.ready {
      animation: none;
    }
  }

  /* Also respect the site-wide reduced-motion toggle */
  .reduce-motion .readyled-sign-track.ready {
    animation: none;
  }
</style>

<script>
  import { readyLED } from "readyled/dist/readyled.js";

  /**
   * Initialise a single LED scrollbar using the readyled library.
   */
  async function initLEDScrollbar(el: HTMLElement): Promise<void> {
    const text = el.dataset.ledText ?? "";
    const pixelHeight = parseInt(el.dataset.ledPixelHeight ?? "9", 10);
    const scrollRate = parseInt(el.dataset.ledScrollRate ?? "40", 10);
    const font = el.dataset.ledFont ?? "sans-serif";

    await readyLED({
      target: el,
      text,
      pixelHeight,
      font,
      fallbackFont: "sans-serif",
      scrollSpeed: scrollRate,
    });
  }

  document
    .querySelectorAll<HTMLElement>(".led-scrollbar")
    .forEach((el) => {
      initLEDScrollbar(el);
    });
</script>
