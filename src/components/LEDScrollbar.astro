---
/**
 * LEDScrollbar.astro — Ghostbusters-themed scrolling LED dot-matrix marquee.
 *
 * How it works:
 *   1. Rasterises the text onto an off-screen <canvas> using the chosen font.
 *   2. Down-samples the canvas pixels into a boolean grid (ON / OFF).
 *   3. Paints the grid as glowing LED dots onto a second canvas.
 *   4. Exports the result as a PNG data-URL, duplicates it for a seamless loop,
 *      and scrolls with a pure CSS animation (GPU-composited translateX).
 *
 * Zero setInterval, zero DOM mutation after first paint, zero memory leaks.
 * Respects `prefers-reduced-motion` (shows a static, non-scrolling sign).
 *
 * Original LED-marquee concept by the GBVA dev team.
 * Optimised for Astro integration and web performance by Copilot.
 */

interface Props {
  /** Text to display on the LED sign */
  text?: string;
  /** Number of pixel rows — controls vertical resolution */
  pixelHeight?: number;
  /** Pixels scrolled per second (higher = faster) */
  scrollRate?: number;
  /** Font family for text rasterisation */
  font?: string;
  /** CSS colour for lit pixels */
  ledColor?: string;
  /** Glow colour (usually a semi-transparent version of ledColor) */
  ledGlow?: string;
  /** Diameter of each LED dot in px */
  pixelSize?: number;
  /** Gap between LED dots in px */
  pixelGap?: number;
  /** Desktop max width for readability */
  desktopMaxWidth?: string;
}

const {
  text = " WE'RE READY TO BELIEVE YOU!     (804) 482-1217  \u2014  ",
  pixelHeight = 9,
  scrollRate = 40,
  font = "Elan Bold",
  ledColor = "#00e676",
  ledGlow = "rgba(0, 230, 118, 0.6)",
  pixelSize = 3,
  pixelGap = 1,
  desktopMaxWidth = "42rem",
} = Astro.props;
---

<div
  class="led-scrollbar"
  style={`--led-desktop-max-width: ${desktopMaxWidth};`}
  data-led-text={text}
  data-led-pixel-height={String(pixelHeight)}
  data-led-scroll-rate={String(scrollRate)}
  data-led-font={font}
  data-led-color={ledColor}
  data-led-glow={ledGlow}
  data-led-pixel-size={String(pixelSize)}
  data-led-pixel-gap={String(pixelGap)}
  role="marquee"
  aria-label={text.trim()}
>
  <div class="led-viewport">
    <div class="led-track"></div>
  </div>
</div>

<style>
  .led-scrollbar {
    background: #080808;
    border: 2px solid #1a1a1a;
    border-radius: var(--radius-md, 6px);
    overflow: hidden;
    box-sizing: border-box;
    width: 100%;
    padding: 6px 0;
    box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.9);
    position: relative;
  }

  @media (min-width: 960px) {
    .led-scrollbar {
      max-width: min(100%, var(--led-desktop-max-width, 42rem));
      margin-inline: auto;
      padding-top: 8px;
      padding-bottom: 8px;
    }
  }

  .led-viewport {
    overflow: hidden;
  }

  .led-track {
    display: flex;
    width: max-content;
    will-change: transform;
  }

  .led-track.led-track--ready {
    animation: led-scroll var(--led-duration, 10s) steps(var(--led-columns)) infinite;
  }

  .led-track img {
    display: block;
    height: auto;
  }

  @keyframes led-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  /* Accessibility: stop animation for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .led-track.led-track--ready {
      animation: none;
    }
  }

  /* Also respect the site-wide reduced-motion toggle */
  :global(.reduce-motion) .led-track.led-track--ready {
    animation: none;
  }
</style>

<script>
  /**
   * Client-side initialiser for each <LEDScrollbar> instance.
   * Runs once after custom fonts have loaded.
   */
  function initLEDScrollbar(el: HTMLElement): void {
    const text = el.dataset.ledText ?? "";
    const pixelHeight = parseInt(el.dataset.ledPixelHeight ?? "9", 10);
    const scrollRate = parseInt(el.dataset.ledScrollRate ?? "40", 10);
    const font = el.dataset.ledFont ?? "sans-serif";
    const color = el.dataset.ledColor ?? "#00e676";
    const glow = el.dataset.ledGlow ?? "rgba(0,230,118,0.6)";
    const pxSize = parseInt(el.dataset.ledPixelSize ?? "3", 10);
    const pxGap = parseInt(el.dataset.ledPixelGap ?? "1", 10);

    const track = el.querySelector<HTMLElement>(".led-track");
    if (!track) return;

    /* ------------------------------------------------------------------
     * Step 1 — Rasterise text into a boolean pixel grid via <canvas>.
     *
     * We render the text at a large font size for accuracy, then
     * down-sample to the target pixelHeight to build the dot matrix.
     * ---------------------------------------------------------------- */
    const fontSize = 96;
    const tmpCanvas = document.createElement("canvas");
    const renderW = Math.ceil(fontSize * 1.2 * text.length);
    tmpCanvas.width = renderW;
    tmpCanvas.height = fontSize;

    const ctx = tmpCanvas.getContext("2d");
    if (!ctx) return;

    // White background, black text — we'll sample luminance later
    ctx.fillStyle = "#fff";
    ctx.fillRect(0, 0, renderW, fontSize);
    ctx.fillStyle = "#000";
    ctx.font = `${fontSize}px "${font}", sans-serif`;
    ctx.textBaseline = "middle";
    ctx.fillText(text, 0, fontSize / 2);

    // Use measureText for actual width so we don't waste pixels on whitespace
    const textW = Math.min(Math.ceil(ctx.measureText(text).width), renderW);
    const sampleW = Math.ceil((pixelHeight / fontSize) * textW);
    const src = ctx.getImageData(0, 0, renderW, fontSize).data;

    // Build the boolean grid row-by-row
    const grid: boolean[][] = [];
    for (let y = 0; y < pixelHeight; y++) {
      const row: boolean[] = [];
      for (let x = 0; x < sampleW; x++) {
        const sx = Math.floor((x / sampleW) * textW);
        const sy = Math.floor((y / pixelHeight) * fontSize);
        const i = (sy * renderW + sx) * 4;
        // ITU-R BT.601 luminance from RGB
        const lum = 0.299 * (src[i] ?? 0) + 0.587 * (src[i + 1] ?? 0) + 0.114 * (src[i + 2] ?? 0);
        row.push(lum < 128);
      }
      grid.push(row);
    }

    /* ------------------------------------------------------------------
     * Step 2 — Paint the LED visualisation onto a second canvas.
     *
     * Each boolean maps to a glowing dot (ON) or a dim dot (OFF),
     * giving the classic LED-sign look.
     * ---------------------------------------------------------------- */
    const step = pxSize + pxGap;
    const ledCanvas = document.createElement("canvas");
    ledCanvas.width = sampleW * step;
    ledCanvas.height = pixelHeight * step;

    const lctx = ledCanvas.getContext("2d");
    if (!lctx) return;

    // Dark housing background
    lctx.fillStyle = "#080808";
    lctx.fillRect(0, 0, ledCanvas.width, ledCanvas.height);

    const half = pxSize / 2;
    for (let y = 0; y < pixelHeight; y++) {
      for (let x = 0; x < sampleW; x++) {
        const cx = x * step + step / 2;
        const cy = y * step + step / 2;

        lctx.beginPath();
        lctx.arc(cx, cy, half, 0, Math.PI * 2);

        if (grid[y][x]) {
          // Lit pixel — colour + glow
          lctx.fillStyle = color;
          lctx.shadowColor = glow;
          lctx.shadowBlur = pxSize * 1.5;
          lctx.fill();
          lctx.shadowBlur = 0;
        } else {
          // Off pixel — faint dot (visible grid pattern)
          lctx.fillStyle = "#121212";
          lctx.fill();
        }
      }
    }

    /* ------------------------------------------------------------------
     * Step 3 — Export as a PNG image and duplicate for seamless loop.
     *
     * Two identical images sit side-by-side. The CSS animation scrolls
     * from 0 to −50 %, so when the first copy leaves the viewport the
     * second copy takes its place — seamless infinite scroll.
     * ---------------------------------------------------------------- */
    const url = ledCanvas.toDataURL("image/png");

    const img1 = new Image();
    img1.src = url;
    img1.alt = "";
    img1.setAttribute("aria-hidden", "true");

    const img2 = new Image();
    img2.src = url;
    img2.alt = "";
    img2.setAttribute("aria-hidden", "true");

    track.appendChild(img1);
    track.appendChild(img2);

    /* ------------------------------------------------------------------
     * Step 4 — Calculate animation duration from content width and
     * kick off the CSS animation by adding the --ready class.
     * ---------------------------------------------------------------- */
    const duration = ledCanvas.width / scrollRate;
    track.style.setProperty("--led-duration", `${duration}s`);
    track.style.setProperty("--led-columns", String(sampleW));
    track.classList.add("led-track--ready");
  }

  // Wait for custom fonts (Elan Bold) before rasterising
  document.fonts.ready.then(() => {
    document.querySelectorAll<HTMLElement>(".led-scrollbar").forEach(initLEDScrollbar);
  });
</script>
