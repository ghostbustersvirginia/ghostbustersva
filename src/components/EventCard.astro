---
import EventCardContent from "./EventCardContent.astro";
import { getResponsiveImageAttrs } from "../lib/images";
import { type EventEntry } from "../lib/events";
import { isSafeExternalUrl } from "../lib/links";

interface Props {
  event: EventEntry;
  showCountdown?: boolean;
  className?: string;
}

const { event, showCountdown = false, className } = Astro.props;

const safeUrl = isSafeExternalUrl(event.data.url) ? event.data.url : undefined;
const hasImage = Boolean(event.data.image);
const eventImage = hasImage
  ? await getResponsiveImageAttrs({
      src: event.data.image!,
      widths: [320, 480, 768, 960],
      sizes: "(max-width: 768px) 100vw, 280px",
      width: 960,
      height: 540,
      quality: 72,
    })
  : null;
---

<li class:list={["event-item", className]}>
  {
    safeUrl ? (
      <a href={safeUrl} target="_blank" rel="noopener noreferrer" class="event-link">
        <EventCardContent
          event={event}
          showCountdown={showCountdown}
          hasImage={hasImage}
          eventImage={eventImage}
        />
        <svg
          class="event-link__external"
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <>
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
            <polyline points="15 3 21 3 21 9" />
            <line x1="10" y1="14" x2="21" y2="3" />
          </>
        </svg>
      </a>
    ) : (
      <div class="event-link">
        <EventCardContent
          event={event}
          showCountdown={showCountdown}
          hasImage={hasImage}
          eventImage={eventImage}
        />
      </div>
    )
  }
</li>

<style>
  .event-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    position: relative;
    transition:
      border-color var(--transition-base),
      box-shadow var(--transition-base),
      transform var(--transition-base);
  }

  .event-item:hover {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-elevated-soft);
    transform: translateY(-2px);
  }

  .event-item--homepage-upcoming,
  .event-item--alt-bg {
    background: var(--color-surface-alt);
  }

  /* Live / "Happening now" — subtle highlight */
  .event-item--live {
    box-shadow: var(--shadow-hover);
  }

  .event-item--live:hover {
    border-color: var(--color-hover-border);
    box-shadow: var(--shadow-hover);
  }

  .event-link {
    display: flex;
    gap: var(--space-xl);
    align-items: flex-start;
    padding: var(--space-xl);
    text-decoration: none;
    color: inherit;
  }

  .event-link__external {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity var(--transition-fast);
    flex-shrink: 0;
  }

  /* Desktop-only: muted text that darkens on hover */
  @media (min-width: 769px) {
    .event-item {
      color: var(--color-text-muted);
    }
    .event-item:hover {
      color: var(--color-text);
    }
  }

  .event-item:hover .event-link__external {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .event-link {
      flex-direction: column;
      gap: var(--space-lg);
      padding: var(--space-lg);
    }
  }
</style>
